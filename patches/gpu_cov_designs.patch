+`ifdef VEER_GPU_COV_SIM_ACCEL
+task gpu_cov_load_program_hex_entries;
+bit [63:0] entry;
+bit [31:0] addr;
+bit [7:0] data;
+bit iccm_seen;
+bit dccm_seen;
+bit [31:0] iccm_start_addr;
+bit [31:0] iccm_end_addr;
+bit [31:0] dccm_start_addr;
+bit [31:0] dccm_end_addr;
+int unsigned i;
+int unsigned entry_count;
+
+entry_count = gpu_cov_program_entries[0][31:0];
+if (entry_count > (GPU_COV_PROGRAM_ENTRY_MAX - 1)) begin
+    $display("GPU cov sparse program image too large: %0d entries (max %0d)", entry_count,
+             GPU_COV_PROGRAM_ENTRY_MAX - 1);
+    $finish;
+end
+iccm_seen = 1'b0;
+dccm_seen = 1'b0;
+
+for (i = 0; i < entry_count; i++) begin
+    entry = gpu_cov_program_entries[i + 1];
+    addr = entry[31:0];
+    data = entry[39:32];
+    lmem.mem[addr] = data;
+    imem.mem[addr] = data;
