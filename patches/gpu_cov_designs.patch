+  logic [31:0] a_w;
+  logic [31:0] b_w;
+  logic [31:0] c_w;
+  logic [31:0] d_w;
+  logic [31:0] y_w;
+  logic [31:0] z_w;
+  logic [31:0] w_w;
+  logic [31:0] cfg_signature_w;
+  logic [31:0] progress_count_w;
+  logic [31:0] progress_signature_w;
+  logic [31:0] word_w [0:17];
+  logic [17:0] seen_bits_w;
+
+  example_gpu_cov_single_cluster_proof_dut dut (
+    .a(a_w),
+    .b(b_w),
+    .c(c_w),
+    .d(d_w),
+    .y(y_w),
+    .z(z_w),
+    .w(w_w)
+  );
+
+  always_comb begin
+    a_w = cfg_seed_i ^ cfg_req_data_hi_xor_i ^ 32'h1357_9BDF;
+    b_w = cfg_batch_length_i ^ cfg_req_valid_pct_i ^ 32'h2468_ACE1;
+    c_w = cfg_rsp_valid_pct_i ^ cfg_address_base_i ^ 32'h00FF_00F3;
+    d_w = cfg_address_mask_i ^ cfg_source_mask_i ^ 32'h5A5A_5A55;
+
