+            if ({addr[31:2], 2'b00} > dccm_end_addr) dccm_end_addr = {addr[31:2], 2'b00};
+        end
+    end
+end
+if (iccm_seen) begin
+    gpu_cov_store_preload_bound(32'hffff_fff0, iccm_start_addr);
+    gpu_cov_store_preload_bound(32'hffff_fff4, iccm_end_addr);
