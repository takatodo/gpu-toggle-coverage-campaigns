+    packed_outputs_w = {
+      cfg_signature_w,
+      done_w,
+      progress_count_w,
+      progress_count_w >> 1,
+      progress_count_w >> 2,
+      progress_count_w >> 3,
+      32'd0,
+      progress_count_w,
+      progress_signature_w,
+      {14'd0, seen_bits_w},
+      32'd0,
+      32'd0,
+      {31'd0, seen_bits_w[0]},
+      {31'd0, seen_bits_w[1]},
+      {31'd0, seen_bits_w[2]},
