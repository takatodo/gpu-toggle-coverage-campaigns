+  tlul_rsp_intg_gen u_target_rsp_intg (
+    .tl_i (target_rsp_pre_w),
+    .tl_o (target_rsp_w)
+  );
+
+  function automatic int unsigned clamp_pct(input int unsigned pct);
+    if (pct > 100) begin
+      return 100;
+    end
+    return pct;
+  endfunction
+
+  function automatic int unsigned prng_next(input int unsigned state);
+    return state * 32'd1664525 + 32'd1013904223;
+  endfunction
+
+  function automatic tl_a_op_e decode_req_opcode(input int unsigned rand_word);
+    rand_word = rand_word % 100;
+    if (rand_word < put_full_pct) begin
+      return PutFullData;
+    end
+    if (rand_word < (put_full_pct + put_partial_pct)) begin
+      return PutPartialData;
+    end
+    return Get;
+  endfunction
+
+  function automatic logic [TL_AW-1:0] choose_address(input int unsigned rand_word);
+    logic [TL_AW-1:0] next_address;
+    case (req_address_mode[1:0])
+      2'd1: next_address = address_base + ((host_cycles_q & 32'h0000_00ff) << 2);
+      2'd2: next_address = address_base + ((req_pending_source_q & 32'h0000_00ff) << 2);
+      default: next_address = (address_base & ~address_mask) | (rand_word & address_mask);
+    endcase
+    next_address[1:0] = 2'b00;
+    return next_address;
+  endfunction
+
+  function automatic logic [TL_DW-1:0] choose_req_data(
+      input int unsigned rand_word,
+      input logic [TL_AW-1:0] next_address
+  );
+    case (req_data_mode[1:0])
+      2'd1: return {next_address, next_address};
+      2'd2: return rand_word ^ req_data_hi_xor ^ host_cycles_q;
+      default: return rand_word ^ req_data_hi_xor;
+    endcase
+  endfunction
+
+  function automatic logic [TL_DW-1:0] choose_rsp_data(input int unsigned rand_word);
+    case (rsp_data_mode[1:0])
+      2'd1: return rand_word ^ rsp_data_hi_xor ^ device_cycles_q;
+      2'd2: return {rsp_pending_source_q, rand_word[TL_DW-TL_AIW-1:0]};
+      default: return rand_word ^ rsp_data_hi_xor;
+    endcase
+  endfunction
+
+  function automatic logic [31:0] window_count8(input logic [7:0] history_bits);
+    logic [31:0] count;
+    int unsigned idx;
+    begin
+      count = 32'd0;
+      for (idx = 0; idx < ObserverWindowLen; idx++) begin
+        if (history_bits[idx]) begin
+          count = count + 32'd1;
+        end
+      end
+      return count;
+    end
+  endfunction
+
+  function automatic bit baseline_done();
+    return bootstrapped_q && (phase_q == DonePhase);
+  endfunction
+
+  always_comb begin
+    batch_length = cfg_valid_i ? cfg_batch_length_i : 32'd256;
+    req_valid_pct = clamp_pct(cfg_valid_i ? cfg_req_valid_pct_i : 32'd65);
+    rsp_valid_pct = clamp_pct(cfg_valid_i ? cfg_rsp_valid_pct_i : 32'd70);
+    host_d_ready_pct = clamp_pct(cfg_valid_i ? cfg_host_d_ready_pct_i : 32'd75);
+    device_a_ready_pct = clamp_pct(cfg_valid_i ? cfg_device_a_ready_pct_i : 32'd80);
+    put_full_pct = clamp_pct(cfg_valid_i ? cfg_put_full_pct_i : 32'd34);
+    put_partial_pct = clamp_pct(cfg_valid_i ? cfg_put_partial_pct_i : 32'd33);
+    if ((put_full_pct + put_partial_pct) > 100) begin
+      put_partial_pct = 100 - put_full_pct;
+    end
+    req_fill_target = cfg_valid_i ? cfg_req_fill_target_i : 32'd2;
+    req_burst_len_max = cfg_valid_i ? cfg_req_burst_len_max_i : 32'd0;
+    req_family = cfg_valid_i ? cfg_req_family_i : 32'd0;
+    req_address_mode = cfg_valid_i ? cfg_req_address_mode_i : 32'd0;
+    req_data_mode = cfg_valid_i ? cfg_req_data_mode_i : 32'd0;
+    req_data_hi_xor = cfg_valid_i ? cfg_req_data_hi_xor_i : 32'd0;
+    access_ack_data_pct = clamp_pct(cfg_valid_i ? cfg_access_ack_data_pct_i : 32'd50);
+    rsp_error_pct = clamp_pct(cfg_valid_i ? cfg_rsp_error_pct_i : 32'd10);
+    rsp_fill_target = cfg_valid_i ? cfg_rsp_fill_target_i : 32'd2;
+    rsp_delay_max = cfg_valid_i ? cfg_rsp_delay_max_i : 32'd4;
+    rsp_family = cfg_valid_i ? cfg_rsp_family_i : 32'd0;
+    rsp_delay_mode = cfg_valid_i ? cfg_rsp_delay_mode_i : 32'd0;
+    rsp_data_mode = cfg_valid_i ? cfg_rsp_data_mode_i : 32'd0;
+    rsp_data_hi_xor = cfg_valid_i ? cfg_rsp_data_hi_xor_i : 32'd0;
+    reset_cycles = cfg_valid_i ? cfg_reset_cycles_i : 32'd4;
+    drain_cycles = cfg_valid_i ? cfg_drain_cycles_i : 32'd24;
+    seed = cfg_valid_i ? cfg_seed_i : 32'd1;
+    address_base = cfg_valid_i ? cfg_address_base_i : 32'd0;
+    address_mask = cfg_valid_i ? cfg_address_mask_i : 32'h0000_0ffc;
+    source_mask = cfg_valid_i ? cfg_source_mask_i : {TL_AIW{1'b1}};
+  end
+
+  assign traffic_phase_w = (phase_q == TrafficPhase);
+  assign response_phase_w = (phase_q == TrafficPhase) || (phase_q == DrainPhase);
+  assign rst_ni = bootstrapped_q && (phase_q != ResetPhase);
+  assign target_a_ready_w = device_a_ready_q && !rsp_pending_valid_q;
+  assign rsp_emit_w = rsp_pending_valid_q && (rsp_pending_delay_q == 4'd0);
+  assign drain_busy_w = req_pending_valid_q || rsp_pending_valid_q || tl_h_o.d_valid || tl_d_o.a_valid;
+  assign observer_mode_exclusive_w = rsp_family[4];
+  assign observer_windowed_w = rsp_family[5];
+
+  assign host_req_handshake_w = req_pending_valid_q && tl_h_o.a_ready;
+  assign device_req_handshake_w = tl_d_o.a_valid && target_a_ready_w;
+  assign device_rsp_handshake_w = rsp_emit_w && tl_d_o.d_ready;
+  assign host_rsp_handshake_w = tl_h_o.d_valid && host_d_ready_q;
+  assign loopback_rsp_valid_w = tl_h_o.d_valid && dut.loopback_request_q;
+  assign forward_rsp_valid_w = tl_h_o.d_valid && !dut.loopback_request_q;
+  assign loopback_observer_enable_w = !observer_mode_exclusive_w
+      || (response_mode_locked_q ? response_mode_loopback_q : loopback_rsp_valid_w);
+  assign forward_observer_enable_w = !observer_mode_exclusive_w
+      || (response_mode_locked_q ? !response_mode_loopback_q : forward_rsp_valid_w);
+  assign loopback_rsp_valid_obs_w = observer_windowed_w
+      ? window_count8(loopback_rsp_valid_hist_q) : loopback_rsp_valid_q;
+  assign loopback_rsp_ackdata_obs_w = observer_windowed_w
+      ? window_count8(loopback_rsp_ackdata_hist_q) : loopback_rsp_ackdata_q;
+  assign forward_rsp_valid_obs_w = observer_windowed_w
+      ? window_count8(forward_rsp_valid_hist_q) : forward_rsp_valid_q;
