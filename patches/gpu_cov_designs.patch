+  function automatic logic [31:0] compose_req_address(
+      input logic [31:0] rand_word,
+      input int unsigned host,
+      input logic [31:0] address_mode_cfg,
+      input logic [31:0] base_cfg,
+      input logic [31:0] mask_cfg,
+      input logic [31:0] fill_target_cfg);
+    logic [31:0] host_word;
+    logic [31:0] offset_word;
+    host_word = host;
+    case (address_mode_cfg[1:0])
+      2'd0: offset_word = rand_word;
+      2'd1: offset_word = (host_word << 6) ^ rand_word;
+      2'd2: offset_word = ((fill_target_cfg & 32'hf) << 8) | (host_word << 4) | (rand_word & 32'hf);
+      default: offset_word = ((host_word ^ (fill_target_cfg & 32'hf)) << 7) | ((rand_word >> 1) & 32'h7f);
+    endcase
+    return base_cfg | ((offset_word << 2) & mask_cfg);
+  endfunction
