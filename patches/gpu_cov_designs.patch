+  function automatic int unsigned clamp_pct(input int unsigned pct);
+    if (pct > 100) return 100;
+    return pct;
+  endfunction
+
+  function automatic logic [31:0] prng_next(input logic [31:0] state);
+    return state * 32'd1664525 + 32'd1013904223;
+  endfunction
+
+  function automatic tl_a_op_e decode_req_opcode(input logic [31:0] rand_word);
+    logic [31:0] pct_word;
+    pct_word = rand_word % 100;
+    if (pct_word < put_full_pct_cfg) return PutFullData;
+    if (pct_word < (put_full_pct_cfg + put_partial_pct_cfg)) return PutPartialData;
+    return Get;
+  endfunction
+
+  function automatic logic [top_pkg::TL_DBW-1:0] size_to_mask(
+      input logic [top_pkg::TL_SZW-1:0] size);
+    logic [top_pkg::TL_DBW-1:0] mask;
+    int unsigned byte_count;
+    mask = '0;
+    byte_count = 1 << size;
+    if (byte_count > top_pkg::TL_DBW) byte_count = top_pkg::TL_DBW;
+    for (int idx = 0; idx < top_pkg::TL_DBW; idx++) begin
+      if (idx < byte_count) mask[idx] = 1'b1;
+    end
+    return mask;
+  endfunction
