index 0000000..55276ae
--- /dev/null
+++ b/designs/XuanTie-C910/src/xuantie_c910_gpu_cov_tb.sv
@@ -0,0 +1,566 @@
+// SPDX-License-Identifier: Apache-2.0
+//
+// Coarse gpu_cov wrapper for XuanTie-C910.
+// This wrapper bypasses the stock timing-heavy tb.v and instantiates soc
+// directly so plain Verilator and sim-accel share the same clock/reset and
+// observability contract.
+
+`timescale 1ns/100ps
+
+module xuantie_c910_gpu_cov_tb (
+  input  logic        cfg_valid_i,
+  input  logic [31:0] cfg_batch_length_i,
+  input  logic [31:0] cfg_req_valid_pct_i,
+  input  logic [31:0] cfg_rsp_valid_pct_i,
+  input  logic [31:0] cfg_host_d_ready_pct_i,
+  input  logic [31:0] cfg_device_a_ready_pct_i,
+  input  logic [31:0] cfg_put_full_pct_i,
+  input  logic [31:0] cfg_put_partial_pct_i,
+  input  logic [31:0] cfg_req_fill_target_i,
+  input  logic [31:0] cfg_req_burst_len_max_i,
+  input  logic [31:0] cfg_req_family_i,
+  input  logic [31:0] cfg_req_address_mode_i,
+  input  logic [31:0] cfg_req_data_mode_i,
+  input  logic [31:0] cfg_req_data_hi_xor_i,
+  input  logic [31:0] cfg_access_ack_data_pct_i,
+  input  logic [31:0] cfg_rsp_error_pct_i,
+  input  logic [31:0] cfg_rsp_fill_target_i,
+  input  logic [31:0] cfg_rsp_delay_max_i,
+  input  logic [31:0] cfg_rsp_family_i,
+  input  logic [31:0] cfg_rsp_delay_mode_i,
+  input  logic [31:0] cfg_rsp_data_mode_i,
+  input  logic [31:0] cfg_rsp_data_hi_xor_i,
+  input  logic [31:0] cfg_reset_cycles_i,
+  input  logic [31:0] cfg_drain_cycles_i,
+  input  logic [31:0] cfg_seed_i,
+  input  logic [31:0] cfg_address_base_i,
+  input  logic [31:0] cfg_address_mask_i,
+  input  logic [31:0] cfg_source_mask_i,
+  output logic [31:0] cfg_signature_o,
+  output logic        done_o,
+  output logic [31:0] host_req_accepted_o,
+  output logic [31:0] device_req_accepted_o,
+  output logic [31:0] device_rsp_accepted_o,
+  output logic [31:0] host_rsp_accepted_o,
+  output logic [31:0] rsp_queue_overflow_o,
+  output logic [31:0] progress_cycle_count_o,
+  output logic [31:0] progress_signature_o,
+  output logic [31:0] toggle_bitmap_word0_o,
+  output logic [31:0] toggle_bitmap_word1_o,
+  output logic [31:0] toggle_bitmap_word2_o,
+  output logic [31:0] real_toggle_subset_word0_o,
+  output logic [31:0] real_toggle_subset_word1_o,
+  output logic [31:0] real_toggle_subset_word2_o,
+  output logic [31:0] real_toggle_subset_word3_o,
+  output logic [31:0] real_toggle_subset_word4_o,
+  output logic [31:0] real_toggle_subset_word5_o,
+  output logic [31:0] real_toggle_subset_word6_o,
+  output logic [31:0] real_toggle_subset_word7_o,
+  output logic [31:0] real_toggle_subset_word8_o,
+  output logic [31:0] real_toggle_subset_word9_o,
+  output logic [31:0] real_toggle_subset_word10_o,
+  output logic [31:0] real_toggle_subset_word11_o,
+  output logic [31:0] real_toggle_subset_word12_o,
+  output logic [31:0] real_toggle_subset_word13_o,
+  output logic [31:0] real_toggle_subset_word14_o,
+  output logic [31:0] real_toggle_subset_word15_o,
+  output logic [31:0] real_toggle_subset_word16_o,
+  output logic [31:0] real_toggle_subset_word17_o,
+  output logic [31:0] focused_wave_word0_o,
+  output logic [31:0] focused_wave_word1_o,
+  output logic [31:0] focused_wave_word2_o,
+  output logic [31:0] focused_wave_word3_o,
+  output logic [31:0] focused_wave_word4_o,
+  output logic [31:0] focused_wave_word5_o,
+  output logic [31:0] focused_wave_word6_o,
+  output logic [31:0] focused_wave_word7_o
+);
+
+  localparam logic [31:0] CLK_PERIOD = 32'd10;
+  localparam logic [31:0] TCLK_PERIOD = 32'd40;
+  localparam logic [31:0] LAST_CYCLE = 32'd50000;
+  localparam logic [31:0] MEM_CLEAR_COUNT = 32'h16384;
+  localparam logic [31:0] INST_COPY_COUNT = 32'h4000;
+  localparam logic [31:0] DATA_COPY_BASE = 32'h4000;
+  logic simaccel_main_clk = 1'b0;
+  logic simaccel_clk_proxy;
+  logic soc_clk_proxy;
+  logic soc_rst_b_proxy;
+  logic clk = 1'b0;
+  logic jclk = 1'b0;
+`ifdef __RTLMETER_SIM_ACCEL
+  assign clk = simaccel_main_clk;
+  assign jclk = simaccel_main_clk;
+  assign simaccel_clk_proxy = simaccel_main_clk;
+`else
+  always #(CLK_PERIOD / 2) clk = ~clk;
+  always #(TCLK_PERIOD / 2) jclk = ~jclk;
+  assign simaccel_clk_proxy = clk;
+`endif
+
+  logic rst_b;
+  logic jrst_b;
+  logic [31:0] simaccel_mem_loaded = 32'd0;
+
+  tri [7:0] b_pad_gpio_porta;
+  wire jtg_tms = 1'b1;
+  wire jtg_tdi = 1'b0;
+  wire uart0_sin = 1'b1;
+  wire jtg_tdo;
+  wire uart0_sout;
+
+  bit [31:0] mem_inst_temp [0:65535] /*verilator public_flat_rw*/;
+  bit [31:0] mem_data_temp [0:65535] /*verilator public_flat_rw*/;
+
+  logic [31:0] cycle_count_q;
+  logic [31:0] retire_inst_in_period_q;
+  logic [31:0] retire_count_q;
+  logic [31:0] write_count_q;
+  logic [31:0] uart_char_count_q;
+  logic [31:0] finish_count_q;
+  logic [31:0] cfg_signature_q;
+
+  logic [39:0] cpu_awaddr_q;
+  logic [39:0] cpu_araddr_q;
+  logic [3:0]  cpu_awlen_q;
+  logic [15:0] cpu_wstrb_q;
+  logic        cpu_wvalid_q;
+  logic [63:0] value0_q;
+  logic [63:0] value1_q;
+  logic [63:0] value2_q;
+  xuantie_axi_gpu_cov_if axi_cov();
+
+  logic cycle_seen_q;
+  logic retire_seen_q;
+  logic aw_handshake_seen_q;
+  logic w_handshake_seen_q;
+  logic b_handshake_seen_q;
+  logic ar_handshake_seen_q;
+  logic r_handshake_seen_q;
+  logic awaddr_high_seen_q;
+  logic araddr_high_seen_q;
+  logic zero_len_write_seen_q;
+  logic zero_len_read_seen_q;
+  logic uart_char_seen_q;
+  logic pass_seen_q;
+  logic fail_seen_q;
+  logic low_lane_seen_q;
+  logic upper_lane_seen_q;
+  logic value0_seen_q;
+  logic value1_seen_q;
+  logic finish_seen_q;
+  logic cfg_valid_seen_q;
+  logic cfg_signature_seen_q;
+  logic finish_pending_q;
+  logic r_response_seen_q;
+  logic b_response_seen_q;
+
+  task automatic gpu_cov_init_program_words;
+    integer iterations;
+    begin
+      iterations = 1;
+      $display("********* Init Program *********");
+      $display("********* Read program *********");
+      $readmemh("inst.pat", mem_inst_temp);
+      $readmemh("data.pat", mem_data_temp);
+      if ($value$plusargs("iterations=%d", iterations)) begin
+        $display("Iterations: %0d", iterations);
+        mem_data_temp[0] = {iterations[7:0], iterations[15:8], iterations[23:16], iterations[31:24]};
+      end
+    end
+  endtask
+
+  task automatic gpu_cov_materialize_program_words;
+    integer i;
+    integer j;
+    begin
+      $display("********* Wipe memory to 0 *********");
+      for (i = 0; i < MEM_CLEAR_COUNT; i = i + 1) begin
+        x_soc.x_axi_slave128.x_f_spsram_large.ram0.mem[i][7:0]  = 8'h00;
+        x_soc.x_axi_slave128.x_f_spsram_large.ram1.mem[i][7:0]  = 8'h00;
+        x_soc.x_axi_slave128.x_f_spsram_large.ram2.mem[i][7:0]  = 8'h00;
+        x_soc.x_axi_slave128.x_f_spsram_large.ram3.mem[i][7:0]  = 8'h00;
+        x_soc.x_axi_slave128.x_f_spsram_large.ram4.mem[i][7:0]  = 8'h00;
+        x_soc.x_axi_slave128.x_f_spsram_large.ram5.mem[i][7:0]  = 8'h00;
+        x_soc.x_axi_slave128.x_f_spsram_large.ram6.mem[i][7:0]  = 8'h00;
+        x_soc.x_axi_slave128.x_f_spsram_large.ram7.mem[i][7:0]  = 8'h00;
+        x_soc.x_axi_slave128.x_f_spsram_large.ram8.mem[i][7:0]  = 8'h00;
+        x_soc.x_axi_slave128.x_f_spsram_large.ram9.mem[i][7:0]  = 8'h00;
+        x_soc.x_axi_slave128.x_f_spsram_large.ram10.mem[i][7:0] = 8'h00;
+        x_soc.x_axi_slave128.x_f_spsram_large.ram11.mem[i][7:0] = 8'h00;
+        x_soc.x_axi_slave128.x_f_spsram_large.ram12.mem[i][7:0] = 8'h00;
+        x_soc.x_axi_slave128.x_f_spsram_large.ram13.mem[i][7:0] = 8'h00;
+        x_soc.x_axi_slave128.x_f_spsram_large.ram14.mem[i][7:0] = 8'h00;
+        x_soc.x_axi_slave128.x_f_spsram_large.ram15.mem[i][7:0] = 8'h00;
+      end
+
+      $display("********* Load program to memory *********");
+      i = 0;
+      for (j = 0; i < INST_COPY_COUNT; i = j / 4) begin
+        x_soc.x_axi_slave128.x_f_spsram_large.ram0.mem[i][7:0]  = mem_inst_temp[j][31:24]; j = j + 1;
+        x_soc.x_axi_slave128.x_f_spsram_large.ram1.mem[i][7:0]  = mem_inst_temp[j-1][23:16];
+        x_soc.x_axi_slave128.x_f_spsram_large.ram2.mem[i][7:0]  = mem_inst_temp[j-1][15:8];
