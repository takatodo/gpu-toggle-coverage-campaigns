+                    ^ cfg_rsp_valid_pct_i
+                    ^ cfg_host_d_ready_pct_i
+                    ^ cfg_device_a_ready_pct_i
+                    ^ cfg_req_family_i
+                    ^ cfg_rsp_family_i
+                    ^ cfg_seed_i
+                    ^ cfg_address_base_i
+                    ^ cfg_address_mask_i
+                    ^ cfg_source_mask_i
+                    ^ 32'hCA11_AB1E;
+
+    progress_count_w = (y_w ^ z_w ^ w_w ^ cfg_signature_w) | 32'h0000_0001;
+    progress_signature_w = progress_count_w ^ {16'h51C1, cfg_signature_w[15:0]};
