+// SPDX-License-Identifier: Apache-2.0
+//
+// Coarse gpu_cov wrapper for the Example design.
+// The design has no external request/response fabric, so the wrapper exports
+// simple progress milestones from the internal counter through the fixed output
+// contract expected by the metrics-driven gpu toggle flow.
+
+module example_gpu_cov_tb (
+  input  logic        cfg_valid_i,
+  input  logic [31:0] cfg_batch_length_i,
+  input  logic [31:0] cfg_req_valid_pct_i,
+  input  logic [31:0] cfg_rsp_valid_pct_i,
+  input  logic [31:0] cfg_host_d_ready_pct_i,
+  input  logic [31:0] cfg_device_a_ready_pct_i,
