diff --git a/designs/XiangShan/src/xiangshan_gpu_cov_tb.sv b/designs/XiangShan/src/xiangshan_gpu_cov_tb.sv
new file mode 100644
index 0000000..05894b4
--- /dev/null
+++ b/designs/XiangShan/src/xiangshan_gpu_cov_tb.sv
@@ -0,0 +1,322 @@
+// SPDX-License-Identifier: Apache-2.0
+//
+// Coarse gpu_cov wrapper for XiangShan.
+// Reuses the stock tb and exports progress/toggle proxies through the
+// fixed output contract expected by the metrics-driven gpu toggle flow.
+
+module xiangshan_gpu_cov_tb (
+  input  logic        cfg_valid_i,
+  input  logic [31:0] cfg_batch_length_i,
+  input  logic [31:0] cfg_req_valid_pct_i,
+  input  logic [31:0] cfg_rsp_valid_pct_i,
+  input  logic [31:0] cfg_host_d_ready_pct_i,
+  input  logic [31:0] cfg_device_a_ready_pct_i,
+  input  logic [31:0] cfg_put_full_pct_i,
+  input  logic [31:0] cfg_put_partial_pct_i,
+  input  logic [31:0] cfg_req_fill_target_i,
+  input  logic [31:0] cfg_req_burst_len_max_i,
+  input  logic [31:0] cfg_req_family_i,
+  input  logic [31:0] cfg_req_address_mode_i,
+  input  logic [31:0] cfg_req_data_mode_i,
+  input  logic [31:0] cfg_req_data_hi_xor_i,
+  input  logic [31:0] cfg_access_ack_data_pct_i,
+  input  logic [31:0] cfg_rsp_error_pct_i,
+  input  logic [31:0] cfg_rsp_fill_target_i,
+  input  logic [31:0] cfg_rsp_delay_max_i,
+  input  logic [31:0] cfg_rsp_family_i,
+  input  logic [31:0] cfg_rsp_delay_mode_i,
+  input  logic [31:0] cfg_rsp_data_mode_i,
+  input  logic [31:0] cfg_rsp_data_hi_xor_i,
+  input  logic [31:0] cfg_reset_cycles_i,
+  input  logic [31:0] cfg_drain_cycles_i,
+  input  logic [31:0] cfg_seed_i,
+  input  logic [31:0] cfg_address_base_i,
+  input  logic [31:0] cfg_address_mask_i,
+  input  logic [31:0] cfg_source_mask_i,
+  output logic [31:0] cfg_signature_o,
+  output logic        done_o,
+  output logic [31:0] host_req_accepted_o,
+  output logic [31:0] device_req_accepted_o,
+  output logic [31:0] device_rsp_accepted_o,
+  output logic [31:0] host_rsp_accepted_o,
+  output logic [31:0] rsp_queue_overflow_o,
+  output logic [31:0] progress_cycle_count_o,
+  output logic [31:0] progress_signature_o,
+  output logic [31:0] toggle_bitmap_word0_o,
+  output logic [31:0] toggle_bitmap_word1_o,
+  output logic [31:0] toggle_bitmap_word2_o,
+  output logic [31:0] real_toggle_subset_word0_o,
+  output logic [31:0] real_toggle_subset_word1_o,
+  output logic [31:0] real_toggle_subset_word2_o,
+  output logic [31:0] real_toggle_subset_word3_o,
+  output logic [31:0] real_toggle_subset_word4_o,
+  output logic [31:0] real_toggle_subset_word5_o,
+  output logic [31:0] real_toggle_subset_word6_o,
+  output logic [31:0] real_toggle_subset_word7_o,
+  output logic [31:0] real_toggle_subset_word8_o,
+  output logic [31:0] real_toggle_subset_word9_o,
+  output logic [31:0] real_toggle_subset_word10_o,
+  output logic [31:0] real_toggle_subset_word11_o,
+  output logic [31:0] real_toggle_subset_word12_o,
+  output logic [31:0] real_toggle_subset_word13_o,
+  output logic [31:0] real_toggle_subset_word14_o,
+  output logic [31:0] real_toggle_subset_word15_o,
+  output logic [31:0] real_toggle_subset_word16_o,
+  output logic [31:0] real_toggle_subset_word17_o,
+  output logic [31:0] focused_wave_word0_o,
+  output logic [31:0] focused_wave_word1_o,
+  output logic [31:0] focused_wave_word2_o,
+  output logic [31:0] focused_wave_word3_o,
+  output logic [31:0] focused_wave_word4_o,
+  output logic [31:0] focused_wave_word5_o,
+  output logic [31:0] focused_wave_word6_o,
+  output logic [31:0] focused_wave_word7_o
+);
+
+  localparam logic [8*13-1:0] GOOD_TRAP_ASCII = "Hit Good Trap";
+
+  tb dut();
+
+  logic mem_aw_accept_w;
+  logic mem_w_accept_w;
+  logic mem_b_accept_w;
+  logic mem_ar_accept_w;
+  logic mem_r_accept_w;
+  logic mmio_aw_accept_w;
+  logic mmio_w_accept_w;
+  logic mmio_b_accept_w;
+  logic mmio_ar_accept_w;
+  logic mmio_r_accept_w;
+  logic uart_valid_w;
+  logic uart_nonzero_w;
+  logic jtag_exit_w;
+  logic [31:0] cfg_signature_q;
+  logic        cycle_seen_q;
+  logic        uart_valid_seen_q;
+  logic        uart_nonzero_seen_q;
+  logic        mem_aw_seen_q;
+  logic        mem_w_seen_q;
+  logic        mem_b_seen_q;
+  logic        mem_ar_seen_q;
+  logic        mem_r_seen_q;
+  logic        mmio_aw_seen_q;
+  logic        mmio_w_seen_q;
+  logic        mmio_b_seen_q;
+  logic        mmio_ar_seen_q;
+  logic        mmio_r_seen_q;
+  logic        long_run_seen_q;
+  logic        cfg_valid_seen_q;
+  logic        activity_threshold_seen_q;
+  logic [17:0] seen_bits_w;
+  logic [31:0] cycle_count_q;
+  logic [31:0] mem_req_count_q;
+  logic [31:0] mem_rsp_count_q;
+  logic [31:0] mmio_req_count_q;
+  logic [31:0] mmio_rsp_count_q;
+  logic [31:0] uart_char_count_q;
+  logic [103:0] uart_shift_q;
+  logic        good_trap_seen_q;
+  logic        fail_seen_q;
+  logic [31:0] progress_signature_q;
+
+  always_comb begin
+    mem_aw_accept_w = dut.top.memory.io_axi4_0_awvalid && dut.top.memory.io_axi4_0_awready;
+    mem_w_accept_w  = dut.top.memory.io_axi4_0_wvalid && dut.top.memory.io_axi4_0_wready;
+    mem_b_accept_w  = dut.top.memory.io_axi4_0_bvalid && dut.top.memory.io_axi4_0_bready;
+    mem_ar_accept_w = dut.top.memory.io_axi4_0_arvalid && dut.top.memory.io_axi4_0_arready;
+    mem_r_accept_w  = dut.top.memory.io_axi4_0_rvalid && dut.top.memory.io_axi4_0_rready;
+    mmio_aw_accept_w = dut.top.l_simMMIO.io_axi4_0_awvalid && dut.top.l_simMMIO.io_axi4_0_awready;
+    mmio_w_accept_w  = dut.top.l_simMMIO.io_axi4_0_wvalid && dut.top.l_simMMIO.io_axi4_0_wready;
+    mmio_b_accept_w  = dut.top.l_simMMIO.io_axi4_0_bvalid && dut.top.l_simMMIO.io_axi4_0_bready;
+    mmio_ar_accept_w = dut.top.l_simMMIO.io_axi4_0_arvalid && dut.top.l_simMMIO.io_axi4_0_arready;
+    mmio_r_accept_w  = dut.top.l_simMMIO.io_axi4_0_rvalid && dut.top.l_simMMIO.io_axi4_0_rready;
+    uart_valid_w    = dut.difftest_uart_out_valid && (dut.difftest_uart_out_ch != 8'h0d);
+    uart_nonzero_w  = uart_valid_w && (dut.difftest_uart_out_ch != 8'h00);
+    jtag_exit_w     = |dut.top._SimJTAG_exit;
+    cfg_signature_q = cfg_batch_length_i
+                    ^ cfg_seed_i
+                    ^ cfg_reset_cycles_i
+                    ^ cfg_drain_cycles_i
+                    ^ cfg_req_family_i
+                    ^ cfg_rsp_family_i
+                    ^ cfg_address_base_i
+                    ^ cfg_address_mask_i
+                    ^ cfg_source_mask_i
+                    ^ {31'd0, cfg_valid_i};
+  end
+
+  always_ff @(posedge dut.clock or posedge dut.reset) begin
+    if (dut.reset) begin
+      cycle_count_q    <= '0;
+      mem_req_count_q  <= '0;
+      mem_rsp_count_q  <= '0;
+      mmio_req_count_q <= '0;
+      mmio_rsp_count_q <= '0;
+      uart_char_count_q <= '0;
+      uart_shift_q     <= '0;
+      cycle_seen_q     <= 1'b0;
+      uart_valid_seen_q <= 1'b0;
+      uart_nonzero_seen_q <= 1'b0;
+      mem_aw_seen_q    <= 1'b0;
+      mem_w_seen_q     <= 1'b0;
+      mem_b_seen_q     <= 1'b0;
+      mem_ar_seen_q    <= 1'b0;
+      mem_r_seen_q     <= 1'b0;
+      mmio_aw_seen_q   <= 1'b0;
+      mmio_w_seen_q    <= 1'b0;
+      mmio_b_seen_q    <= 1'b0;
+      mmio_ar_seen_q   <= 1'b0;
+      mmio_r_seen_q    <= 1'b0;
+      long_run_seen_q  <= 1'b0;
+      cfg_valid_seen_q <= 1'b0;
+      activity_threshold_seen_q <= 1'b0;
+      good_trap_seen_q <= 1'b0;
+      fail_seen_q      <= 1'b0;
+    end else begin
+      cycle_count_q <= cycle_count_q + 32'd1;
+      cycle_seen_q <= 1'b1;
+
+      if (uart_valid_w) begin
+        uart_char_count_q <= uart_char_count_q + 32'd1;
+        uart_shift_q <= {uart_shift_q[95:0], dut.difftest_uart_out_ch};
+        uart_valid_seen_q <= 1'b1;
+      end
+      if (uart_nonzero_w) begin
+        uart_nonzero_seen_q <= 1'b1;
+      end
+      if ({uart_shift_q[95:0], dut.difftest_uart_out_ch} == GOOD_TRAP_ASCII) begin
+        good_trap_seen_q <= 1'b1;
+      end
+
+      if (mem_aw_accept_w) begin
+        mem_req_count_q <= mem_req_count_q + 32'd1;
+        mem_aw_seen_q <= 1'b1;
+      end
+      if (mem_w_accept_w) begin
+        mem_w_seen_q <= 1'b1;
+      end
+      if (mem_b_accept_w) begin
+        mem_rsp_count_q <= mem_rsp_count_q + 32'd1;
+        mem_b_seen_q <= 1'b1;
+      end
+      if (mem_ar_accept_w) begin
+        mem_req_count_q <= mem_req_count_q + 32'd1;
+        mem_ar_seen_q <= 1'b1;
+      end
+      if (mem_r_accept_w) begin
+        mem_rsp_count_q <= mem_rsp_count_q + 32'd1;
+        mem_r_seen_q <= 1'b1;
+      end
+
+      if (mmio_aw_accept_w) begin
+        mmio_req_count_q <= mmio_req_count_q + 32'd1;
+        mmio_aw_seen_q <= 1'b1;
+      end
+      if (mmio_w_accept_w) begin
+        mmio_w_seen_q <= 1'b1;
+      end
+      if (mmio_b_accept_w) begin
+        mmio_rsp_count_q <= mmio_rsp_count_q + 32'd1;
+        mmio_b_seen_q <= 1'b1;
+      end
+      if (mmio_ar_accept_w) begin
+        mmio_req_count_q <= mmio_req_count_q + 32'd1;
+        mmio_ar_seen_q <= 1'b1;
+      end
+      if (mmio_r_accept_w) begin
+        mmio_rsp_count_q <= mmio_rsp_count_q + 32'd1;
+        mmio_r_seen_q <= 1'b1;
+      end
+
+      if (jtag_exit_w) begin
+        fail_seen_q <= 1'b1;
+      end
+      if (cycle_count_q >= 32'd1024) begin
+        long_run_seen_q <= 1'b1;
+      end
+      if (cfg_valid_i) begin
+        cfg_valid_seen_q <= 1'b1;
+      end
+      if ((mem_req_count_q + mem_rsp_count_q + mmio_req_count_q + mmio_rsp_count_q) >= 32'd16) begin
+        activity_threshold_seen_q <= 1'b1;
+      end
+    end
+  end
+
+  always_comb begin
+    seen_bits_w = {
+      activity_threshold_seen_q,
+      cfg_valid_seen_q,
+      long_run_seen_q,
+      fail_seen_q,
+      mmio_r_seen_q,
+      mmio_ar_seen_q,
+      mmio_b_seen_q,
+      mmio_w_seen_q,
+      mmio_aw_seen_q,
+      mem_r_seen_q,
+      mem_ar_seen_q,
+      mem_b_seen_q,
+      mem_w_seen_q,
+      mem_aw_seen_q,
+      good_trap_seen_q,
+      uart_nonzero_seen_q,
+      uart_valid_seen_q,
+      cycle_seen_q
+    };
+  end
+
+  always_comb begin
+    progress_signature_q = cfg_signature_q
+                         ^ cycle_count_q
+                         ^ mem_req_count_q
+                         ^ mem_rsp_count_q
+                         ^ mmio_req_count_q
+                         ^ mmio_rsp_count_q
+                         ^ uart_char_count_q
+                         ^ {14'd0, seen_bits_w};
+  end
+
+  assign cfg_signature_o        = cfg_signature_q;
+  assign done_o                 = good_trap_seen_q | fail_seen_q;
+  assign host_req_accepted_o    = mem_req_count_q;
+  assign device_req_accepted_o  = mmio_req_count_q;
+  assign device_rsp_accepted_o  = mem_rsp_count_q;
+  assign host_rsp_accepted_o    = mmio_rsp_count_q;
+  assign rsp_queue_overflow_o   = 32'd0;
+  assign progress_cycle_count_o = cycle_count_q;
+  assign progress_signature_o   = progress_signature_q;
+
+  assign toggle_bitmap_word0_o = {26'd0, seen_bits_w[5:0]};
+  assign toggle_bitmap_word1_o = {26'd0, seen_bits_w[11:6]};
+  assign toggle_bitmap_word2_o = {26'd0, seen_bits_w[17:12]};
+
+  assign real_toggle_subset_word0_o  = {31'd0, seen_bits_w[0]};
+  assign real_toggle_subset_word1_o  = {31'd0, seen_bits_w[1]};
+  assign real_toggle_subset_word2_o  = {31'd0, seen_bits_w[2]};
+  assign real_toggle_subset_word3_o  = {31'd0, seen_bits_w[3]};
+  assign real_toggle_subset_word4_o  = {31'd0, seen_bits_w[4]};
+  assign real_toggle_subset_word5_o  = {31'd0, seen_bits_w[5]};
+  assign real_toggle_subset_word6_o  = {31'd0, seen_bits_w[6]};
+  assign real_toggle_subset_word7_o  = {31'd0, seen_bits_w[7]};
+  assign real_toggle_subset_word8_o  = {31'd0, seen_bits_w[8]};
+  assign real_toggle_subset_word9_o  = {31'd0, seen_bits_w[9]};
+  assign real_toggle_subset_word10_o = {31'd0, seen_bits_w[10]};
+  assign real_toggle_subset_word11_o = {31'd0, seen_bits_w[11]};
+  assign real_toggle_subset_word12_o = {31'd0, seen_bits_w[12]};
+  assign real_toggle_subset_word13_o = {31'd0, seen_bits_w[13]};
+  assign real_toggle_subset_word14_o = {31'd0, seen_bits_w[14]};
+  assign real_toggle_subset_word15_o = {31'd0, seen_bits_w[15]};
+  assign real_toggle_subset_word16_o = {31'd0, seen_bits_w[16]};
+  assign real_toggle_subset_word17_o = {31'd0, seen_bits_w[17]};
+
+  assign focused_wave_word0_o = cycle_count_q;
+  assign focused_wave_word1_o = mem_req_count_q;
+  assign focused_wave_word2_o = mem_rsp_count_q;
+  assign focused_wave_word3_o = mmio_req_count_q;
+  assign focused_wave_word4_o = mmio_rsp_count_q;
+  assign focused_wave_word5_o = uart_char_count_q;
+  assign focused_wave_word6_o = uart_shift_q[31:0];
+  assign focused_wave_word7_o = progress_signature_q;
+
+endmodule
