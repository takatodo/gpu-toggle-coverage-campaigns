+  assign real_toggle_subset_word10_o = {31'd0, seen_bits_w[10]};
+  assign real_toggle_subset_word11_o = {31'd0, seen_bits_w[11]};
+  assign real_toggle_subset_word12_o = {31'd0, seen_bits_w[12]};
