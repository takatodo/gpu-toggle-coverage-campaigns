+      input logic [31:0] raw_value,
+      input int unsigned minimum_value,
+      input int unsigned maximum_value);
+    logic [31:0] clamped;
+    clamped = raw_value;
+    if (clamped < minimum_value) clamped = minimum_value;
+    if (clamped > maximum_value) clamped = maximum_value;
+    return clamped;
+  endfunction
+
+  function automatic logic req_family_selects_host(
+      input logic [31:0] rand_word,
+      input int unsigned host,
+      input logic [31:0] family_cfg);
+    case (family_cfg[1:0])
+      2'd0: return 1'b1;
+      2'd1: return (host == (rand_word % M));
+      2'd2: return (host[0] == rand_word[0]);
+      default: return (((rand_word >> host) & 32'h1) != 0);
+    endcase
+  endfunction
