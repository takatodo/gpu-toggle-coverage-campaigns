+if (entry_count > GPU_COV_PROGRAM_ENTRY_MAX - 1) begin
+    $display("GPU cov program entry overflow: %0d > %0d", entry_count, GPU_COV_PROGRAM_ENTRY_MAX - 1);
+    $finish;
+end
+iccm_seen = 1'b0;
+dccm_seen = 1'b0;
