+  input  logic [31:0] cfg_req_data_hi_xor_i,
+  input  logic [31:0] cfg_access_ack_data_pct_i,
+  input  logic [31:0] cfg_rsp_error_pct_i,
+  input  logic [31:0] cfg_rsp_fill_target_i,
+  input  logic [31:0] cfg_rsp_delay_max_i,
+  input  logic [31:0] cfg_rsp_family_i,
+  input  logic [31:0] cfg_rsp_delay_mode_i,
+  input  logic [31:0] cfg_rsp_data_mode_i,
+  input  logic [31:0] cfg_rsp_data_hi_xor_i,
+  input  logic [31:0] cfg_reset_cycles_i,
+  input  logic [31:0] cfg_drain_cycles_i,
+  input  logic [31:0] cfg_seed_i,
+  input  logic [31:0] cfg_address_base_i,
+  input  logic [31:0] cfg_address_mask_i,
+  input  logic [31:0] cfg_source_mask_i,
+  output logic [31:0] cfg_signature_o,
+  output logic        done_o,
+  output logic [31:0] host_req_accepted_o,
+  output logic [31:0] device_req_accepted_o,
+  output logic [31:0] device_rsp_accepted_o,
+  output logic [31:0] host_rsp_accepted_o,
+  output logic [31:0] rsp_queue_overflow_o,
+  output logic [31:0] progress_cycle_count_o,
+  output logic [31:0] progress_signature_o,
+  output logic [31:0] toggle_bitmap_word0_o,
+  output logic [31:0] toggle_bitmap_word1_o,
+  output logic [31:0] toggle_bitmap_word2_o,
+  output logic [31:0] real_toggle_subset_word0_o,
+  output logic [31:0] real_toggle_subset_word1_o,
+  output logic [31:0] real_toggle_subset_word2_o,
+  output logic [31:0] real_toggle_subset_word3_o,
+  output logic [31:0] real_toggle_subset_word4_o,
+  output logic [31:0] real_toggle_subset_word5_o,
+  output logic [31:0] real_toggle_subset_word6_o,
+  output logic [31:0] real_toggle_subset_word7_o,
+  output logic [31:0] real_toggle_subset_word8_o,
+  output logic [31:0] real_toggle_subset_word9_o,
+  output logic [31:0] real_toggle_subset_word10_o,
+  output logic [31:0] real_toggle_subset_word11_o,
+  output logic [31:0] real_toggle_subset_word12_o,
+  output logic [31:0] real_toggle_subset_word13_o,
+  output logic [31:0] real_toggle_subset_word14_o,
+  output logic [31:0] real_toggle_subset_word15_o,
+  output logic [31:0] real_toggle_subset_word16_o,
+  output logic [31:0] real_toggle_subset_word17_o,
+  output logic [31:0] focused_wave_word0_o,
+  output logic [31:0] focused_wave_word1_o,
+  output logic [31:0] focused_wave_word2_o,
+  output logic [31:0] focused_wave_word3_o,
+  output logic [31:0] focused_wave_word4_o,
+  output logic [31:0] focused_wave_word5_o,
+  output logic [31:0] focused_wave_word6_o,
+  output logic [31:0] focused_wave_word7_o
+);
+
+  logic simaccel_main_clk = 1'b0;
+`ifdef __RTLMETER_SIM_ACCEL
+  top dut(.simaccel_clk_i(simaccel_main_clk));
+`else
+  top dut();
+`endif
+
+  logic [17:0] seen_bits_w;
+  logic [31:0] progress_count_w;
+  logic [31:0] cfg_signature_w;
+  logic [31:0] progress_signature_w;
+  logic done_w;
+
+  always_comb begin
+    cfg_signature_w = cfg_batch_length_i
+                    ^ cfg_req_valid_pct_i
+                    ^ cfg_rsp_valid_pct_i
+                    ^ cfg_req_family_i
+                    ^ cfg_rsp_family_i
+                    ^ cfg_reset_cycles_i
+                    ^ cfg_drain_cycles_i
+                    ^ cfg_seed_i
+                    ^ cfg_address_base_i
+                    ^ cfg_address_mask_i
+                    ^ cfg_source_mask_i
+                    ^ {31'd0, cfg_valid_i};
+
+`ifdef __RTLMETER_SIM_ACCEL
+    progress_count_w = progress_cycle_count_o + 32'd1;
+`else
+    progress_count_w = dut.cnt[31:0];
+`endif
+    done_w = (progress_count_w >= 32'd256);
+
+    seen_bits_w[0]  = (progress_count_w >= 32'd1);
+    seen_bits_w[1]  = (progress_count_w >= 32'd2);
+    seen_bits_w[2]  = (progress_count_w >= 32'd3);
+    seen_bits_w[3]  = (progress_count_w >= 32'd4);
+    seen_bits_w[4]  = (progress_count_w >= 32'd5);
+    seen_bits_w[5]  = (progress_count_w >= 32'd6);
+    seen_bits_w[6]  = (progress_count_w >= 32'd8);
+    seen_bits_w[7]  = (progress_count_w >= 32'd10);
+    seen_bits_w[8]  = (progress_count_w >= 32'd12);
+    seen_bits_w[9]  = (progress_count_w >= 32'd16);
+    seen_bits_w[10] = (progress_count_w >= 32'd24);
+    seen_bits_w[11] = (progress_count_w >= 32'd32);
+    seen_bits_w[12] = (progress_count_w >= 32'd48);
+    seen_bits_w[13] = (progress_count_w >= 32'd64);
+    seen_bits_w[14] = (progress_count_w >= 32'd96);
+    seen_bits_w[15] = (progress_count_w >= 32'd128);
+    seen_bits_w[16] = (progress_count_w >= 32'd192);
+    seen_bits_w[17] = done_w;
+
+`ifdef __RTLMETER_SIM_ACCEL
+    progress_signature_w = cfg_signature_w ^ progress_count_w;
+`else
+    progress_signature_w = cfg_signature_w ^ progress_count_w ^ {31'd0, dut.clk};
+`endif
+  end
+
+`ifdef __RTLMETER_SIM_ACCEL
+  always_ff @(posedge simaccel_main_clk) begin
+    cfg_signature_o <= cfg_signature_w;
+    done_o <= done_w;
+    host_req_accepted_o <= progress_count_w;
+    device_req_accepted_o <= progress_count_w >> 1;
+    device_rsp_accepted_o <= progress_count_w >> 2;
+    host_rsp_accepted_o <= progress_count_w >> 3;
+    rsp_queue_overflow_o  <= 32'd0;
+
+    progress_cycle_count_o <= progress_count_w;
+    progress_signature_o <= progress_signature_w;
+
+    toggle_bitmap_word0_o <= toggle_bitmap_word0_o | {14'd0, seen_bits_w};
+    toggle_bitmap_word1_o <= 32'd0;
+    toggle_bitmap_word2_o <= 32'd0;
+
+    if (seen_bits_w[0])  real_toggle_subset_word0_o  <= 32'd1;
+    if (seen_bits_w[1])  real_toggle_subset_word1_o  <= 32'd1;
+    if (seen_bits_w[2])  real_toggle_subset_word2_o  <= 32'd1;
+    if (seen_bits_w[3])  real_toggle_subset_word3_o  <= 32'd1;
+    if (seen_bits_w[4])  real_toggle_subset_word4_o  <= 32'd1;
+    if (seen_bits_w[5])  real_toggle_subset_word5_o  <= 32'd1;
+    if (seen_bits_w[6])  real_toggle_subset_word6_o  <= 32'd1;
+    if (seen_bits_w[7])  real_toggle_subset_word7_o  <= 32'd1;
+    if (seen_bits_w[8])  real_toggle_subset_word8_o  <= 32'd1;
+    if (seen_bits_w[9])  real_toggle_subset_word9_o  <= 32'd1;
+    if (seen_bits_w[10]) real_toggle_subset_word10_o <= 32'd1;
+    if (seen_bits_w[11]) real_toggle_subset_word11_o <= 32'd1;
+    if (seen_bits_w[12]) real_toggle_subset_word12_o <= 32'd1;
+    if (seen_bits_w[13]) real_toggle_subset_word13_o <= 32'd1;
+    if (seen_bits_w[14]) real_toggle_subset_word14_o <= 32'd1;
+    if (seen_bits_w[15]) real_toggle_subset_word15_o <= 32'd1;
+    if (seen_bits_w[16]) real_toggle_subset_word16_o <= 32'd1;
+    if (seen_bits_w[17]) real_toggle_subset_word17_o <= 32'd1;
+
+    focused_wave_word0_o <= progress_count_w;
+    focused_wave_word1_o <= cfg_signature_w;
+    focused_wave_word2_o <= {31'd0, simaccel_main_clk};
+    focused_wave_word3_o <= {31'd0, done_w};
+    if (seen_bits_w[13]) focused_wave_word4_o <= 32'd1;
+    if (seen_bits_w[15]) focused_wave_word5_o <= 32'd1;
+    if (seen_bits_w[16]) focused_wave_word6_o <= 32'd1;
+    focused_wave_word7_o <= {31'd0, cfg_valid_i};
+  end
+`else
+  always_comb begin
+    cfg_signature_o = cfg_signature_w;
+    done_o = done_w;
+    host_req_accepted_o   = progress_count_w;
+    device_req_accepted_o = progress_count_w >> 1;
+    device_rsp_accepted_o = progress_count_w >> 2;
+    host_rsp_accepted_o   = progress_count_w >> 3;
+    rsp_queue_overflow_o  = 32'd0;
+
+    progress_cycle_count_o = progress_count_w;
+    progress_signature_o = progress_signature_w;
+
+    toggle_bitmap_word0_o = {14'd0, seen_bits_w};
+    toggle_bitmap_word1_o = 32'd0;
+    toggle_bitmap_word2_o = 32'd0;
+
+    real_toggle_subset_word0_o  = {31'd0, seen_bits_w[0]};
+    real_toggle_subset_word1_o  = {31'd0, seen_bits_w[1]};
+    real_toggle_subset_word2_o  = {31'd0, seen_bits_w[2]};
+    real_toggle_subset_word3_o  = {31'd0, seen_bits_w[3]};
+    real_toggle_subset_word4_o  = {31'd0, seen_bits_w[4]};
+    real_toggle_subset_word5_o  = {31'd0, seen_bits_w[5]};
+    real_toggle_subset_word6_o  = {31'd0, seen_bits_w[6]};
+    real_toggle_subset_word7_o  = {31'd0, seen_bits_w[7]};
+    real_toggle_subset_word8_o  = {31'd0, seen_bits_w[8]};
+    real_toggle_subset_word9_o  = {31'd0, seen_bits_w[9]};
+    real_toggle_subset_word10_o = {31'd0, seen_bits_w[10]};
+    real_toggle_subset_word11_o = {31'd0, seen_bits_w[11]};
+    real_toggle_subset_word12_o = {31'd0, seen_bits_w[12]};
+    real_toggle_subset_word13_o = {31'd0, seen_bits_w[13]};
+    real_toggle_subset_word14_o = {31'd0, seen_bits_w[14]};
+    real_toggle_subset_word15_o = {31'd0, seen_bits_w[15]};
+    real_toggle_subset_word16_o = {31'd0, seen_bits_w[16]};
+    real_toggle_subset_word17_o = {31'd0, seen_bits_w[17]};
+
+    focused_wave_word0_o = progress_count_w;
+    focused_wave_word1_o = cfg_signature_w;
+    focused_wave_word2_o = {31'd0, dut.clk};
+    focused_wave_word3_o = {31'd0, done_w};
+    focused_wave_word4_o = {31'd0, seen_bits_w[13]};
+    focused_wave_word5_o = {31'd0, seen_bits_w[15]};
+    focused_wave_word6_o = {31'd0, seen_bits_w[16]};
+    focused_wave_word7_o = {31'd0, cfg_valid_i};
+  end
+`endif
+
+endmodule
diff --git a/designs/OpenPiton/src/common/openpiton_gpu_cov_tb.sv b/designs/OpenPiton/src/common/openpiton_gpu_cov_tb.sv
new file mode 100644
index 0000000..4dd13cc
--- /dev/null
+++ b/designs/OpenPiton/src/common/openpiton_gpu_cov_tb.sv
@@ -0,0 +1,214 @@
+// SPDX-License-Identifier: Apache-2.0
+//
+// Coarse gpu_cov wrapper for OpenPiton.
+// Reuses the stock cmp_top testbench and exports shallow progress, finish, and
+// fake-memory-controller activity through the fixed gpu toggle output contract.
+
+module openpiton_gpu_cov_tb (
+  input  logic        cfg_valid_i,
+  input  logic [31:0] cfg_batch_length_i,
+  input  logic [31:0] cfg_req_valid_pct_i,
+  input  logic [31:0] cfg_rsp_valid_pct_i,
+  input  logic [31:0] cfg_host_d_ready_pct_i,
+  input  logic [31:0] cfg_device_a_ready_pct_i,
+  input  logic [31:0] cfg_put_full_pct_i,
+  input  logic [31:0] cfg_put_partial_pct_i,
+  input  logic [31:0] cfg_req_fill_target_i,
+  input  logic [31:0] cfg_req_burst_len_max_i,
+  input  logic [31:0] cfg_req_family_i,
+  input  logic [31:0] cfg_req_address_mode_i,
+  input  logic [31:0] cfg_req_data_mode_i,
+  input  logic [31:0] cfg_req_data_hi_xor_i,
+  input  logic [31:0] cfg_access_ack_data_pct_i,
+  input  logic [31:0] cfg_rsp_error_pct_i,
+  input  logic [31:0] cfg_rsp_fill_target_i,
+  input  logic [31:0] cfg_rsp_delay_max_i,
+  input  logic [31:0] cfg_rsp_family_i,
+  input  logic [31:0] cfg_rsp_delay_mode_i,
+  input  logic [31:0] cfg_rsp_data_mode_i,
+  input  logic [31:0] cfg_rsp_data_hi_xor_i,
+  input  logic [31:0] cfg_reset_cycles_i,
+  input  logic [31:0] cfg_drain_cycles_i,
+  input  logic [31:0] cfg_seed_i,
+  input  logic [31:0] cfg_address_base_i,
+  input  logic [31:0] cfg_address_mask_i,
+  input  logic [31:0] cfg_source_mask_i,
+  output logic [31:0] cfg_signature_o,
+  output logic        done_o,
+  output logic [31:0] host_req_accepted_o,
+  output logic [31:0] device_req_accepted_o,
+  output logic [31:0] device_rsp_accepted_o,
+  output logic [31:0] host_rsp_accepted_o,
+  output logic [31:0] rsp_queue_overflow_o,
+  output logic [31:0] progress_cycle_count_o,
+  output logic [31:0] progress_signature_o,
+  output logic [31:0] toggle_bitmap_word0_o,
+  output logic [31:0] toggle_bitmap_word1_o,
+  output logic [31:0] toggle_bitmap_word2_o,
+  output logic [31:0] real_toggle_subset_word0_o,
+  output logic [31:0] real_toggle_subset_word1_o,
+  output logic [31:0] real_toggle_subset_word2_o,
+  output logic [31:0] real_toggle_subset_word3_o,
+  output logic [31:0] real_toggle_subset_word4_o,
+  output logic [31:0] real_toggle_subset_word5_o,
+  output logic [31:0] real_toggle_subset_word6_o,
+  output logic [31:0] real_toggle_subset_word7_o,
+  output logic [31:0] real_toggle_subset_word8_o,
+  output logic [31:0] real_toggle_subset_word9_o,
+  output logic [31:0] real_toggle_subset_word10_o,
+  output logic [31:0] real_toggle_subset_word11_o,
+  output logic [31:0] real_toggle_subset_word12_o,
+  output logic [31:0] real_toggle_subset_word13_o,
+  output logic [31:0] real_toggle_subset_word14_o,
+  output logic [31:0] real_toggle_subset_word15_o,
+  output logic [31:0] real_toggle_subset_word16_o,
+  output logic [31:0] real_toggle_subset_word17_o,
+  output logic [31:0] focused_wave_word0_o,
+  output logic [31:0] focused_wave_word1_o,
+  output logic [31:0] focused_wave_word2_o,
+  output logic [31:0] focused_wave_word3_o,
+  output logic [31:0] focused_wave_word4_o,
+  output logic [31:0] focused_wave_word5_o,
+  output logic [31:0] focused_wave_word6_o,
+  output logic [31:0] focused_wave_word7_o
+);
+
+  localparam logic [63:0] GOOD_TRAP_PC = 64'h0000_0000_8000_0220;
+  localparam logic [63:0] BAD_TRAP_PC  = 64'h0000_0000_8000_0200;
+
+  cmp_top dut();
+
+  logic [31:0] cfg_signature_q;
+  logic [31:0] progress_cycle_proxy_q;
+  logic [31:0] progress_signature_q;
+  logic [31:0] mem_req_count_q;
+  logic [31:0] mem_rsp_count_q;
+  logic [31:0] dram_accept_count_q;
+  logic [31:0] uart_req_count_q;
+  logic [31:0] uart_rsp_count_q;
+  logic [31:0] uart_accept_count_q;
+
+  logic ok_iob_w;
+  logic pc_valid_w;
+  logic [63:0] pc_w;
+  logic good_hit_w;
+  logic bad_hit_w;
+  logic done_w;
+  logic local_diag_done_w;
+  logic good_trap_exists_w;
+  logic bad_trap_exists_w;
+  logic control_progress_w;
+  logic mem_req_valid_w;
+  logic mem_rsp_valid_w;
+  logic mem_req_accept_w;
+  logic mem_rsp_accept_w;
+  logic dram_req_w;
+  logic dram_accept_w;
+  logic memory_threshold_w;
+  logic host_output_w;
+  logic uart_req_w;
+  logic uart_rsp_w;
+  logic cfg_valid_seen_w;
+  logic [2:0] noc2_uart_count_w;
+  logic [2:0] noc3_uart_count_w;
+  logic [7:0] msg_send_type_w;
+  logic [7:0] msg_send_length_w;
+
+  always_comb begin
+    ok_iob_w           = dut.system.chipset.chipset_impl.ciop_fake_iob.ok_iob;
+    pc_valid_w         = dut.monitor.pc_cmp.spc0_inst_done;
+    pc_w               = dut.monitor.pc_cmp.spc0_phy_pc_w;
+    local_diag_done_w  = dut.monitor.pc_cmp.local_diag_done;
+    good_trap_exists_w = dut.monitor.pc_cmp.good_trap_exists[0];
+    bad_trap_exists_w  = dut.monitor.pc_cmp.bad_trap_exists[0];
+    noc2_uart_count_w  = dut.system.chipset.chipset_impl.noc2_uart_to_xbar.count_f;
+    noc3_uart_count_w  = dut.system.chipset.chipset_impl.noc3_uart_to_xbar.count_f;
+    msg_send_type_w    = dut.system.chipset.chipset_impl.fake_mem_ctrl.msg_send_type;
+    msg_send_length_w  = dut.system.chipset.chipset_impl.fake_mem_ctrl.msg_send_length;
+    good_hit_w         = dut.monitor.pc_cmp.good[0]
+                      || local_diag_done_w
+                      || (pc_valid_w && (pc_w == GOOD_TRAP_PC));
+    bad_hit_w          = dut.monitor.pc_cmp.hit_bad
+                      && !dut.monitor.pc_cmp.good[0]
+                      && !local_diag_done_w
+                      && (pc_valid_w && (pc_w == BAD_TRAP_PC));
+    done_w             = good_hit_w || bad_hit_w;
+    control_progress_w = ok_iob_w || local_diag_done_w || good_trap_exists_w || bad_trap_exists_w;
+    mem_req_valid_w    = (msg_send_length_w != 8'd0);
+    mem_rsp_valid_w    = (msg_send_type_w != 8'd0);
+    mem_req_accept_w   = mem_req_valid_w;
+    mem_rsp_accept_w   = mem_rsp_valid_w;
+    dram_req_w         = (msg_send_length_w >= 8'd1);
+    dram_accept_w      = (msg_send_type_w != 8'd0);
+    memory_threshold_w = (msg_send_length_w >= 8'd4);
+    uart_req_w         = (noc2_uart_count_w != 3'd0);
+    uart_rsp_w         = (noc3_uart_count_w != 3'd0);
+    host_output_w      = uart_req_w || uart_rsp_w;
+    cfg_signature_q    = cfg_batch_length_i
+                      ^ cfg_seed_i
+                      ^ cfg_reset_cycles_i
+                      ^ cfg_drain_cycles_i
+                      ^ cfg_req_family_i
+                      ^ cfg_rsp_family_i
+                      ^ cfg_address_base_i
+                      ^ cfg_address_mask_i
+                      ^ cfg_source_mask_i
+                      ^ {31'd0, cfg_valid_i};
+    cfg_valid_seen_w   = cfg_valid_i || (cfg_signature_q != 32'd0);
+    mem_req_count_q    = {24'd0, msg_send_length_w};
+    mem_rsp_count_q    = {24'd0, msg_send_type_w};
+    dram_accept_count_q = {24'd0, msg_send_length_w};
+    uart_req_count_q   = {29'd0, noc2_uart_count_w};
+    uart_rsp_count_q   = {29'd0, noc3_uart_count_w};
+    uart_accept_count_q = uart_req_count_q + uart_rsp_count_q;
+    progress_cycle_proxy_q = {16'd0, msg_send_length_w, 1'b0, noc2_uart_count_w, 1'b0, noc3_uart_count_w};
+    progress_signature_q = cfg_signature_q
+                        ^ progress_cycle_proxy_q
+                        ^ {24'd0, msg_send_type_w}
+                        ^ {31'd0, local_diag_done_w}
+                        ^ {31'd0, ok_iob_w};
+  end
+
+  assign cfg_signature_o = cfg_signature_q;
+  assign done_o = done_w;
+  assign host_req_accepted_o = mem_req_count_q;
+  assign device_req_accepted_o = dram_accept_count_q;
+  assign device_rsp_accepted_o = mem_rsp_count_q;
+  assign host_rsp_accepted_o = uart_accept_count_q;
+  assign rsp_queue_overflow_o = 32'd0;
+  assign progress_cycle_count_o = progress_cycle_proxy_q;
+  assign progress_signature_o = progress_signature_q;
+
+  assign toggle_bitmap_word0_o = {16'd0, msg_send_length_w, msg_send_type_w};
+  assign toggle_bitmap_word1_o = {13'd0, noc2_uart_count_w, 13'd0, noc3_uart_count_w};
+  assign toggle_bitmap_word2_o = progress_signature_q;
+
+  assign real_toggle_subset_word0_o  = {31'd0, control_progress_w};
+  assign real_toggle_subset_word1_o  = {31'd0, good_trap_exists_w || bad_trap_exists_w};
+  assign real_toggle_subset_word2_o  = {31'd0, ok_iob_w};
+  assign real_toggle_subset_word3_o  = {31'd0, good_hit_w};
+  assign real_toggle_subset_word4_o  = {31'd0, mem_req_valid_w};
+  assign real_toggle_subset_word5_o  = {31'd0, mem_rsp_valid_w};
+  assign real_toggle_subset_word6_o  = {31'd0, mem_req_accept_w};
+  assign real_toggle_subset_word7_o  = {31'd0, mem_rsp_accept_w};
+  assign real_toggle_subset_word8_o  = {31'd0, dram_req_w};
+  assign real_toggle_subset_word9_o  = {31'd0, dram_accept_w};
+  assign real_toggle_subset_word10_o = {31'd0, memory_threshold_w};
+  assign real_toggle_subset_word11_o = {31'd0, host_output_w};
+  assign real_toggle_subset_word12_o = {31'd0, uart_req_w};
+  assign real_toggle_subset_word13_o = {31'd0, uart_rsp_w};
+  assign real_toggle_subset_word14_o = {31'd0, bad_hit_w};
+  assign real_toggle_subset_word15_o = {31'd0, local_diag_done_w || good_hit_w};
+  assign real_toggle_subset_word16_o = {31'd0, memory_threshold_w || host_output_w};
+  assign real_toggle_subset_word17_o = {31'd0, cfg_valid_seen_w};
+
+  assign focused_wave_word0_o = pc_w[31:0];
+  assign focused_wave_word1_o = pc_w[63:32];
+  assign focused_wave_word2_o = progress_cycle_proxy_q;
+  assign focused_wave_word3_o = {24'd0, msg_send_type_w};
+  assign focused_wave_word4_o = {24'd0, msg_send_length_w};
+  assign focused_wave_word5_o = {13'd0, noc2_uart_count_w, 13'd0, noc3_uart_count_w};
+  assign focused_wave_word6_o = {31'd0, local_diag_done_w};
+  assign focused_wave_word7_o = progress_signature_q;
+
+endmodule
