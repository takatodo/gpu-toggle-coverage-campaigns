+  task automatic load_trace_replay_file;
+    int replay_fd;
+    int replay_rc;
+    int unsigned replay_idx;
+    int unsigned req_opcode;
+    int unsigned req_param;
+    int unsigned req_size;
+    int unsigned req_address;
+    int unsigned req_mask;
+    int unsigned req_data;
+    int unsigned req_source;
+    int unsigned req_spare;
+    int unsigned host_ready_mode;
+    int unsigned device_ready_mode;
+    int unsigned rsp_valid;
+    int unsigned rsp_opcode;
+    int unsigned rsp_size;
+    int unsigned rsp_source;
+    int unsigned rsp_has_data;
+    int unsigned rsp_data;
+    int unsigned rsp_delay;
+    int unsigned rsp_error;
+    int unsigned req_valid_mode;
+    int unsigned req_burst_len;
+
+    if ((trace_replay_enable == 0) || (trace_replay_init_file.len() == 0)) begin
+      return;
+    end
+    replay_fd = $fopen(trace_replay_init_file, "r");
+    if (replay_fd == 0) begin
+      $fatal(1, "Failed to open trace replay init file '%0s'", trace_replay_init_file);
+    end
+    replay_rc = $fscanf(replay_fd, "%d\n", trace_replay_cycles);
+    if (replay_rc != 1) begin
+      $fatal(1, "Failed to read trace replay cycle count from '%0s'", trace_replay_init_file);
+    end
+    if (trace_replay_cycles > TraceDepth) begin
+      $fatal(1, "trace replay cycles %0d exceed TraceDepth=%0d", trace_replay_cycles, TraceDepth);
+    end
+    dut.trace_step_count_q = trace_replay_cycles;
+    dut.trace_step_q = 32'd0;
+    dut.direct_trace_step_q = 32'd0;
+    for (replay_idx = 0; replay_idx < trace_replay_cycles; replay_idx++) begin
+      replay_rc = $fscanf(
+          replay_fd,
+          "%h %h %h %h %h %h %h %h %d %h %h %h %d %h %d %h %d %d %d %d\n",
+          req_opcode,
+          req_param,
+          req_size,
+          req_address,
+          req_mask,
+          req_data,
+          req_source,
+          req_spare,
+          rsp_valid,
+          rsp_opcode,
+          rsp_size,
+          rsp_source,
+          rsp_has_data,
+          rsp_data,
+          rsp_delay,
+          rsp_error,
+          host_ready_mode,
+          device_ready_mode,
+          req_valid_mode,
+          req_burst_len
+      );
+      if (replay_rc != 20) begin
+        $fatal(1, "Malformed trace replay entry %0d in '%0s'", replay_idx, trace_replay_init_file);
+      end
+      dut.trace_req_opcode_q[replay_idx] = req_opcode[1:0];
+      dut.trace_req_param_q[replay_idx] = req_param[2:0];
+      dut.trace_req_size_q[replay_idx] = req_size[top_pkg::TL_SZW-1:0];
+      dut.trace_req_address_q[replay_idx] = req_address[top_pkg::TL_AW-1:0];
+      dut.trace_req_mask_q[replay_idx] = req_mask[top_pkg::TL_DBW-1:0];
+      dut.trace_req_data_q[replay_idx] = req_data[top_pkg::TL_DW-1:0];
+      dut.trace_req_source_q[replay_idx] = req_source[top_pkg::TL_AIW-1:0];
+      dut.trace_req_burst_len_q[replay_idx] = req_burst_len;
+      dut.trace_req_spare_q[replay_idx] = req_spare[0];
+      dut.trace_rsp_valid_q[replay_idx] = rsp_valid[0];
+      dut.trace_rsp_opcode_q[replay_idx] = rsp_opcode[2:0];
+      dut.trace_rsp_size_q[replay_idx] = rsp_size[top_pkg::TL_SZW-1:0];
+      dut.trace_rsp_source_q[replay_idx] = rsp_source[top_pkg::TL_AIW-1:0];
+      dut.trace_rsp_has_data_q[replay_idx] = rsp_has_data[0];
+      dut.trace_rsp_data_q[replay_idx] = rsp_data[top_pkg::TL_DW-1:0];
+      dut.trace_rsp_delay_q[replay_idx] = rsp_delay;
+      dut.trace_rsp_error_q[replay_idx] = rsp_error[0];
+      dut.trace_host_ready_mode_q[replay_idx] = host_ready_mode[1:0];
+      dut.trace_device_ready_mode_q[replay_idx] = device_ready_mode[1:0];
+      dut.trace_req_valid_mode_q[replay_idx] = req_valid_mode[1:0];
+    end
+    $fclose(replay_fd);
+  endtask
+
+  task automatic print_summary;
+    $display("summary_cfg_signature=0x%08x", cfg_signature);
+    $display("summary_done=%0d", done);
+    $display("summary_host_req_accepted=%0d", host_req_accepted);
+    $display("summary_device_req_accepted=%0d", device_req_accepted);
+    $display("summary_device_rsp_accepted=%0d", device_rsp_accepted);
+    $display("summary_host_rsp_accepted=%0d", host_rsp_accepted);
+    $display("summary_rsp_queue_overflow=%0d", rsp_queue_overflow);
+    $display("summary_progress_cycle_count=%0d", progress_cycle_count);
+    $display("summary_progress_signature=0x%08x", progress_signature);
+    $display("summary_trace_step=%0d", trace_metric_trace_step);
+    $display("summary_trace_step_count=%0d", trace_metric_trace_step_count);
+    $display("summary_req_handshake_seen=%0d", trace_metric_req_handshake_seen);
+    $display("summary_rsp_handshake_seen=%0d", trace_metric_rsp_handshake_seen);
+    $display("summary_host_rsp_handshake_seen=%0d", trace_metric_host_rsp_handshake_seen);
+    $display("summary_host_rsp_ackdata_seen=%0d", trace_metric_host_rsp_ackdata_seen);
+    $display("summary_host_rsp_payload_upper_seen=%0d", trace_metric_host_rsp_payload_upper_seen);
+    $display("summary_host_raw_rsp_ackdata_seen=%0d", trace_metric_host_raw_rsp_ackdata_seen);
+    $display("summary_host_raw_rsp_payload_upper_seen=%0d", trace_metric_host_raw_rsp_payload_upper_seen);
+    $display("summary_device_rsp_ackdata_seen=%0d", trace_metric_device_rsp_ackdata_seen);
+    $display("summary_device_rsp_payload_upper_seen=%0d", trace_metric_device_rsp_payload_upper_seen);
+    $display("summary_host_rsp_opcode_or=0x%08x", trace_metric_host_rsp_opcode_or);
+    $display("summary_host_raw_rsp_opcode_or=0x%08x", trace_metric_host_raw_rsp_opcode_or);
+    $display("summary_device_rsp_opcode_or=0x%08x", trace_metric_device_rsp_opcode_or);
+    $display("summary_max_reqfifo_depth=%0d", trace_metric_max_reqfifo_depth);
+    $display("summary_max_rspfifo_depth=%0d", trace_metric_max_rspfifo_depth);
+    $display("summary_first_device_rsp_pack=0x%08x", trace_metric_first_device_rsp_pack);
+    $display("summary_first_host_rsp_pack=0x%08x", trace_metric_first_host_rsp_pack);
+    $display("summary_a_data_upper_or=0x%08x", trace_metric_a_data_upper_or);
+    $display("summary_device_d_data_upper_or=0x%08x", trace_metric_device_d_data_upper_or);
+    $display("summary_host_d_data_upper_or=0x%08x", trace_metric_d_data_upper_or);
+  endtask
+
+  initial begin
+    cfg_valid = 1'b1;
+    cfg_batch_length = 32'd256;
+    cfg_req_valid_pct = 32'd65;
+    cfg_rsp_valid_pct = 32'd70;
+    cfg_host_d_ready_pct = 32'd75;
+    cfg_device_a_ready_pct = 32'd80;
+    cfg_put_full_pct = 32'd34;
+    cfg_put_partial_pct = 32'd33;
+    cfg_req_fill_target = 32'd2;
+    cfg_req_burst_len_max = 32'd0;
+    cfg_req_family = 32'd0;
+    cfg_req_address_mode = 32'd0;
+    cfg_req_data_mode = 32'd0;
+    cfg_req_data_hi_xor = 32'd0;
+    cfg_access_ack_data_pct = 32'd50;
+    cfg_rsp_error_pct = 32'd10;
+    cfg_rsp_fill_target = 32'd2;
+    cfg_rsp_delay_max = 32'd4;
+    cfg_rsp_family = 32'd0;
+    cfg_rsp_delay_mode = 32'd0;
+    cfg_rsp_data_mode = 32'd0;
+    cfg_rsp_data_hi_xor = 32'd0;
+    cfg_reset_cycles = 32'd4;
+    cfg_drain_cycles = 32'd16;
+    cfg_seed = 32'd1;
+    cfg_address_base = 32'd0;
+    cfg_address_mask = 32'h0000_0ffc;
+    cfg_source_mask = 32'h0000_00ff;
+    trace_replay_enable = 0;
+    trace_replay_cycles = 0;
+    trace_replay_init_file = "";
+    trace_vcd_file = "";
+    max_cycles = 32'd4096;
+
+    void'($value$plusargs("batch_length=%d", cfg_batch_length));
+    void'($value$plusargs("req_valid_pct=%d", cfg_req_valid_pct));
+    void'($value$plusargs("rsp_valid_pct=%d", cfg_rsp_valid_pct));
+    void'($value$plusargs("host_d_ready_pct=%d", cfg_host_d_ready_pct));
+    void'($value$plusargs("device_a_ready_pct=%d", cfg_device_a_ready_pct));
+    void'($value$plusargs("put_full_pct=%d", cfg_put_full_pct));
+    void'($value$plusargs("put_partial_pct=%d", cfg_put_partial_pct));
+    void'($value$plusargs("req_fill_target=%d", cfg_req_fill_target));
+    void'($value$plusargs("req_burst_len_max=%d", cfg_req_burst_len_max));
+    void'($value$plusargs("req_family=%d", cfg_req_family));
+    void'($value$plusargs("req_address_mode=%d", cfg_req_address_mode));
+    void'($value$plusargs("req_data_mode=%d", cfg_req_data_mode));
+    void'($value$plusargs("req_data_hi_xor=%d", cfg_req_data_hi_xor));
+    void'($value$plusargs("access_ack_data_pct=%d", cfg_access_ack_data_pct));
+    void'($value$plusargs("rsp_error_pct=%d", cfg_rsp_error_pct));
+    void'($value$plusargs("rsp_fill_target=%d", cfg_rsp_fill_target));
+    void'($value$plusargs("rsp_delay_max=%d", cfg_rsp_delay_max));
+    void'($value$plusargs("rsp_family=%d", cfg_rsp_family));
+    void'($value$plusargs("rsp_delay_mode=%d", cfg_rsp_delay_mode));
+    void'($value$plusargs("rsp_data_mode=%d", cfg_rsp_data_mode));
+    void'($value$plusargs("rsp_data_hi_xor=%d", cfg_rsp_data_hi_xor));
+    void'($value$plusargs("reset_cycles=%d", cfg_reset_cycles));
+    void'($value$plusargs("drain_cycles=%d", cfg_drain_cycles));
+    void'($value$plusargs("seed=%d", cfg_seed));
+    void'($value$plusargs("address_base=%d", cfg_address_base));
+    void'($value$plusargs("address_mask=%d", cfg_address_mask));
+    void'($value$plusargs("source_mask=%d", cfg_source_mask));
+    void'($value$plusargs("trace_replay_enable=%d", trace_replay_enable));
+    void'($value$plusargs("trace_replay_cycles=%d", trace_replay_cycles));
+    void'($value$plusargs("trace_replay_init_file=%s", trace_replay_init_file));
+    void'($value$plusargs("trace_vcd=%s", trace_vcd_file));
+    void'($value$plusargs("max_cycles=%d", max_cycles));
+
+    if (trace_vcd_file.len() != 0) begin
+      $dumpfile(trace_vcd_file);
+      $dumpvars(0, tlul_fifo_sync_gpu_cov_cpu_replay_tb);
+    end
+
+    #1;
+    load_trace_replay_file();
+    repeat (max_cycles) begin
+      @(posedge dut.clk_i);
+      if (done) begin
+        print_summary();
+        $finish;
+      end
+    end
+    print_summary();
+    $fatal(1, "Timed out waiting for tlul_fifo_sync_gpu_cov_tb replay to finish");
+  end
+endmodule
diff --git a/designs/OpenTitan/src/tlul_fifo_sync_gpu_cov_rt_tb.sv b/designs/OpenTitan/src/tlul_fifo_sync_gpu_cov_rt_tb.sv
