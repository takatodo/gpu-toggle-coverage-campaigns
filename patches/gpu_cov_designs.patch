+      if (cpu_awlen_q == 4'b0 && cpu_awaddr_q[31:0] == UART_ADDR && cpu_wvalid_q) begin
+        if (cpu_wstrb_q == 16'h000f) begin
+          $write("%c", x_soc.biu_pad_wdata[7:0]);
+        end else if (cpu_wstrb_q == 16'h00f0) begin
+          $write("%c", x_soc.biu_pad_wdata[39:32]);
+        end else if (cpu_wstrb_q == 16'h0f00) begin
+          $write("%c", x_soc.biu_pad_wdata[71:64]);
+        end else if (cpu_wstrb_q == 16'hf000) begin
+          $write("%c", x_soc.biu_pad_wdata[103:96]);
+        end
+      end
+
+      if (finish_pending_q) begin
+        if (pass_seen_q) begin
+          $display("**********************************************");
+          $display("*    simulation finished successfully        *");
+          $display("**********************************************");
+          $display("TEST PASSED");
+        end else begin
+          $display("**********************************************");
+          $display("*    simulation finished with error          *");
+          $display("**********************************************");
+          $display("TEST FAILED");
+        end
+        $finish;
+      end
+    end
+  end
+
+  assign cfg_signature_o        = cfg_signature_q;
+  assign done_o                 = pass_seen_q || fail_seen_q;
+  assign host_req_accepted_o    = write_count_q;
+  assign device_req_accepted_o  = uart_char_count_q;
+  assign device_rsp_accepted_o  = retire_count_q;
+  assign host_rsp_accepted_o    = finish_count_q;
+  assign rsp_queue_overflow_o   = 32'd0;
+  assign progress_cycle_count_o = cycle_count_q;
+  assign progress_signature_o   = cfg_signature_q
+                                ^ cycle_count_q
+                                ^ retire_count_q
+                                ^ write_count_q
+                                ^ uart_char_count_q
+                                ^ finish_count_q;
+
+  assign toggle_bitmap_word0_o = {26'd0, zero_len_write_seen_q, awaddr_high_seen_q, bus_write_seen_q, retire_16_q, retire_seen_q, cycle_seen_q};
+  assign toggle_bitmap_word1_o = {26'd0, upper_lane_seen_q, low_lane_seen_q, uart_burst_seen_q, fail_seen_q, pass_seen_q, uart_char_seen_q};
+  assign toggle_bitmap_word2_o = {26'd0, cfg_signature_seen_q, cfg_valid_seen_q, finish_seen_q, long_run_seen_q, value1_seen_q, value0_seen_q};
+
+  assign real_toggle_subset_word0_o  = {31'd0, cycle_seen_q};
+  assign real_toggle_subset_word1_o  = {31'd0, retire_seen_q};
+  assign real_toggle_subset_word2_o  = {31'd0, retire_16_q};
+  assign real_toggle_subset_word3_o  = {31'd0, bus_write_seen_q};
+  assign real_toggle_subset_word4_o  = {31'd0, awaddr_high_seen_q};
+  assign real_toggle_subset_word5_o  = {31'd0, zero_len_write_seen_q};
+  assign real_toggle_subset_word6_o  = {31'd0, uart_char_seen_q};
+  assign real_toggle_subset_word7_o  = {31'd0, pass_seen_q};
+  assign real_toggle_subset_word8_o  = {31'd0, fail_seen_q};
+  assign real_toggle_subset_word9_o  = {31'd0, uart_burst_seen_q};
+  assign real_toggle_subset_word10_o = {31'd0, low_lane_seen_q};
+  assign real_toggle_subset_word11_o = {31'd0, upper_lane_seen_q};
+  assign real_toggle_subset_word12_o = {31'd0, value0_seen_q};
+  assign real_toggle_subset_word13_o = {31'd0, value1_seen_q};
+  assign real_toggle_subset_word14_o = {31'd0, long_run_seen_q};
+  assign real_toggle_subset_word15_o = {31'd0, finish_seen_q};
+  assign real_toggle_subset_word16_o = {31'd0, cfg_valid_seen_q};
+  assign real_toggle_subset_word17_o = {31'd0, cfg_signature_seen_q};
+
+  assign focused_wave_word0_o = x_soc.biu_pad_retire_pc_0[31:0];
+  assign focused_wave_word1_o = {24'd0, x_soc.biu_pad_retire_0, x_soc.biu_pad_retire_pc_0[38:32]};
+  assign focused_wave_word2_o = x_soc.biu_pad_awaddr[31:0];
+  assign focused_wave_word3_o = x_soc.biu_pad_haddr[31:0];
+  assign focused_wave_word4_o = {28'd0, simaccel_mem_loaded[0], soc_rst_b_proxy, x_soc.biu_pad_retire_0, uart0_sout};
+  assign focused_wave_word5_o = {14'd0, x_soc.biu_pad_wstrb, 1'b0, x_soc.biu_pad_wvalid};
+  assign focused_wave_word6_o = x_soc.x_axi_slave128.mem_addr[31:0];
+  assign focused_wave_word7_o = x_soc.x_cpu_sub_system_axi.x_c906_wrapper.x_cpu_top.x_aq_top_0.x_aq_core.x_aq_rtu_top.x_aq_rtu_wb.wb_wb0_data[31:0];
+
+`include "__rtlmeter_top_include.vh"
+
+endmodule
