diff --git a/designs/Caliptra/src/caliptra-rtl/caliptra_gpu_cov_tb.sv b/designs/Caliptra/src/caliptra-rtl/caliptra_gpu_cov_tb.sv
new file mode 100644
index 0000000..320b525
--- /dev/null
+++ b/designs/Caliptra/src/caliptra-rtl/caliptra_gpu_cov_tb.sv
@@ -0,0 +1,268 @@
+// SPDX-License-Identifier: Apache-2.0
+//
+// Coarse gpu_cov wrapper for Caliptra.
+// Reuses the stock caliptra_top_tb and exports lightweight progress/traffic
+// proxies through the fixed output words expected by the GPU coverage flow.
+
+`timescale 1ns/100ps
+
+module caliptra_gpu_cov_tb (
+  input  logic        cfg_valid_i,
+  input  logic [31:0] cfg_batch_length_i,
+  input  logic [31:0] cfg_req_valid_pct_i,
+  input  logic [31:0] cfg_rsp_valid_pct_i,
+  input  logic [31:0] cfg_host_d_ready_pct_i,
+  input  logic [31:0] cfg_device_a_ready_pct_i,
+  input  logic [31:0] cfg_put_full_pct_i,
+  input  logic [31:0] cfg_put_partial_pct_i,
+  input  logic [31:0] cfg_req_fill_target_i,
+  input  logic [31:0] cfg_req_burst_len_max_i,
+  input  logic [31:0] cfg_req_family_i,
+  input  logic [31:0] cfg_req_address_mode_i,
+  input  logic [31:0] cfg_req_data_mode_i,
+  input  logic [31:0] cfg_req_data_hi_xor_i,
+  input  logic [31:0] cfg_access_ack_data_pct_i,
+  input  logic [31:0] cfg_rsp_error_pct_i,
+  input  logic [31:0] cfg_rsp_fill_target_i,
+  input  logic [31:0] cfg_rsp_delay_max_i,
+  input  logic [31:0] cfg_rsp_family_i,
+  input  logic [31:0] cfg_rsp_delay_mode_i,
+  input  logic [31:0] cfg_rsp_data_mode_i,
+  input  logic [31:0] cfg_rsp_data_hi_xor_i,
+  input  logic [31:0] cfg_reset_cycles_i,
+  input  logic [31:0] cfg_drain_cycles_i,
+  input  logic [31:0] cfg_seed_i,
+  input  logic [31:0] cfg_address_base_i,
+  input  logic [31:0] cfg_address_mask_i,
+  input  logic [31:0] cfg_source_mask_i,
+  output logic [31:0] cfg_signature_o,
+  output logic        done_o,
+  output logic [31:0] host_req_accepted_o,
+  output logic [31:0] device_req_accepted_o,
+  output logic [31:0] device_rsp_accepted_o,
+  output logic [31:0] host_rsp_accepted_o,
+  output logic [31:0] rsp_queue_overflow_o,
+  output logic [31:0] progress_cycle_count_o,
+  output logic [31:0] progress_signature_o,
+  output logic [31:0] toggle_bitmap_word0_o,
+  output logic [31:0] toggle_bitmap_word1_o,
+  output logic [31:0] toggle_bitmap_word2_o,
+  output logic [31:0] real_toggle_subset_word0_o,
+  output logic [31:0] real_toggle_subset_word1_o,
+  output logic [31:0] real_toggle_subset_word2_o,
+  output logic [31:0] real_toggle_subset_word3_o,
+  output logic [31:0] real_toggle_subset_word4_o,
+  output logic [31:0] real_toggle_subset_word5_o,
+  output logic [31:0] real_toggle_subset_word6_o,
+  output logic [31:0] real_toggle_subset_word7_o,
+  output logic [31:0] real_toggle_subset_word8_o,
+  output logic [31:0] real_toggle_subset_word9_o,
+  output logic [31:0] real_toggle_subset_word10_o,
+  output logic [31:0] real_toggle_subset_word11_o,
+  output logic [31:0] real_toggle_subset_word12_o,
+  output logic [31:0] real_toggle_subset_word13_o,
+  output logic [31:0] real_toggle_subset_word14_o,
+  output logic [31:0] real_toggle_subset_word15_o,
+  output logic [31:0] real_toggle_subset_word16_o,
+  output logic [31:0] real_toggle_subset_word17_o,
+  output logic [31:0] focused_wave_word0_o,
+  output logic [31:0] focused_wave_word1_o,
+  output logic [31:0] focused_wave_word2_o,
+  output logic [31:0] focused_wave_word3_o,
+  output logic [31:0] focused_wave_word4_o,
+  output logic [31:0] focused_wave_word5_o,
+  output logic [31:0] focused_wave_word6_o,
+  output logic [31:0] focused_wave_word7_o
+);
+
+  caliptra_top_tb dut();
+
+  logic [31:0] host_req_accepted_q;
+  logic [31:0] device_req_accepted_q;
+  logic [31:0] device_rsp_accepted_q;
+  logic [31:0] host_rsp_accepted_q;
+  logic [31:0] last_mailbox_data_q;
+  logic [17:0] seen_bits_q;
+  logic        pass_seen_q;
+  logic        fail_seen_q;
+  logic [31:0] cycle_count_q;
+  logic [31:0] commit_count_q;
+  logic [31:0] cfg_signature_q;
+
+  logic host_aw_accept;
+  logic host_w_accept;
+  logic host_b_accept;
+  logic host_ar_accept;
+  logic host_r_accept;
+
+  always_comb begin
+    host_aw_accept = dut.m_axi_bfm_if.awvalid && dut.m_axi_bfm_if.awready;
+    host_w_accept  = dut.m_axi_bfm_if.wvalid && dut.m_axi_bfm_if.wready;
+    host_b_accept  = dut.m_axi_bfm_if.bvalid && dut.m_axi_bfm_if.bready;
+    host_ar_accept = dut.m_axi_bfm_if.arvalid && dut.m_axi_bfm_if.arready;
+    host_r_accept  = dut.m_axi_bfm_if.rvalid && dut.m_axi_bfm_if.rready;
+
+    cycle_count_q  = dut.cycleCnt[31:0];
+    commit_count_q = dut.tb_services_i.commit_count[31:0];
+    cfg_signature_q = cfg_batch_length_i ^ cfg_seed_i ^ cfg_reset_cycles_i ^ cfg_drain_cycles_i
+                    ^ cfg_req_family_i ^ cfg_rsp_family_i ^ cfg_address_base_i ^ cfg_address_mask_i
+                    ^ cfg_source_mask_i ^ cfg_req_valid_pct_i ^ cfg_rsp_valid_pct_i
+                    ^ {31'd0, cfg_valid_i};
+  end
+
+  always_ff @(posedge dut.core_clk or negedge dut.cptra_rst_b) begin
+    if (!dut.cptra_rst_b) begin
+      host_req_accepted_q   <= '0;
+      device_req_accepted_q <= '0;
+      device_rsp_accepted_q <= '0;
+      host_rsp_accepted_q   <= '0;
+      last_mailbox_data_q   <= '0;
+      seen_bits_q           <= '0;
+      pass_seen_q           <= 1'b0;
+      fail_seen_q           <= 1'b0;
+    end else begin
+      if (cfg_valid_i) begin
+        seen_bits_q[0] <= 1'b1;
+      end
+      if (dut.cptra_pwrgood) begin
+        seen_bits_q[1] <= 1'b1;
+      end
+      if (dut.cptra_rst_b) begin
+        seen_bits_q[2] <= 1'b1;
+      end
+      if (dut.ready_for_fuses) begin
+        seen_bits_q[3] <= 1'b1;
+      end
+      if (dut.ready_for_mb_processing) begin
+        seen_bits_q[4] <= 1'b1;
+      end
+      if (dut.mailbox_data_avail) begin
+        seen_bits_q[5] <= 1'b1;
+      end
+      if (dut.tb_services_i.mailbox_write) begin
+        seen_bits_q[6] <= 1'b1;
+        last_mailbox_data_q <= dut.tb_services_i.WriteData;
+        if (dut.tb_services_i.WriteData[7:0] == 8'hff) begin
+          pass_seen_q <= 1'b1;
+          seen_bits_q[17] <= 1'b1;
+        end
+        if (dut.tb_services_i.WriteData[7:0] == 8'h01) begin
+          fail_seen_q <= 1'b1;
+        end
+      end
+      if (dut.tb_services_i.mailbox_data_val) begin
+        seen_bits_q[7] <= 1'b1;
+      end
+      if (host_aw_accept) begin
+        host_req_accepted_q <= host_req_accepted_q + 32'd1;
+        device_req_accepted_q <= device_req_accepted_q + 32'd1;
+        seen_bits_q[8] <= 1'b1;
+      end
+      if (host_w_accept) begin
+        device_req_accepted_q <= device_req_accepted_q + 32'd1;
+        seen_bits_q[9] <= 1'b1;
+      end
+      if (host_b_accept) begin
+        device_rsp_accepted_q <= device_rsp_accepted_q + 32'd1;
+        host_rsp_accepted_q <= host_rsp_accepted_q + 32'd1;
+        seen_bits_q[10] <= 1'b1;
+      end
+      if (host_ar_accept) begin
+        host_req_accepted_q <= host_req_accepted_q + 32'd1;
+        seen_bits_q[11] <= 1'b1;
+      end
+      if (host_r_accept) begin
+        device_rsp_accepted_q <= device_rsp_accepted_q + 32'd1;
+        host_rsp_accepted_q <= host_rsp_accepted_q + 32'd1;
+        seen_bits_q[12] <= 1'b1;
+      end
+      if (cycle_count_q >= 32'd64) begin
+        seen_bits_q[13] <= 1'b1;
+      end
+      if (cycle_count_q >= 32'd512) begin
+        seen_bits_q[14] <= 1'b1;
+      end
+      if (commit_count_q >= 32'd1) begin
+        seen_bits_q[15] <= 1'b1;
+      end
+      if (commit_count_q >= 32'd32) begin
+        seen_bits_q[16] <= 1'b1;
+      end
+      if (dut.cptra_error_fatal || dut.cptra_error_non_fatal) begin
+        fail_seen_q <= 1'b1;
+      end
+    end
+  end
+
+  assign cfg_signature_o        = cfg_signature_q;
+  assign done_o                 = pass_seen_q | fail_seen_q;
+  assign host_req_accepted_o    = host_req_accepted_q;
+  assign device_req_accepted_o  = device_req_accepted_q;
+  assign device_rsp_accepted_o  = device_rsp_accepted_q;
+  assign host_rsp_accepted_o    = host_rsp_accepted_q;
+  assign rsp_queue_overflow_o   = 32'd0;
+  assign progress_cycle_count_o = cycle_count_q;
+  assign progress_signature_o   = cfg_signature_q
+                                ^ cycle_count_q
+                                ^ commit_count_q
+                                ^ host_req_accepted_q
+                                ^ device_req_accepted_q
+                                ^ device_rsp_accepted_q
+                                ^ host_rsp_accepted_q
+                                ^ last_mailbox_data_q
+                                ^ {14'd0, seen_bits_q};
+
+  assign toggle_bitmap_word0_o = {14'd0, seen_bits_q[17:0]};
+  assign toggle_bitmap_word1_o = {
+    24'd0,
+    dut.cptra_error_non_fatal,
+    dut.cptra_error_fatal,
+    dut.mailbox_data_avail,
+    dut.ready_for_mb_processing,
+    dut.ready_for_fuses,
+    host_r_accept,
+    host_b_accept,
+    host_w_accept
+  };
+  assign toggle_bitmap_word2_o = {
+    24'd0,
+    host_ar_accept,
+    host_aw_accept,
+    pass_seen_q,
+    fail_seen_q,
+    dut.tb_services_i.mailbox_data_val,
+    dut.tb_services_i.mailbox_write,
+    dut.cptra_rst_b,
+    dut.cptra_pwrgood
+  };
+
+  assign real_toggle_subset_word0_o  = {31'd0, seen_bits_q[0]};
+  assign real_toggle_subset_word1_o  = {31'd0, seen_bits_q[1]};
+  assign real_toggle_subset_word2_o  = {31'd0, seen_bits_q[2]};
+  assign real_toggle_subset_word3_o  = {31'd0, seen_bits_q[3]};
+  assign real_toggle_subset_word4_o  = {31'd0, seen_bits_q[4]};
+  assign real_toggle_subset_word5_o  = {31'd0, seen_bits_q[5]};
+  assign real_toggle_subset_word6_o  = {31'd0, seen_bits_q[6]};
+  assign real_toggle_subset_word7_o  = {31'd0, seen_bits_q[7]};
+  assign real_toggle_subset_word8_o  = {31'd0, seen_bits_q[8]};
+  assign real_toggle_subset_word9_o  = {31'd0, seen_bits_q[9]};
+  assign real_toggle_subset_word10_o = {31'd0, seen_bits_q[10]};
+  assign real_toggle_subset_word11_o = {31'd0, seen_bits_q[11]};
+  assign real_toggle_subset_word12_o = {31'd0, seen_bits_q[12]};
+  assign real_toggle_subset_word13_o = {31'd0, seen_bits_q[13]};
+  assign real_toggle_subset_word14_o = {31'd0, seen_bits_q[14]};
+  assign real_toggle_subset_word15_o = {31'd0, seen_bits_q[15]};
+  assign real_toggle_subset_word16_o = {31'd0, seen_bits_q[16]};
+  assign real_toggle_subset_word17_o = {31'd0, seen_bits_q[17]};
+
+  assign focused_wave_word0_o = cycle_count_q;
+  assign focused_wave_word1_o = commit_count_q;
+  assign focused_wave_word2_o = host_req_accepted_q;
+  assign focused_wave_word3_o = device_rsp_accepted_q;
+  assign focused_wave_word4_o = last_mailbox_data_q;
+  assign focused_wave_word5_o = {27'd0, fail_seen_q, pass_seen_q, dut.mailbox_data_avail,
+                                 dut.ready_for_mb_processing, dut.ready_for_fuses};
+  assign focused_wave_word6_o = {30'd0, dut.cptra_error_non_fatal, dut.cptra_error_fatal};
+  assign focused_wave_word7_o = cfg_signature_q;
+
+endmodule
