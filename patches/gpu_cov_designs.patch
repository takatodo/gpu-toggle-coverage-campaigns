index 0000000..bde0b74
--- /dev/null
+++ b/designs/OpenTitan/src/tlul_fifo_sync_gpu_cov_rt_tb.sv
@@ -0,0 +1,393 @@
+// Copyright lowRISC contributors (OpenTitan project).
+// SPDX-License-Identifier: Apache-2.0
+//
+// Bench-friendly GPU coverage target for tlul_fifo_sync.
+// This keeps the shared batch contract but avoids event-driven queue semantics
+// so sim-accel can advance it as a pure next-state workload.
+
+module tlul_fifo_sync_gpu_cov_rt_tb (
+  input  logic        cfg_valid_i,
+  input  logic [31:0] cfg_batch_length_i,
+  input  logic [31:0] cfg_req_valid_pct_i,
+  input  logic [31:0] cfg_rsp_valid_pct_i,
+  input  logic [31:0] cfg_host_d_ready_pct_i,
+  input  logic [31:0] cfg_device_a_ready_pct_i,
+  input  logic [31:0] cfg_put_full_pct_i,
+  input  logic [31:0] cfg_put_partial_pct_i,
+  input  logic [31:0] cfg_access_ack_data_pct_i,
+  input  logic [31:0] cfg_rsp_error_pct_i,
+  input  logic [31:0] cfg_reset_cycles_i,
+  input  logic [31:0] cfg_drain_cycles_i,
+  input  logic [31:0] cfg_seed_i,
+  input  logic [31:0] cfg_address_base_i,
+  input  logic [31:0] cfg_address_mask_i,
+  input  logic [31:0] cfg_source_mask_i,
+  output logic [31:0] cfg_signature_o,
+  output logic        done_o,
+  output logic [31:0] host_req_accepted_o,
+  output logic [31:0] device_req_accepted_o,
+  output logic [31:0] device_rsp_accepted_o,
+  output logic [31:0] host_rsp_accepted_o,
+  output logic [31:0] rsp_queue_overflow_o,
+  output logic [31:0] progress_cycle_count_o,
+  output logic [31:0] progress_signature_o,
+  output logic [31:0] toggle_bitmap_word0_o,
+  output logic [31:0] toggle_bitmap_word1_o,
+  output logic [31:0] toggle_bitmap_word2_o
+);
+  import tlul_pkg::*;
+
+  localparam int unsigned WarmupCycles = 2;
+  localparam int unsigned TogglePointCount = 96;
+
+  logic clk_i;
+  logic rst_ni;
+
+  tl_h2d_t tl_h_i;
+  tl_d2h_t tl_h_o;
+  tl_h2d_t tl_d_o;
+  tl_d2h_t tl_d_i;
+
+  logic [0:0] spare_req_i;
+  logic [0:0] spare_req_o;
+  logic [0:0] spare_rsp_i;
+  logic [0:0] spare_rsp_o;
+
+  int unsigned batch_length;
+  int unsigned req_valid_pct;
+  int unsigned rsp_valid_pct;
+  int unsigned host_d_ready_pct;
+  int unsigned device_a_ready_pct;
+  int unsigned put_full_pct;
+  int unsigned put_partial_pct;
+  int unsigned access_ack_data_pct;
+  int unsigned rsp_error_pct;
+  int unsigned reset_cycles;
+  int unsigned drain_cycles;
+  int unsigned seed;
+  int unsigned address_base;
+  int unsigned address_mask;
+  int unsigned source_mask;
+
+  logic [31:0] cycle_count_q;
+  logic [31:0] rand_state_q;
+  logic [31:0] outstanding_rsp_q;
+  logic [31:0] host_req_accepted_q;
+  logic [31:0] device_req_accepted_q;
+  logic [31:0] device_rsp_accepted_q;
+  logic [31:0] host_rsp_accepted_q;
+  logic [31:0] rsp_queue_overflow_q;
+  logic [31:0] progress_signature_q;
+
+  logic [TogglePointCount-1:0] toggle_curr_d;
+  logic [TogglePointCount-1:0] toggle_prev_q;
+  logic [TogglePointCount-1:0] toggle_hit_q;
+
+  logic traffic_phase;
+  logic drain_phase;
+  logic active_phase;
+  logic req_enable;
+  logic rsp_enable;
+  logic [31:0] traffic_window_end;
+  logic [31:0] drain_window_end;
+
+  logic [31:0] mix0;
+  logic [31:0] mix1;
+  logic [31:0] mix2;
+  logic [31:0] mix3;
+  logic [31:0] mix4;
+  logic [31:0] mix5;
+  logic [31:0] mix6;
+  logic [31:0] mix7;
+  logic [31:0] mix8;
+  logic [31:0] mix9;
+  logic [31:0] mix10;
+  logic [31:0] mix11;
+
+  tlul_fifo_sync dut (
+    .clk_i,
+    .rst_ni,
+    .tl_h_i,
+    .tl_h_o,
+    .tl_d_o,
+    .tl_d_i,
+    .spare_req_i,
+    .spare_req_o,
+    .spare_rsp_i,
+    .spare_rsp_o
+  );
+
+  always #5 clk_i = ~clk_i;
+
+  function automatic int unsigned clamp_pct(input int unsigned pct);
+    if (pct > 100) return 100;
+    return pct;
+  endfunction
+
+  function automatic logic [31:0] prng_next(input logic [31:0] state);
+    return state * 32'd1664525 + 32'd1013904223;
+  endfunction
+
+  function automatic tl_a_op_e choose_req_opcode(input logic [31:0] rand_word);
+    logic [31:0] pct_word;
+    pct_word = rand_word % 100;
+    if (pct_word < put_full_pct) begin
+      return PutFullData;
+    end else if (pct_word < (put_full_pct + put_partial_pct)) begin
+      return PutPartialData;
+    end
+    return Get;
+  endfunction
+
+  function automatic tl_d_op_e choose_rsp_opcode(input logic [31:0] rand_word);
+    return ((rand_word % 100) < access_ack_data_pct) ? AccessAckData : AccessAck;
+  endfunction
+
+  assign cfg_signature_o = {31'd0, cfg_valid_i}
+      ^ cfg_batch_length_i
+      ^ cfg_req_valid_pct_i
+      ^ cfg_rsp_valid_pct_i
+      ^ cfg_host_d_ready_pct_i
+      ^ cfg_device_a_ready_pct_i
+      ^ cfg_put_full_pct_i
+      ^ cfg_put_partial_pct_i
+      ^ cfg_access_ack_data_pct_i
+      ^ cfg_rsp_error_pct_i
+      ^ cfg_reset_cycles_i
+      ^ cfg_drain_cycles_i
+      ^ cfg_seed_i
+      ^ cfg_address_base_i
+      ^ cfg_address_mask_i
+      ^ cfg_source_mask_i;
+
+  assign host_req_accepted_o = host_req_accepted_q[31:0];
+  assign device_req_accepted_o = device_req_accepted_q[31:0];
+  assign device_rsp_accepted_o = device_rsp_accepted_q[31:0];
+  assign host_rsp_accepted_o = host_rsp_accepted_q[31:0];
+  assign rsp_queue_overflow_o = rsp_queue_overflow_q[31:0];
+  assign progress_cycle_count_o = cycle_count_q[31:0];
+  assign progress_signature_o = progress_signature_q[31:0];
+  assign toggle_bitmap_word0_o = toggle_curr_d[31:0];
+  assign toggle_bitmap_word1_o = toggle_curr_d[63:32];
+  assign toggle_bitmap_word2_o = toggle_curr_d[95:64];
+
+  always_comb begin
+    if (cfg_valid_i) begin
+      batch_length = cfg_batch_length_i;
+      req_valid_pct = cfg_req_valid_pct_i;
+      rsp_valid_pct = cfg_rsp_valid_pct_i;
+      host_d_ready_pct = cfg_host_d_ready_pct_i;
+      device_a_ready_pct = cfg_device_a_ready_pct_i;
+      put_full_pct = cfg_put_full_pct_i;
+      put_partial_pct = cfg_put_partial_pct_i;
+      access_ack_data_pct = cfg_access_ack_data_pct_i;
+      rsp_error_pct = cfg_rsp_error_pct_i;
+      reset_cycles = cfg_reset_cycles_i;
+      drain_cycles = cfg_drain_cycles_i;
+      seed = cfg_seed_i;
+      address_base = cfg_address_base_i;
+      address_mask = cfg_address_mask_i;
+      source_mask = cfg_source_mask_i;
+    end else begin
+      batch_length = 256;
+      req_valid_pct = 65;
+      rsp_valid_pct = 70;
+      host_d_ready_pct = 75;
+      device_a_ready_pct = 80;
+      put_full_pct = 34;
+      put_partial_pct = 33;
+      access_ack_data_pct = 50;
+      rsp_error_pct = 10;
+      reset_cycles = 4;
+      drain_cycles = 16;
+      seed = 1;
+      address_base = 0;
+      address_mask = 32'h0000_0ffc;
+      source_mask = (32'd1 << top_pkg::TL_AIW) - 1;
+    end
+  end
+
+  always_comb begin
+    traffic_window_end = reset_cycles + WarmupCycles + batch_length;
+    drain_window_end = traffic_window_end + drain_cycles;
+    rst_ni = (cycle_count_q >= reset_cycles);
+    traffic_phase = rst_ni && (cycle_count_q >= (reset_cycles + WarmupCycles))
+                    && (cycle_count_q < traffic_window_end);
+    drain_phase = rst_ni && (cycle_count_q >= traffic_window_end)
+                  && (cycle_count_q < drain_window_end);
+    active_phase = traffic_phase || drain_phase;
+    req_enable = traffic_phase;
+    rsp_enable = traffic_phase || drain_phase;
+    done_o = rst_ni && (cycle_count_q >= drain_window_end);
+
+    mix0 = prng_next(rand_state_q ^ (cycle_count_q + 32'h1020_3040));
+    mix1 = prng_next(mix0 ^ 32'h5566_7788);
+    mix2 = prng_next(mix1 ^ 32'h89ab_cdef);
+    mix3 = prng_next(mix2 ^ 32'h1357_9bdf);
+    mix4 = prng_next(mix3 ^ 32'h2468_ace0);
+    mix5 = prng_next(mix4 ^ 32'h0f1e_2d3c);
+    mix6 = prng_next(mix5 ^ 32'h4b5a_6978);
+    mix7 = prng_next(mix6 ^ 32'h8877_6655);
+    mix8 = prng_next(mix7 ^ 32'hdead_beef);
+    mix9 = prng_next(mix8 ^ 32'h3141_5926);
+    mix10 = prng_next(mix9 ^ 32'h2718_2818);
+    mix11 = prng_next(mix10 ^ 32'h1123_5813);
+
+    tl_h_i = tlul_pkg::TL_H2D_DEFAULT;
+    tl_d_i = tlul_pkg::TL_D2H_DEFAULT;
+    spare_req_i = '0;
+    spare_rsp_i = '0;
+
+    if (active_phase) begin
+      tl_h_i.d_ready = ((mix0 % 100) < clamp_pct(host_d_ready_pct));
+      tl_d_i.a_ready = ((mix1 % 100) < clamp_pct(device_a_ready_pct));
+
+      tl_h_i.a_valid = req_enable && ((mix2 % 100) < clamp_pct(req_valid_pct));
+      tl_h_i.a_opcode = choose_req_opcode(mix3);
+      tl_h_i.a_param = mix4[2:0];
+      tl_h_i.a_size = mix5[top_pkg::TL_SZW-1:0];
+      tl_h_i.a_source = mix6[top_pkg::TL_AIW-1:0] & source_mask[top_pkg::TL_AIW-1:0];
+      tl_h_i.a_address = (address_base & ~address_mask) | (mix7 & address_mask);
+      tl_h_i.a_address[1:0] = 2'b00;
+      tl_h_i.a_mask = mix8[top_pkg::TL_DBW-1:0];
+      tl_h_i.a_data = mix9;
+      tl_h_i.a_user = tlul_pkg::TL_A_USER_DEFAULT;
+      tl_h_i.a_user.rsvd = mix10[tlul_pkg::RsvdWidth-1:0];
+      tl_h_i.a_user.instr_type = mix10[8]
+          ? prim_mubi_pkg::MuBi4True
+          : prim_mubi_pkg::MuBi4False;
+      tl_h_i.a_user.cmd_intg = mix11[tlul_pkg::H2DCmdIntgWidth-1:0];
+      tl_h_i.a_user.data_intg = mix6[tlul_pkg::DataIntgWidth-1:0];
+      spare_req_i = mix9[0];
+
+      tl_d_i.d_valid = rsp_enable && ((mix3 % 100) < clamp_pct(rsp_valid_pct));
+      tl_d_i.d_opcode = choose_rsp_opcode(mix4);
+      tl_d_i.d_param = mix5[2:0];
+      tl_d_i.d_size = mix6[top_pkg::TL_SZW-1:0];
+      tl_d_i.d_source = mix7[top_pkg::TL_AIW-1:0] & source_mask[top_pkg::TL_AIW-1:0];
+      tl_d_i.d_sink = mix8[top_pkg::TL_DIW-1:0];
+      tl_d_i.d_data = mix10;
+      tl_d_i.d_user = tlul_pkg::TL_D_USER_DEFAULT;
+      tl_d_i.d_user.rsp_intg = mix11[tlul_pkg::D2HRspIntgWidth-1:0];
+      tl_d_i.d_user.data_intg = mix2[tlul_pkg::DataIntgWidth-1:0];
+      tl_d_i.d_error = ((mix9 % 100) < clamp_pct(rsp_error_pct));
+      spare_rsp_i = mix11[0];
+    end
+
+    toggle_curr_d = '0;
+    toggle_curr_d[0] = traffic_phase;
+    toggle_curr_d[1] = drain_phase;
+    toggle_curr_d[2] = req_enable;
+    toggle_curr_d[3] = rsp_enable;
+    toggle_curr_d[4] = tl_h_i.a_valid;
+    toggle_curr_d[5] = tl_d_i.d_valid;
+    toggle_curr_d[6] = tl_h_i.d_ready;
+    toggle_curr_d[7] = tl_d_i.a_ready;
+    toggle_curr_d[8 +: 8] = cycle_count_q[7:0];
+    toggle_curr_d[16 +: 8] = mix0[7:0];
+    toggle_curr_d[24 +: 8] = mix3[7:0];
+    toggle_curr_d[32] = dut.reqfifo.gen_normal_fifo.under_rst;
+    toggle_curr_d[33] = dut.rspfifo.gen_normal_fifo.under_rst;
+    toggle_curr_d[34] = dut.reqfifo.gen_normal_fifo.fifo_empty;
+    toggle_curr_d[35] = dut.rspfifo.gen_normal_fifo.fifo_empty;
+    toggle_curr_d[36] = dut.reqfifo.gen_normal_fifo.empty;
+    toggle_curr_d[37] = dut.rspfifo.gen_normal_fifo.empty;
+    toggle_curr_d[38] = dut.reqfifo.gen_normal_fifo.fifo_incr_wptr;
+    toggle_curr_d[39] = dut.reqfifo.gen_normal_fifo.fifo_incr_rptr;
+    toggle_curr_d[40] = dut.rspfifo.gen_normal_fifo.fifo_incr_wptr;
+    toggle_curr_d[41] = dut.rspfifo.gen_normal_fifo.fifo_incr_rptr;
+    toggle_curr_d[42] = dut.reqfifo.full_o;
+    toggle_curr_d[43] = dut.rspfifo.full_o;
+    toggle_curr_d[44] = dut.reqfifo.wready_o;
+    toggle_curr_d[45] = dut.rspfifo.wready_o;
+    toggle_curr_d[46] = dut.reqfifo.rvalid_o;
+    toggle_curr_d[47] = dut.rspfifo.rvalid_o;
+    toggle_curr_d[32 +: 3] = tl_h_i.a_opcode;
+    toggle_curr_d[35 +: 3] = tl_d_i.d_opcode;
+    toggle_curr_d[38 +: 3] = tl_d_o.a_opcode;
+    toggle_curr_d[41 +: 3] = tl_h_o.d_opcode;
+    toggle_curr_d[44 +: 2] = tl_h_i.a_size;
+    toggle_curr_d[46 +: 2] = tl_d_i.d_size;
+    toggle_curr_d[48 +: 2] = tl_d_o.a_size;
+    toggle_curr_d[50 +: 2] = tl_h_o.d_size;
+    toggle_curr_d[52 +: top_pkg::TL_AIW] = tl_h_i.a_source;
+    toggle_curr_d[60 +: top_pkg::TL_AIW] = tl_d_i.d_source;
+    toggle_curr_d[68 +: top_pkg::TL_DIW] = tl_d_i.d_sink;
+    toggle_curr_d[69 +: 8] = tl_h_i.a_address[9:2];
+    toggle_curr_d[77 +: top_pkg::TL_DBW] = tl_h_i.a_mask;
+    toggle_curr_d[81 +: 3] = outstanding_rsp_q[2:0];
+    toggle_curr_d[84 +: 2] = dut.reqfifo.gen_normal_fifo.u_fifo_cnt.wptr_wrap_cnt_q;
+    toggle_curr_d[86 +: 2] = dut.reqfifo.gen_normal_fifo.u_fifo_cnt.rptr_wrap_cnt_q;
+    toggle_curr_d[88 +: 2] = dut.rspfifo.gen_normal_fifo.u_fifo_cnt.wptr_wrap_cnt_q;
+    toggle_curr_d[90 +: 2] = dut.rspfifo.gen_normal_fifo.u_fifo_cnt.rptr_wrap_cnt_q;
+    toggle_curr_d[92] = req_enable;
+    toggle_curr_d[93] = rsp_enable;
+    toggle_curr_d[94] = active_phase;
+    toggle_curr_d[95] = done_o;
+  end
+
+  initial begin
+    clk_i = 1'b0;
+    cycle_count_q = 0;
+    rand_state_q = 32'h1;
+    outstanding_rsp_q = 0;
+    host_req_accepted_q = 0;
+    device_req_accepted_q = 0;
+    device_rsp_accepted_q = 0;
+    host_rsp_accepted_q = 0;
+    rsp_queue_overflow_q = 0;
+    progress_signature_q = 0;
+    toggle_prev_q = '0;
+    toggle_hit_q = '0;
+  end
+
+  always_ff @(posedge clk_i) begin
+    if (!done_o) begin
+      cycle_count_q <= cycle_count_q + 1;
+      rand_state_q <= prng_next(rand_state_q ^ cfg_signature_o ^ cycle_count_q);
+    end
+
+    if (!rst_ni) begin
+      outstanding_rsp_q <= 0;
+      host_req_accepted_q <= 0;
+      device_req_accepted_q <= 0;
+      device_rsp_accepted_q <= 0;
+      host_rsp_accepted_q <= 0;
+      rsp_queue_overflow_q <= 0;
+      progress_signature_q <= 0;
+      toggle_prev_q <= '0;
+      toggle_hit_q <= '0;
+    end else begin
+      progress_signature_q <= progress_signature_q
+                              ^ mix0 ^ mix3 ^ cycle_count_q
+                              ^ {31'd0, tl_h_i.a_valid}
+                              ^ ({31'd0, tl_d_i.d_valid} << 1)
+                              ^ ({31'd0, tl_h_o.a_ready} << 2)
+                              ^ ({31'd0, tl_h_o.d_valid} << 3);
+      toggle_hit_q <= toggle_hit_q | (toggle_curr_d ^ toggle_prev_q);
+      toggle_prev_q <= toggle_curr_d;
+
+      if (tl_h_i.a_valid && tl_h_o.a_ready) begin
+        host_req_accepted_q <= host_req_accepted_q + 1;
+      end
+      if (tl_d_o.a_valid && tl_d_i.a_ready) begin
+        device_req_accepted_q <= device_req_accepted_q + 1;
+        if (outstanding_rsp_q != 32'hffff_ffff) begin
+          outstanding_rsp_q <= outstanding_rsp_q + 1;
+        end else begin
+          rsp_queue_overflow_q <= rsp_queue_overflow_q + 1;
+        end
+      end
+      if (tl_d_i.d_valid && tl_d_o.d_ready) begin
+        device_rsp_accepted_q <= device_rsp_accepted_q + 1;
+      end
+      if (tl_h_o.d_valid && tl_h_i.d_ready) begin
+        host_rsp_accepted_q <= host_rsp_accepted_q + 1;
+        if (outstanding_rsp_q != 0) begin
+          outstanding_rsp_q <= outstanding_rsp_q - 1;
+        end
+      end
+    end
+  end
+
+endmodule
diff --git a/designs/OpenTitan/src/tlul_fifo_sync_gpu_cov_seq_tb.sv b/designs/OpenTitan/src/tlul_fifo_sync_gpu_cov_seq_tb.sv
