+    word_w[0]  = {31'd0, cfg_valid_i} | 32'h0000_0001;
+    word_w[1]  = y_w | 32'h0000_0001;
+    word_w[2]  = z_w | 32'h0000_0001;
+    word_w[3]  = w_w | 32'h0000_0001;
+    word_w[4]  = (a_w ^ b_w) | 32'h0000_0001;
+    word_w[5]  = (c_w ^ d_w) | 32'h0000_0001;
+    word_w[6]  = (y_w ^ z_w) | 32'h0000_0001;
+    word_w[7]  = (z_w ^ w_w) | 32'h0000_0001;
+    word_w[8]  = (y_w ^ w_w) | 32'h0000_0001;
+    word_w[9]  = (a_w + b_w) | 32'h0000_0001;
+    word_w[10] = (c_w + d_w) | 32'h0000_0001;
+    word_w[11] = (a_w - b_w) | 32'h0000_0001;
+    word_w[12] = (c_w - d_w) | 32'h0000_0001;
+    word_w[13] = ({y_w[15:0], z_w[15:0]}) | 32'h0000_0001;
+    word_w[14] = ({w_w[15:0], y_w[15:0]}) | 32'h0000_0001;
+    word_w[15] = progress_signature_w | 32'h0000_0001;
+    word_w[16] = cfg_signature_w | 32'h0000_0001;
+    word_w[17] = ((a_w & c_w) ^ (b_w | d_w)) | 32'h0000_0001;
+
+    seen_bits_w[0]  = |word_w[0];
+    seen_bits_w[1]  = |word_w[1];
+    seen_bits_w[2]  = |word_w[2];
+    seen_bits_w[3]  = |word_w[3];
+    seen_bits_w[4]  = |word_w[4];
+    seen_bits_w[5]  = |word_w[5];
+    seen_bits_w[6]  = |word_w[6];
+    seen_bits_w[7]  = |word_w[7];
+    seen_bits_w[8]  = |word_w[8];
+    seen_bits_w[9]  = |word_w[9];
+    seen_bits_w[10] = |word_w[10];
+    seen_bits_w[11] = |word_w[11];
+    seen_bits_w[12] = |word_w[12];
+    seen_bits_w[13] = |word_w[13];
+    seen_bits_w[14] = |word_w[14];
+    seen_bits_w[15] = |word_w[15];
+    seen_bits_w[16] = |word_w[16];
+    seen_bits_w[17] = |word_w[17];
+
+    cfg_signature_o = cfg_signature_w;
+    done_o = 1'b1;
+    host_req_accepted_o = y_w;
+    device_req_accepted_o = z_w;
+    device_rsp_accepted_o = w_w;
+    host_rsp_accepted_o = progress_count_w;
+    rsp_queue_overflow_o = 32'd0;
+    progress_cycle_count_o = progress_count_w;
+    progress_signature_o = progress_signature_w;
+    toggle_bitmap_word0_o = {14'd0, seen_bits_w};
+    toggle_bitmap_word1_o = y_w;
+    toggle_bitmap_word2_o = z_w ^ w_w;
+    real_toggle_subset_word0_o = word_w[0];
+    real_toggle_subset_word1_o = word_w[1];
+    real_toggle_subset_word2_o = word_w[2];
+    real_toggle_subset_word3_o = word_w[3];
+    real_toggle_subset_word4_o = word_w[4];
+    real_toggle_subset_word5_o = word_w[5];
+    real_toggle_subset_word6_o = word_w[6];
+    real_toggle_subset_word7_o = word_w[7];
+    real_toggle_subset_word8_o = word_w[8];
+    real_toggle_subset_word9_o = word_w[9];
+    real_toggle_subset_word10_o = word_w[10];
+    real_toggle_subset_word11_o = word_w[11];
+    real_toggle_subset_word12_o = word_w[12];
+    real_toggle_subset_word13_o = word_w[13];
+    real_toggle_subset_word14_o = word_w[14];
+    real_toggle_subset_word15_o = word_w[15];
+    real_toggle_subset_word16_o = word_w[16];
+    real_toggle_subset_word17_o = word_w[17];
+    focused_wave_word0_o = a_w;
+    focused_wave_word1_o = b_w;
+    focused_wave_word2_o = c_w;
+    focused_wave_word3_o = d_w;
+    focused_wave_word4_o = y_w;
+    focused_wave_word5_o = z_w;
+    focused_wave_word6_o = w_w;
+    focused_wave_word7_o = progress_signature_w;
+  end
+
+endmodule
+
+module example_gpu_cov_single_cluster_proof_dut (
+  input  logic [31:0] a,
+  input  logic [31:0] b,
+  input  logic [31:0] c,
+  input  logic [31:0] d,
+  output logic [31:0] y,
+  output logic [31:0] z,
+  output logic [31:0] w
+);
+
+  logic [31:0] n0;
+  logic [31:0] n1;
+  logic [31:0] n2;
+  logic [31:0] n3;
+  logic [31:0] n4;
+  logic [31:0] n5;
+  logic [31:0] n6;
+  logic [31:0] n7;
+  logic [31:0] n8;
+  logic [31:0] n9;
+  logic [31:0] n10;
+  logic [31:0] n11;
+
+  always_comb begin
+    n0 = a & b;
+    n1 = c ^ d;
+    n2 = ~n1;
+    n3 = a + b;
+    n4 = a - b;
+    n5 = {31'b0, (a == b)};
+    n6 = {31'b0, (c != d)};
+    n7 = {16'b0, a[23:8]};
+    n8 = {a[15:0], b[15:0]};
+    n9 = a << c[4:0];
+    n10 = b >> d[4:0];
+    n11 = a[0] ? n9 : n10;
+    y = n0 | n2;
+    z = (a ^ c) & ((~b) | d) ^ n3 ^ n4 ^ n8 ^ n11 ^ n7;
+    w = y ^ z ^ n5 ^ n6;
+  end
+
+endmodule
