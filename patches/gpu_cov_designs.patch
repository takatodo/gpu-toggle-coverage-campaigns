+task automatic gpu_cov_store_preload_bound(input bit [31:0] addr, input bit [31:0] value);
+{
+  lmem.mem[addr+3],
+  lmem.mem[addr+2],
+  lmem.mem[addr+1],
+  lmem.mem[addr]
+} = value;
+endtask
