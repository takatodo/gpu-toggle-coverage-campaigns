--- /dev/null
+++ b/designs/OpenTitan/src/tlul_fifo_async_cov_tb.sv
@@ -0,0 +1,901 @@
+// Copyright lowRISC contributors (OpenTitan project).
+// SPDX-License-Identifier: Apache-2.0
+//
+// GPU-toggle-ready standalone coverage target for tlul_fifo_async.
+
+module tlul_fifo_async_cov_tb (
+  input  logic        cfg_valid_i,
+  input  logic [31:0] cfg_batch_length_i,
+  input  logic [31:0] cfg_req_valid_pct_i,
+  input  logic [31:0] cfg_rsp_valid_pct_i,
+  input  logic [31:0] cfg_host_d_ready_pct_i,
+  input  logic [31:0] cfg_device_a_ready_pct_i,
+  input  logic [31:0] cfg_put_full_pct_i,
+  input  logic [31:0] cfg_put_partial_pct_i,
+  input  logic [31:0] cfg_req_fill_target_i,
+  input  logic [31:0] cfg_req_burst_len_max_i,
+  input  logic [31:0] cfg_req_family_i,
+  input  logic [31:0] cfg_req_address_mode_i,
+  input  logic [31:0] cfg_req_data_mode_i,
+  input  logic [31:0] cfg_req_data_hi_xor_i,
+  input  logic [31:0] cfg_access_ack_data_pct_i,
+  input  logic [31:0] cfg_rsp_error_pct_i,
+  input  logic [31:0] cfg_rsp_fill_target_i,
+  input  logic [31:0] cfg_rsp_delay_max_i,
+  input  logic [31:0] cfg_rsp_family_i,
+  input  logic [31:0] cfg_rsp_delay_mode_i,
+  input  logic [31:0] cfg_rsp_data_mode_i,
+  input  logic [31:0] cfg_rsp_data_hi_xor_i,
+  input  logic [31:0] cfg_reset_cycles_i,
+  input  logic [31:0] cfg_drain_cycles_i,
+  input  logic [31:0] cfg_seed_i,
+  input  logic [31:0] cfg_address_base_i,
+  input  logic [31:0] cfg_address_mask_i,
+  input  logic [31:0] cfg_source_mask_i,
+  output logic [31:0] cfg_signature_o,
+  output logic        done_o,
+  output logic [31:0] host_req_accepted_o,
+  output logic [31:0] device_req_accepted_o,
+  output logic [31:0] device_rsp_accepted_o,
+  output logic [31:0] host_rsp_accepted_o,
+  output logic [31:0] rsp_queue_overflow_o,
+  output logic [31:0] progress_cycle_count_o,
+  output logic [31:0] progress_signature_o,
+  output logic [31:0] toggle_bitmap_word0_o,
+  output logic [31:0] toggle_bitmap_word1_o,
+  output logic [31:0] toggle_bitmap_word2_o,
+  output logic [31:0] real_toggle_subset_word0_o,
+  output logic [31:0] real_toggle_subset_word1_o,
+  output logic [31:0] real_toggle_subset_word2_o,
+  output logic [31:0] real_toggle_subset_word3_o,
+  output logic [31:0] real_toggle_subset_word4_o,
+  output logic [31:0] real_toggle_subset_word5_o,
+  output logic [31:0] real_toggle_subset_word6_o,
+  output logic [31:0] real_toggle_subset_word7_o,
+  output logic [31:0] real_toggle_subset_word8_o,
+  output logic [31:0] real_toggle_subset_word9_o,
+  output logic [31:0] real_toggle_subset_word10_o,
+  output logic [31:0] real_toggle_subset_word11_o,
+  output logic [31:0] real_toggle_subset_word12_o,
+  output logic [31:0] real_toggle_subset_word13_o,
+  output logic [31:0] real_toggle_subset_word14_o,
+  output logic [31:0] real_toggle_subset_word15_o,
+  output logic [31:0] real_toggle_subset_word16_o,
+  output logic [31:0] real_toggle_subset_word17_o,
+  output logic [31:0] focused_wave_word0_o,
+  output logic [31:0] focused_wave_word1_o,
+  output logic [31:0] focused_wave_word2_o,
+  output logic [31:0] focused_wave_word3_o,
+  output logic [31:0] focused_wave_word4_o,
+  output logic [31:0] focused_wave_word5_o,
+  output logic [31:0] focused_wave_word6_o,
+  output logic [31:0] focused_wave_word7_o
+);
+  import tlul_pkg::*;
+
+  localparam logic [2:0] ResetPhase   = 3'd0;
+  localparam logic [2:0] WarmupPhase  = 3'd1;
+  localparam logic [2:0] TrafficPhase = 3'd2;
+  localparam logic [2:0] DrainPhase   = 3'd3;
+  localparam logic [2:0] DonePhase    = 3'd4;
+  localparam logic [31:0] WarmupCycles = 32'd2;
+  localparam int unsigned QueueDepth = 1024;
+  localparam int unsigned TogglePointCount = 96;
+  localparam int unsigned RealToggleChunkCount = 18;
+  localparam int unsigned FocusedWaveDepth = 8;
+
+  logic clk_i;
+  logic rst_ni;
+  logic clk_h_i;
+  logic rst_h_ni;
+  logic clk_d_i;
+  logic rst_d_ni;
+  logic        bootstrapped_q;
+  logic [2:0]  phase_q;
+  logic [31:0] cycle_count_q;
+  logic [31:0] reset_cycles_remaining_q;
+  logic [31:0] warmup_cycles_remaining_q;
+  logic [31:0] traffic_cycles_remaining_q;
+  logic [31:0] drain_cycles_remaining_q;
+
+  tl_h2d_t tl_h_i;
+  tl_d2h_t tl_h_o;
+  tl_h2d_t tl_d_o;
+  tl_d2h_t tl_d_i;
+
+  logic                   req_pending_valid_q;
+  tl_a_op_e               req_pending_opcode_q;
+  logic             [2:0] req_pending_param_q;
+  logic [top_pkg::TL_SZW-1:0] req_pending_size_q;
+  logic [top_pkg::TL_AIW-1:0] req_pending_source_q;
+  logic  [top_pkg::TL_AW-1:0] req_pending_address_q;
+  logic [top_pkg::TL_DBW-1:0] req_pending_mask_q;
+  logic  [top_pkg::TL_DW-1:0] req_pending_data_q;
+  tl_a_user_t             req_pending_user_q;
+  logic                   host_d_ready_q;
+  int unsigned            host_cycles_q;
+  int unsigned            host_rand_state_q;
+
+  logic                   rsp_pending_valid_q;
+  tl_d_op_e               rsp_pending_opcode_q;
+  logic             [2:0] rsp_pending_param_q;
+  logic [top_pkg::TL_SZW-1:0] rsp_pending_size_q;
+  logic [top_pkg::TL_AIW-1:0] rsp_pending_source_q;
+  logic [top_pkg::TL_DIW-1:0] rsp_pending_sink_q;
+  logic  [top_pkg::TL_DW-1:0] rsp_pending_data_q;
+  tl_d_user_t             rsp_pending_user_q;
+  logic                   rsp_pending_error_q;
+  logic                   device_a_ready_q;
+  int unsigned            device_cycles_q;
+  int unsigned            device_rand_state_q;
+
+  logic [top_pkg::TL_SZW-1:0] rsp_size_queue   [QueueDepth];
+  logic [top_pkg::TL_AIW-1:0] rsp_source_queue [QueueDepth];
+  int unsigned                rsp_head_q;
+  int unsigned                rsp_tail_q;
+  int unsigned                rsp_count_q;
+
+  int unsigned batch_length;
+  int unsigned req_valid_pct;
+  int unsigned rsp_valid_pct;
+  int unsigned host_d_ready_pct;
+  int unsigned device_a_ready_pct;
+  int unsigned put_full_pct;
+  int unsigned put_partial_pct;
+  int unsigned req_fill_target;
+  int unsigned req_burst_len_max;
+  int unsigned req_family;
+  int unsigned req_address_mode;
+  int unsigned req_data_mode;
+  int unsigned req_data_hi_xor;
+  int unsigned access_ack_data_pct;
+  int unsigned rsp_error_pct;
+  int unsigned rsp_fill_target;
+  int unsigned rsp_delay_max;
+  int unsigned rsp_family;
+  int unsigned rsp_delay_mode;
+  int unsigned rsp_data_mode;
+  int unsigned rsp_data_hi_xor;
+  int unsigned reset_cycles;
+  int unsigned drain_cycles;
+  int unsigned seed;
+  int unsigned address_base;
+  int unsigned address_mask;
+  int unsigned source_mask;
+  int unsigned host_req_accepted;
+  int unsigned device_req_accepted;
+  int unsigned device_rsp_accepted;
+  int unsigned host_rsp_accepted;
+  int unsigned rsp_queue_overflow;
+  logic [TogglePointCount-1:0] toggle_sample_w;
+  logic [TogglePointCount-1:0] toggle_prev_q;
+  logic [TogglePointCount-1:0] toggle_seen_q;
+  logic [15:0] real_word0_w, real_word1_w, real_word2_w, real_word3_w, real_word4_w;
+  logic [15:0] real_word5_w, real_word6_w, real_word7_w, real_word8_w, real_word9_w;
+  logic [15:0] real_word10_w, real_word11_w, real_word12_w, real_word13_w;
+  logic [15:0] real_word14_w, real_word15_w, real_word16_w, real_word17_w;
+  logic [15:0] real_prev_word0_q, real_prev_word1_q, real_prev_word2_q, real_prev_word3_q;
+  logic [15:0] real_prev_word4_q, real_prev_word5_q, real_prev_word6_q, real_prev_word7_q;
+  logic [15:0] real_prev_word8_q, real_prev_word9_q, real_prev_word10_q, real_prev_word11_q;
+  logic [15:0] real_prev_word12_q, real_prev_word13_q, real_prev_word14_q;
+  logic [15:0] real_prev_word15_q, real_prev_word16_q, real_prev_word17_q;
+  logic [31:0] real_hit_word0_q, real_hit_word1_q, real_hit_word2_q, real_hit_word3_q;
+  logic [31:0] real_hit_word4_q, real_hit_word5_q, real_hit_word6_q, real_hit_word7_q;
+  logic [31:0] real_hit_word8_q, real_hit_word9_q, real_hit_word10_q, real_hit_word11_q;
+  logic [31:0] real_hit_word12_q, real_hit_word13_q, real_hit_word14_q;
+  logic [31:0] real_hit_word15_q, real_hit_word16_q, real_hit_word17_q;
+  logic [31:0] focused_wave_q [0:FocusedWaveDepth-1];
+  logic [31:0] focused_pack_a_w;
+  logic [31:0] focused_pack_b_w;
+  logic [31:0] cfg_signature_w;
+  logic [31:0] progress_cycle_count_w;
+  logic [31:0] progress_signature_w;
+  logic        done_w;
+  logic        traffic_phase_w;
+  logic        response_phase_w;
+  logic        drain_busy_w;
+
+  tlul_fifo_async dut (
+    .clk_h_i,
+    .rst_h_ni,
+    .clk_d_i,
+    .rst_d_ni,
+    .tl_h_i,
+    .tl_h_o,
+    .tl_d_o,
+    .tl_d_i
+  );
+
+  // The GPU slice runner advances a single fixed-step simulation clock. Drive
+  // both async sides from that shared clock and express execution through an
+  // explicit phase contract instead of timed initial-block waits.
+  assign clk_h_i = clk_i;
+  assign clk_d_i = clk_i;
+  assign rst_h_ni = rst_ni;
+  assign rst_d_ni = rst_ni;
+  always #5 clk_i = ~clk_i;
+
+  always_comb begin
+    batch_length = cfg_valid_i ? cfg_batch_length_i : 32'd256;
+    req_valid_pct = clamp_pct(cfg_valid_i ? cfg_req_valid_pct_i : 32'd65);
+    rsp_valid_pct = clamp_pct(cfg_valid_i ? cfg_rsp_valid_pct_i : 32'd70);
+    host_d_ready_pct = clamp_pct(cfg_valid_i ? cfg_host_d_ready_pct_i : 32'd75);
+    device_a_ready_pct = clamp_pct(cfg_valid_i ? cfg_device_a_ready_pct_i : 32'd80);
+    put_full_pct = clamp_pct(cfg_valid_i ? cfg_put_full_pct_i : 32'd34);
+    put_partial_pct = clamp_pct(cfg_valid_i ? cfg_put_partial_pct_i : 32'd33);
+    if ((put_full_pct + put_partial_pct) > 100) begin
+      put_partial_pct = 100 - put_full_pct;
+    end
+    req_fill_target = cfg_valid_i ? cfg_req_fill_target_i : 32'd2;
+    req_burst_len_max = cfg_valid_i ? cfg_req_burst_len_max_i : 32'd0;
+    req_family = cfg_valid_i ? cfg_req_family_i : 32'd0;
+    req_address_mode = cfg_valid_i ? cfg_req_address_mode_i : 32'd0;
+    req_data_mode = cfg_valid_i ? cfg_req_data_mode_i : 32'd0;
+    req_data_hi_xor = cfg_valid_i ? cfg_req_data_hi_xor_i : 32'd0;
+    access_ack_data_pct = clamp_pct(cfg_valid_i ? cfg_access_ack_data_pct_i : 32'd50);
+    rsp_error_pct = clamp_pct(cfg_valid_i ? cfg_rsp_error_pct_i : 32'd10);
+    rsp_fill_target = cfg_valid_i ? cfg_rsp_fill_target_i : 32'd2;
+    rsp_delay_max = cfg_valid_i ? cfg_rsp_delay_max_i : 32'd4;
+    rsp_family = cfg_valid_i ? cfg_rsp_family_i : 32'd0;
+    rsp_delay_mode = cfg_valid_i ? cfg_rsp_delay_mode_i : 32'd0;
+    rsp_data_mode = cfg_valid_i ? cfg_rsp_data_mode_i : 32'd0;
+    rsp_data_hi_xor = cfg_valid_i ? cfg_rsp_data_hi_xor_i : 32'd0;
+    reset_cycles = cfg_valid_i ? cfg_reset_cycles_i : 32'd4;
+    drain_cycles = cfg_valid_i ? cfg_drain_cycles_i : 32'd24;
+    seed = cfg_valid_i ? cfg_seed_i : 32'd1;
+    address_base = cfg_valid_i ? cfg_address_base_i : 32'd0;
+    address_mask = cfg_valid_i ? cfg_address_mask_i : 32'h0000_0ffc;
+    source_mask = cfg_valid_i ? cfg_source_mask_i : {top_pkg::TL_AIW{1'b1}};
+  end
+
+  function automatic int unsigned clamp_pct(input int unsigned pct);
+    if (pct > 100) begin
+      return 100;
+    end
+    return pct;
+  endfunction
+
+  function automatic int unsigned prng_next(input int unsigned state);
+    return state * 32'd1664525 + 32'd1013904223;
+  endfunction
+
+  function automatic tl_a_op_e decode_req_opcode(input int unsigned rand_word);
+    rand_word = rand_word % 100;
+    if (rand_word < put_full_pct) begin
+      return PutFullData;
+    end
+    if (rand_word < (put_full_pct + put_partial_pct)) begin
+      return PutPartialData;
+    end
+    return Get;
+  endfunction
+
+  function automatic tl_d_op_e decode_rsp_opcode(input int unsigned rand_word);
+    return ((rand_word % 100) < access_ack_data_pct) ? AccessAckData : AccessAck;
+  endfunction
+
+  function automatic logic [top_pkg::TL_AW-1:0] choose_address(input int unsigned rand_word);
+    logic [top_pkg::TL_AW-1:0] next_address;
+    case (req_address_mode[1:0])
+      2'd1: next_address = address_base + ((host_cycles_q & 32'h0000_00ff) << 2);
+      2'd2: next_address = address_base + ((req_pending_source_q & 32'h0000_00ff) << 2);
+      default: next_address = (address_base & ~address_mask) | (rand_word & address_mask);
+    endcase
+    next_address[1:0] = 2'b00;
+    return next_address;
+  endfunction
+
+  function automatic logic [top_pkg::TL_DW-1:0] choose_req_data(
+      input int unsigned rand_word,
+      input logic [top_pkg::TL_AW-1:0] next_address
+  );
+    case (req_data_mode[1:0])
+      2'd1: return {next_address, next_address};
+      2'd2: return rand_word ^ req_data_hi_xor ^ host_cycles_q;
+      default: return rand_word ^ req_data_hi_xor;
+    endcase
+  endfunction
+
+  function automatic logic [top_pkg::TL_DW-1:0] choose_rsp_data(input int unsigned rand_word);
+    case (rsp_data_mode[1:0])
+      2'd1: return rand_word ^ rsp_data_hi_xor ^ device_cycles_q;
+      2'd2: return {rsp_pending_source_q, rand_word[top_pkg::TL_DW-top_pkg::TL_AIW-1:0]};
+      default: return rand_word ^ rsp_data_hi_xor;
+    endcase
+  endfunction
+
+  function automatic logic [31:0] pack_toggle_hits(
+      input logic [15:0] prev_word,
+      input logic [15:0] curr_word
+  );
+    return {
+      (prev_word[15] && !curr_word[15]),
+      ((!prev_word[15]) && curr_word[15]),
+      (prev_word[14] && !curr_word[14]),
+      ((!prev_word[14]) && curr_word[14]),
+      (prev_word[13] && !curr_word[13]),
+      ((!prev_word[13]) && curr_word[13]),
+      (prev_word[12] && !curr_word[12]),
+      ((!prev_word[12]) && curr_word[12]),
+      (prev_word[11] && !curr_word[11]),
+      ((!prev_word[11]) && curr_word[11]),
+      (prev_word[10] && !curr_word[10]),
+      ((!prev_word[10]) && curr_word[10]),
+      (prev_word[9] && !curr_word[9]),
+      ((!prev_word[9]) && curr_word[9]),
+      (prev_word[8] && !curr_word[8]),
+      ((!prev_word[8]) && curr_word[8]),
+      (prev_word[7] && !curr_word[7]),
+      ((!prev_word[7]) && curr_word[7]),
+      (prev_word[6] && !curr_word[6]),
+      ((!prev_word[6]) && curr_word[6]),
+      (prev_word[5] && !curr_word[5]),
+      ((!prev_word[5]) && curr_word[5]),
+      (prev_word[4] && !curr_word[4]),
+      ((!prev_word[4]) && curr_word[4]),
+      (prev_word[3] && !curr_word[3]),
+      ((!prev_word[3]) && curr_word[3]),
+      (prev_word[2] && !curr_word[2]),
+      ((!prev_word[2]) && curr_word[2]),
+      (prev_word[1] && !curr_word[1]),
+      ((!prev_word[1]) && curr_word[1]),
+      (prev_word[0] && !curr_word[0]),
+      ((!prev_word[0]) && curr_word[0])
+    };
+  endfunction
+
+  assign traffic_phase_w = (phase_q == TrafficPhase);
+  assign response_phase_w = (phase_q == TrafficPhase) || (phase_q == DrainPhase);
+  assign rst_ni = bootstrapped_q && (phase_q != ResetPhase);
+  assign drain_busy_w = req_pending_valid_q
+      || rsp_pending_valid_q
+      || (rsp_count_q != 0)
+      || tl_d_o.a_valid
+      || tl_h_o.d_valid;
+
+  function automatic bit baseline_done();
+    return bootstrapped_q && (phase_q == DonePhase);
+  endfunction
+
+  always_comb begin
+    tl_h_i = tlul_pkg::TL_H2D_DEFAULT;
+    tl_h_i.d_ready = host_d_ready_q;
+    tl_h_i.a_valid = req_pending_valid_q;
+    tl_h_i.a_opcode = req_pending_opcode_q;
+    tl_h_i.a_param = req_pending_param_q;
+    tl_h_i.a_size = req_pending_size_q;
+    tl_h_i.a_source = req_pending_source_q;
+    tl_h_i.a_address = req_pending_address_q;
+    tl_h_i.a_mask = req_pending_mask_q;
+    tl_h_i.a_data = req_pending_data_q;
+    tl_h_i.a_user = req_pending_user_q;
