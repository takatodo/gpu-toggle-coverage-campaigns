diff --git a/designs/BlackParrot/src/bp/blackparrot_gpu_cov_tb.sv b/designs/BlackParrot/src/bp/blackparrot_gpu_cov_tb.sv
new file mode 100644
index 0000000..ac8bad8
--- /dev/null
+++ b/designs/BlackParrot/src/bp/blackparrot_gpu_cov_tb.sv
@@ -0,0 +1,404 @@
+// SPDX-License-Identifier: Apache-2.0
+//
+// Coarse gpu_cov wrapper for BlackParrot.
+// Reuses the stock testbench and exports shallow progress/memory/DRAM/finish
+// proxies through the fixed output contract expected by the GPU toggle flow.
+
+module blackparrot_gpu_cov_tb
+ import bp_common_pkg::*;
+ #(parameter bp_params_e bp_params_p = `BP_CFG_FLOWVAR
+   , parameter tb_clock_period_p           = 0
+   , parameter tb_reset_cycles_lo_p        = 0
+   , parameter tb_reset_cycles_hi_p        = 0
+   , parameter sim_clock_period_p          = 0
+   , parameter sim_reset_cycles_lo_p       = 0
+   , parameter sim_reset_cycles_hi_p       = 0
+   , parameter watchdog_enable_p           = 0
+   , parameter stall_cycles_p              = 0
+   , parameter halt_instr_p                = 0
+   , parameter heartbeat_instr_p           = 0
+   , parameter cosim_trace_p               = 0
+   , parameter cosim_check_p               = 0
+   , parameter perf_enable_p               = 0
+   , parameter warmup_instr_p              = 0
+   , parameter max_instr_p                 = 0
+   , parameter max_cycle_p                 = 0
+   , parameter icache_trace_p              = 0
+   , parameter dcache_trace_p              = 0
+   , parameter vm_trace_p                  = 0
+   , parameter uce_trace_p                 = 0
+   , parameter lce_trace_p                 = 0
+   , parameter cce_trace_p                 = 0
+   , parameter dev_trace_p                 = 0
+   , parameter dram_trace_p                = 0
+   )
+(
+  input  logic        cfg_valid_i,
+  input  logic [31:0] cfg_batch_length_i,
+  input  logic [31:0] cfg_req_valid_pct_i,
+  input  logic [31:0] cfg_rsp_valid_pct_i,
+  input  logic [31:0] cfg_host_d_ready_pct_i,
+  input  logic [31:0] cfg_device_a_ready_pct_i,
+  input  logic [31:0] cfg_put_full_pct_i,
+  input  logic [31:0] cfg_put_partial_pct_i,
+  input  logic [31:0] cfg_req_fill_target_i,
+  input  logic [31:0] cfg_req_burst_len_max_i,
+  input  logic [31:0] cfg_req_family_i,
+  input  logic [31:0] cfg_req_address_mode_i,
+  input  logic [31:0] cfg_req_data_mode_i,
+  input  logic [31:0] cfg_req_data_hi_xor_i,
+  input  logic [31:0] cfg_access_ack_data_pct_i,
+  input  logic [31:0] cfg_rsp_error_pct_i,
+  input  logic [31:0] cfg_rsp_fill_target_i,
+  input  logic [31:0] cfg_rsp_delay_max_i,
+  input  logic [31:0] cfg_rsp_family_i,
+  input  logic [31:0] cfg_rsp_delay_mode_i,
+  input  logic [31:0] cfg_rsp_data_mode_i,
+  input  logic [31:0] cfg_rsp_data_hi_xor_i,
+  input  logic [31:0] cfg_reset_cycles_i,
+  input  logic [31:0] cfg_drain_cycles_i,
+  input  logic [31:0] cfg_seed_i,
+  input  logic [31:0] cfg_address_base_i,
+  input  logic [31:0] cfg_address_mask_i,
+  input  logic [31:0] cfg_source_mask_i,
+  output logic [31:0] cfg_signature_o,
+  output logic        done_o,
+  output logic [31:0] host_req_accepted_o,
+  output logic [31:0] device_req_accepted_o,
+  output logic [31:0] device_rsp_accepted_o,
+  output logic [31:0] host_rsp_accepted_o,
+  output logic [31:0] rsp_queue_overflow_o,
+  output logic [31:0] progress_cycle_count_o,
+  output logic [31:0] progress_signature_o,
+  output logic [31:0] toggle_bitmap_word0_o,
+  output logic [31:0] toggle_bitmap_word1_o,
+  output logic [31:0] toggle_bitmap_word2_o,
+  output logic [31:0] real_toggle_subset_word0_o,
+  output logic [31:0] real_toggle_subset_word1_o,
+  output logic [31:0] real_toggle_subset_word2_o,
+  output logic [31:0] real_toggle_subset_word3_o,
+  output logic [31:0] real_toggle_subset_word4_o,
+  output logic [31:0] real_toggle_subset_word5_o,
+  output logic [31:0] real_toggle_subset_word6_o,
+  output logic [31:0] real_toggle_subset_word7_o,
+  output logic [31:0] real_toggle_subset_word8_o,
+  output logic [31:0] real_toggle_subset_word9_o,
+  output logic [31:0] real_toggle_subset_word10_o,
+  output logic [31:0] real_toggle_subset_word11_o,
+  output logic [31:0] real_toggle_subset_word12_o,
+  output logic [31:0] real_toggle_subset_word13_o,
+  output logic [31:0] real_toggle_subset_word14_o,
+  output logic [31:0] real_toggle_subset_word15_o,
+  output logic [31:0] real_toggle_subset_word16_o,
+  output logic [31:0] real_toggle_subset_word17_o,
+  output logic [31:0] focused_wave_word0_o,
+  output logic [31:0] focused_wave_word1_o,
+  output logic [31:0] focused_wave_word2_o,
+  output logic [31:0] focused_wave_word3_o,
+  output logic [31:0] focused_wave_word4_o,
+  output logic [31:0] focused_wave_word5_o,
+  output logic [31:0] focused_wave_word6_o,
+  output logic [31:0] focused_wave_word7_o
+);
+
+  localparam int GPU_COV_PROGRAM_WORD_MAX = 32768;
+
+  testbench
+   #(.bp_params_p(bp_params_p)
+     ,.tb_clock_period_p(tb_clock_period_p)
+     ,.tb_reset_cycles_lo_p(tb_reset_cycles_lo_p)
+     ,.tb_reset_cycles_hi_p(tb_reset_cycles_hi_p)
+     ,.sim_clock_period_p(sim_clock_period_p)
+     ,.sim_reset_cycles_lo_p(sim_reset_cycles_lo_p)
+     ,.sim_reset_cycles_hi_p(sim_reset_cycles_hi_p)
+     ,.watchdog_enable_p(watchdog_enable_p)
+     ,.stall_cycles_p(stall_cycles_p)
+     ,.halt_instr_p(halt_instr_p)
+     ,.heartbeat_instr_p(heartbeat_instr_p)
+     ,.cosim_trace_p(cosim_trace_p)
+     ,.cosim_check_p(cosim_check_p)
+     ,.perf_enable_p(perf_enable_p)
+     ,.warmup_instr_p(warmup_instr_p)
+     ,.max_instr_p(max_instr_p)
+     ,.max_cycle_p(max_cycle_p)
+     ,.icache_trace_p(icache_trace_p)
+     ,.dcache_trace_p(dcache_trace_p)
+     ,.vm_trace_p(vm_trace_p)
+     ,.uce_trace_p(uce_trace_p)
+     ,.lce_trace_p(lce_trace_p)
+     ,.cce_trace_p(cce_trace_p)
+     ,.dev_trace_p(dev_trace_p)
+     ,.dram_trace_p(dram_trace_p)
+     )
+   dut();
+
+  logic [63:0] gpu_cov_program_words [0:GPU_COV_PROGRAM_WORD_MAX-1] /*verilator public_flat_rw*/;
+
+  logic mem_fwd_host_accept_w;
+  logic mem_rev_host_accept_w;
+  logic mem_fwd_loader_accept_w;
+  logic mem_rev_loader_accept_w;
+  logic dma_pkt_accept_w;
+  logic dma_data_in_accept_w;
+  logic dma_data_out_accept_w;
+  logic finish_write_w;
+  logic pass_write_w;
+  logic fail_write_w;
+  logic host_output_w;
+  logic [31:0] cfg_signature_q;
+  logic [17:0] seen_bits_w;
+  logic cycle_seen_q;
+  logic loader_done_seen_q;
+  logic long_run_seen_q;
+  logic pass_seen_q;
+  logic mem_fwd_host_seen_q;
+  logic mem_rev_host_seen_q;
+  logic mem_fwd_loader_seen_q;
+  logic mem_rev_loader_seen_q;
+  logic memory_threshold_seen_q;
+  logic dma_pkt_seen_q;
+  logic dma_data_in_seen_q;
+  logic dma_data_out_seen_q;
+  logic dram_threshold_seen_q;
+  logic host_output_seen_q;
+  logic fail_seen_q;
+  logic cfg_valid_seen_q;
+  logic reset_release_seen_q;
+  logic finish_seen_q;
+  logic [31:0] cycle_count_q;
+  logic [31:0] mem_req_count_q;
+  logic [31:0] mem_rsp_count_q;
+  logic [31:0] dma_count_q;
+  logic [31:0] host_output_count_q;
+  logic [31:0] finish_count_q;
+  logic [31:0] progress_signature_q;
+  logic        gpu_cov_preload_applied_q;
+
+  task automatic gpu_cov_apply_program_words;
+    int unsigned word_count;
+    int unsigned word_index;
+    int unsigned byte_index;
+    int unsigned base_addr;
+    logic [63:0] word_data;
+    begin
+      word_count = gpu_cov_program_words[0][31:0];
+      if (word_count > GPU_COV_PROGRAM_WORD_MAX-1) begin
+        $display("BlackParrot gpu_cov preload overflow: %0d > %0d", word_count, GPU_COV_PROGRAM_WORD_MAX-1);
+        $finish;
+      end
+      for (word_index = 0; word_index < word_count; word_index++) begin
+        word_data = gpu_cov_program_words[word_index + 1];
+        base_addr = word_index * 8;
+        for (byte_index = 0; byte_index < 8; byte_index++) begin
+          dut.dram.mem[base_addr + byte_index] = word_data[8*byte_index +: 8];
+        end
+      end
+    end
+  endtask
+
+  always_comb begin
+    mem_fwd_host_accept_w   = dut.mem_fwd_v_lo && dut.mem_fwd_ready_and_li;
+    mem_rev_host_accept_w   = dut.mem_rev_v_li && dut.mem_rev_ready_and_lo;
+    mem_fwd_loader_accept_w = dut.mem_fwd_v_li && dut.mem_fwd_ready_and_lo;
+    mem_rev_loader_accept_w = dut.mem_rev_v_lo && dut.mem_rev_ready_and_li;
+    dma_pkt_accept_w        = |(dut.dma_pkt_v_lo & dut.dma_pkt_yumi_li);
+    dma_data_in_accept_w    = |(dut.dma_data_v_li & dut.dma_data_ready_and_lo);
+    dma_data_out_accept_w   = |(dut.dma_data_v_lo & dut.dma_data_yumi_li);
+    finish_write_w          = dut.host.finish_w_v_li;
+    pass_write_w            = dut.host.finish_w_v_li && ~|dut.host.data_lo[7:0];
+    fail_write_w            = dut.host.finish_w_v_li &&  |dut.host.data_lo[7:0];
+    host_output_w           = dut.host.putchar_w_v_li
+                           || dut.host.putch_core_w_v_li
+                           || dut.host.signature_w_v_li
+                           || dut.host.putint_w_v_li;
+    cfg_signature_q         = cfg_batch_length_i
+                            ^ cfg_seed_i
+                            ^ cfg_reset_cycles_i
+                            ^ cfg_drain_cycles_i
+                            ^ cfg_req_family_i
+                            ^ cfg_rsp_family_i
+                            ^ cfg_address_base_i
+                            ^ cfg_address_mask_i
+                            ^ cfg_source_mask_i
+                            ^ {31'd0, cfg_valid_i};
+  end
+
+  always_ff @(posedge dut.dut_clk or posedge dut.dut_reset) begin
+    if (dut.dut_reset) begin
+      if (gpu_cov_program_words[0][31:0] != 0) begin
+        if (!gpu_cov_preload_applied_q) begin
+          gpu_cov_apply_program_words();
+        end
+        gpu_cov_preload_applied_q <= 1'b1;
+      end else begin
+        gpu_cov_preload_applied_q <= 1'b0;
+      end
+      cycle_seen_q           <= 1'b0;
+      loader_done_seen_q     <= 1'b0;
+      long_run_seen_q        <= 1'b0;
+      pass_seen_q            <= 1'b0;
+      mem_fwd_host_seen_q    <= 1'b0;
+      mem_rev_host_seen_q    <= 1'b0;
+      mem_fwd_loader_seen_q  <= 1'b0;
+      mem_rev_loader_seen_q  <= 1'b0;
+      memory_threshold_seen_q <= 1'b0;
+      dma_pkt_seen_q         <= 1'b0;
+      dma_data_in_seen_q     <= 1'b0;
+      dma_data_out_seen_q    <= 1'b0;
+      dram_threshold_seen_q  <= 1'b0;
+      host_output_seen_q     <= 1'b0;
+      fail_seen_q            <= 1'b0;
+      cfg_valid_seen_q       <= 1'b0;
+      reset_release_seen_q   <= 1'b0;
+      finish_seen_q          <= 1'b0;
+      cycle_count_q          <= '0;
+      mem_req_count_q        <= '0;
+      mem_rsp_count_q        <= '0;
+      dma_count_q            <= '0;
+      host_output_count_q    <= '0;
+      finish_count_q         <= '0;
+    end else begin
+      cycle_seen_q         <= 1'b1;
+      reset_release_seen_q <= 1'b1;
+      cycle_count_q        <= cycle_count_q + 32'd1;
+
+      if (dut.loader_done_lo) begin
+        loader_done_seen_q <= 1'b1;
+      end
+      if (cycle_count_q >= 32'd4096) begin
+        long_run_seen_q <= 1'b1;
+      end
+      if (cfg_valid_i) begin
+        cfg_valid_seen_q <= 1'b1;
+      end
+
+      if (mem_fwd_host_accept_w) begin
+        mem_fwd_host_seen_q <= 1'b1;
+        mem_req_count_q <= mem_req_count_q + 32'd1;
+      end
+      if (mem_fwd_loader_accept_w) begin
+        mem_fwd_loader_seen_q <= 1'b1;
+        mem_req_count_q <= mem_req_count_q + 32'd1;
+      end
+      if (mem_rev_host_accept_w) begin
+        mem_rev_host_seen_q <= 1'b1;
+        mem_rsp_count_q <= mem_rsp_count_q + 32'd1;
+      end
+      if (mem_rev_loader_accept_w) begin
+        mem_rev_loader_seen_q <= 1'b1;
+        mem_rsp_count_q <= mem_rsp_count_q + 32'd1;
+      end
+      if ((mem_req_count_q + mem_rsp_count_q) >= 32'd16) begin
+        memory_threshold_seen_q <= 1'b1;
+      end
+
+      if (dma_pkt_accept_w) begin
+        dma_pkt_seen_q <= 1'b1;
+        dma_count_q <= dma_count_q + 32'd1;
+      end
+      if (dma_data_in_accept_w) begin
+        dma_data_in_seen_q <= 1'b1;
+        dma_count_q <= dma_count_q + 32'd1;
+      end
+      if (dma_data_out_accept_w) begin
+        dma_data_out_seen_q <= 1'b1;
+        dma_count_q <= dma_count_q + 32'd1;
+      end
+      if (dma_count_q >= 32'd8) begin
+        dram_threshold_seen_q <= 1'b1;
+      end
+
+      if (host_output_w) begin
+        host_output_seen_q <= 1'b1;
+        host_output_count_q <= host_output_count_q + 32'd1;
+      end
+      if (finish_write_w) begin
+        finish_seen_q <= 1'b1;
+        finish_count_q <= finish_count_q + 32'd1;
+      end
+      if (pass_write_w) begin
+        pass_seen_q <= 1'b1;
+      end
+      if (fail_write_w) begin
+        fail_seen_q <= 1'b1;
+      end
+    end
+  end
+
+  always_comb begin
+    seen_bits_w = {
+      finish_seen_q,
+      reset_release_seen_q,
+      cfg_valid_seen_q,
+      fail_seen_q,
+      host_output_seen_q,
+      dram_threshold_seen_q,
+      dma_data_out_seen_q,
+      dma_data_in_seen_q,
+      dma_pkt_seen_q,
+      memory_threshold_seen_q,
+      mem_rev_loader_seen_q,
+      mem_fwd_loader_seen_q,
+      mem_rev_host_seen_q,
+      mem_fwd_host_seen_q,
+      pass_seen_q,
+      long_run_seen_q,
+      loader_done_seen_q,
+      cycle_seen_q
+    };
+  end
+
+  always_comb begin
+    progress_signature_q = cfg_signature_q
+                         ^ cycle_count_q
+                         ^ mem_req_count_q
+                         ^ mem_rsp_count_q
+                         ^ dma_count_q
+                         ^ host_output_count_q
+                         ^ finish_count_q
+                         ^ {14'd0, seen_bits_w};
+  end
+
+  assign cfg_signature_o        = cfg_signature_q;
+  assign done_o                 = pass_seen_q | fail_seen_q;
+  assign host_req_accepted_o    = mem_req_count_q;
+  assign device_req_accepted_o  = dma_count_q;
+  assign device_rsp_accepted_o  = mem_rsp_count_q;
