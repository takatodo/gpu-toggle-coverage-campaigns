diff --git a/designs/XuanTie-C906/src/xuantie_axi_gpu_cov_if.sv b/designs/XuanTie-C906/src/xuantie_axi_gpu_cov_if.sv
new file mode 100644
index 0000000..a9b6077
--- /dev/null
+++ b/designs/XuanTie-C906/src/xuantie_axi_gpu_cov_if.sv
@@ -0,0 +1,89 @@
+// SPDX-License-Identifier: Apache-2.0
+//
+// AXI-oriented observability interface for XuanTie gpu_cov wrappers.
+// The wrapper drives raw DUT-side request/response/writeback/config signals
+// into this interface, and the interface derives the coarse event wires that
+// become the real_toggle_subset coverage words.
+
+interface xuantie_axi_gpu_cov_if;
+  localparam logic [31:0] UART_ADDR = 32'h9000_0000;
+  localparam logic [63:0] PASS_SENTINEL = 64'h0000_0004_4433_3222;
+  localparam logic [63:0] FAIL_SENTINEL = 64'd2382348720;
+
+  logic         retire_event;
+  logic [39:0]  araddr;
+  logic [7:0]   arlen;
+  logic         arvalid;
+  logic         arready;
+  logic [39:0]  awaddr;
+  logic [7:0]   awlen;
+  logic         awvalid;
+  logic         awready;
+  logic [15:0]  wstrb;
+  logic         wvalid;
+  logic         wready;
+  logic [127:0] wdata;
+  logic         rvalid;
+  logic         rready;
+  logic         bvalid;
+  logic         bready;
+  logic         axim_clk_en;
+  logic [63:0]  value0;
+  logic [63:0]  value1;
+  logic [63:0]  value2;
+  logic         cfg_valid;
+  logic [31:0]  cfg_signature;
+  logic [31:0]  cycle_count;
+  logic [31:0]  retire_count;
+  logic [31:0]  uart_char_count;
+
+  logic aw_handshake_event;
+  logic w_handshake_event;
+  logic b_handshake_event;
+  logic ar_handshake_event;
+  logic r_handshake_event;
+  logic r_response_event;
+  logic b_response_event;
+  logic awaddr_high_event;
+  logic araddr_high_event;
+  logic zero_len_write_event;
+  logic zero_len_read_event;
+  logic uart_char_event;
+  logic pass_hit_event;
+  logic fail_hit_event;
+  logic low_lane_event;
+  logic upper_lane_event;
+  logic value0_active_event;
+  logic value1_active_event;
+  logic awaddr_offset_event;
+  logic retire_16_event;
+  logic uart_burst_event;
+  logic long_run_event;
+  logic cfg_valid_event;
+  logic cfg_signature_event;
+
+  assign aw_handshake_event   = awvalid && awready;
+  assign w_handshake_event    = wvalid && wready;
+  assign b_handshake_event    = bvalid && bready;
+  assign ar_handshake_event   = arvalid && arready;
+  assign r_handshake_event    = rvalid && rready;
+  assign r_response_event     = rvalid;
+  assign b_response_event     = bvalid;
+  assign awaddr_high_event    = |awaddr[31:16];
+  assign araddr_high_event    = |araddr[31:16];
+  assign zero_len_write_event = aw_handshake_event && (awlen == 8'd0);
+  assign zero_len_read_event  = ar_handshake_event && (arlen == 8'd0);
+  assign uart_char_event      = w_handshake_event && (awaddr[31:0] == UART_ADDR) && axim_clk_en;
+  assign pass_hit_event       = (value0 == PASS_SENTINEL) || (value1 == PASS_SENTINEL) || (value2 == PASS_SENTINEL);
+  assign fail_hit_event       = (value0 == FAIL_SENTINEL) || (value1 == FAIL_SENTINEL) || (value2 == FAIL_SENTINEL);
+  assign low_lane_event       = w_handshake_event && |wstrb[3:0];
+  assign upper_lane_event     = w_handshake_event && |wstrb[15:4];
+  assign value0_active_event  = |value0;
+  assign value1_active_event  = |value1 || |value2;
+  assign awaddr_offset_event  = aw_handshake_event && |awaddr[7:0];
+  assign retire_16_event      = (retire_count >= 32'd15);
+  assign uart_burst_event     = (uart_char_count >= 32'd3);
+  assign long_run_event       = (cycle_count >= 32'd1000);
+  assign cfg_valid_event      = cfg_valid;
+  assign cfg_signature_event  = (cfg_signature != 32'd0);
+endinterface
diff --git a/designs/XuanTie-C906/src/xuantie_c906_gpu_cov_tb.sv b/designs/XuanTie-C906/src/xuantie_c906_gpu_cov_tb.sv
