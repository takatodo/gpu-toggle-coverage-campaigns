+  output logic [31:0] trace_metric_a_address_window_or_o,
+  output logic [31:0] trace_metric_device_d_data_low_or_o,
+  output logic [31:0] trace_metric_device_d_data_upper_or_o,
+  output logic [31:0] trace_metric_d_data_low_or_o,
+  output logic [31:0] trace_metric_d_data_upper_or_o,
+  output logic [31:0] toggle_bitmap_word0_o,
+  output logic [31:0] toggle_bitmap_word1_o,
+  output logic [31:0] toggle_bitmap_word2_o,
+  output logic [31:0] real_toggle_subset_word0_o,
+  output logic [31:0] real_toggle_subset_word1_o,
+  output logic [31:0] real_toggle_subset_word2_o,
+  output logic [31:0] real_toggle_subset_word3_o,
+  output logic [31:0] real_toggle_subset_word4_o,
+  output logic [31:0] real_toggle_subset_word5_o,
+  output logic [31:0] real_toggle_subset_word6_o,
+  output logic [31:0] real_toggle_subset_word7_o,
+  output logic [31:0] real_toggle_subset_word8_o,
+  output logic [31:0] real_toggle_subset_word9_o,
+  output logic [31:0] real_toggle_subset_word10_o,
+  output logic [31:0] real_toggle_subset_word11_o,
+  output logic [31:0] real_toggle_subset_word12_o,
+  output logic [31:0] real_toggle_subset_word13_o,
+  output logic [31:0] real_toggle_subset_word14_o,
+  output logic [31:0] real_toggle_subset_word15_o,
+  output logic [31:0] real_toggle_subset_word16_o,
+  output logic [31:0] real_toggle_subset_word17_o,
+  output logic [31:0] focused_wave_word0_o,
+  output logic [31:0] focused_wave_word1_o,
+  output logic [31:0] focused_wave_word2_o,
+  output logic [31:0] focused_wave_word3_o,
+  output logic [31:0] focused_wave_word4_o,
+  output logic [31:0] focused_wave_word5_o,
+  output logic [31:0] focused_wave_word6_o,
+  output logic [31:0] focused_wave_word7_o,
+  output logic [31:0] focused_metric_word0_o,
+  output logic [31:0] focused_metric_word1_o,
+  output logic [31:0] focused_metric_word2_o,
+  output logic [31:0] focused_metric_word3_o,
+  output logic [31:0] focused_metric_word4_o
+);
+  localparam int MEM_STAGES = 20;
+
+  logic                             clk = 1'b0;
+  logic                             reset = 1'b1;
+
+  logic                             mem_req_valid;
+  logic                             mem_req_rw;
+  logic [`VX_MEM_BYTEEN_WIDTH-1:0]  mem_req_byteen;
+  logic [`VX_MEM_ADDR_WIDTH-1:0]    mem_req_addr;
+  logic [`VX_MEM_DATA_WIDTH-1:0]    mem_req_data;
+  logic [`VX_MEM_TAG_WIDTH-1:0]     mem_req_tag;
+  logic                             mem_req_ready = 1'b0;
+
+  logic                             mem_rsp_valid = 1'b0;
+  logic [`VX_MEM_DATA_WIDTH-1:0]    mem_rsp_data;
+  logic [`VX_MEM_TAG_WIDTH-1:0]     mem_rsp_tag;
+  logic                             mem_rsp_ready;
+
+  logic                             dcr_wr_valid = 1'b0;
+  logic [`VX_DCR_ADDR_WIDTH-1:0]    dcr_wr_addr;
+  logic [`VX_DCR_DATA_WIDTH-1:0]    dcr_wr_data;
+
+  logic                             busy;
+  logic                             done_q;
+  logic                             seen_busy_high_q;
+  logic [17:0]                      seen_bits_q;
+  logic [31:0]                      dcr_write_count_q;
+  logic [31:0]                      mem_req_handshake_count_q;
+  logic [31:0]                      mem_rsp_handshake_count_q;
+  logic [31:0]                      completed_iterations_q;
+  logic [31:0]                      rsp_queue_overflow_q;
+  logic [31:0]                      cycle_count_q;
+  logic [31:0]                      max_reqfifo_depth_q;
+  logic [31:0]                      max_rspfifo_depth_q;
+  logic [31:0]                      req_data_mid_or_q;
+  logic [31:0]                      req_addr_window_or_q;
+  logic [31:0]                      rsp_data_low_or_q;
+  logic [31:0]                      rsp_data_upper_or_q;
+  logic [MEM_STAGES-1:0]            mem_rsp_valid_vec;
+  logic [31:0]                      progress_signature_w;
+
+  Vortex dut (
+    .clk            (clk           ),
+    .reset          (reset         ),
+    .mem_req_valid  (mem_req_valid ),
+    .mem_req_rw     (mem_req_rw    ),
+    .mem_req_byteen (mem_req_byteen),
+    .mem_req_addr   (mem_req_addr  ),
+    .mem_req_data   (mem_req_data  ),
+    .mem_req_tag    (mem_req_tag   ),
+    .mem_req_ready  (mem_req_ready ),
+    .mem_rsp_valid  (mem_rsp_valid ),
+    .mem_rsp_data   (mem_rsp_data  ),
+    .mem_rsp_tag    (mem_rsp_tag   ),
+    .mem_rsp_ready  (mem_rsp_ready ),
+    .dcr_wr_valid   (dcr_wr_valid  ),
+    .dcr_wr_addr    (dcr_wr_addr   ),
+    .dcr_wr_data    (dcr_wr_data   ),
+    .busy           (busy          )
+  );
+
+  always #5 clk = ~clk;
+
+  import "DPI-C" function void mem_load(input string fileName);
+  import "DPI-C" function bit mem_check(input string fileName, input bit verbose);
+  import "DPI-C" function void mem_access(
+    input  bit                          req_rw,
+    input  longint unsigned             req_byteen,
+    input  longint unsigned             req_addr,
+    input  bit [`VX_MEM_DATA_WIDTH-1:0] req_data,
+    output bit [`VX_MEM_DATA_WIDTH-1:0] rsp_data
+  );
+
+  function automatic [31:0] cfg_or_default(input logic [31:0] raw_value, input logic [31:0] default_value);
+    if (cfg_valid_i && (raw_value != 32'd0)) begin
+      return raw_value;
+    end
+    return default_value;
+  endfunction
+
+  function automatic [31:0] cfg_with_floor(
+    input logic [31:0] raw_value,
+    input logic [31:0] default_value,
+    input logic [31:0] floor_value
+  );
+    logic [31:0] selected;
+    begin
+      selected = cfg_or_default(raw_value, default_value);
+      if (selected < floor_value) begin
+        return floor_value;
+      end
+      return selected;
+    end
+  endfunction
+
+  function automatic [31:0] count_valid_stages(input logic [MEM_STAGES-1:0] values);
+    integer idx;
+    begin
+      count_valid_stages = 32'd0;
+      for (idx = 0; idx < MEM_STAGES; idx++) begin
+        count_valid_stages = count_valid_stages + {31'd0, values[idx]};
+      end
+    end
+  endfunction
+
+  task automatic drive_dcr_sequence;
+    int fd;
+    begin
+      fd = $fopen("dcrs.bin", "r");
+      if (fd == 0) begin
+        $display("Error: failed to open dcrs.bin");
+        $finish;
+      end
+      while (1'b1) begin
+        int code;
+        int unsigned addr;
+        int unsigned data;
+        code = $fread(addr, fd);
+        if (code == 0) break;
+        if (code != 4) begin
+          $display("Error: reading DCR address");
+          $finish;
+        end
+        code = $fread(data, fd);
+        if (code != 4) begin
+          $display("Error: reading DCR data");
+          $finish;
+        end
+        dcr_wr_valid = 1'b1;
+        dcr_wr_addr = `VX_DCR_ADDR_WIDTH'(addr);
+        dcr_wr_data = `VX_DCR_DATA_WIDTH'(data);
+        @(posedge clk);
+        dcr_wr_valid = 1'b0;
+        @(posedge clk);
+      end
+      $fclose(fd);
+    end
+  endtask
+
+  initial begin
+    int errors;
+    int unsigned iterations;
+    int unsigned iter;
+    int unsigned reset_cycles;
+    int unsigned drain_cycles;
+
+    errors = 0;
+    iterations = 1;
+    if ($value$plusargs("iterations=%d", iterations)) begin
+      $display("Iterations: %0d", iterations);
+    end
+    reset_cycles = cfg_with_floor(cfg_reset_cycles_i, 10, 10);
+    drain_cycles = cfg_or_default(cfg_drain_cycles_i, 24);
+
+    dcr_wr_valid = 1'b0;
+    dcr_wr_addr = '0;
+    dcr_wr_data = '0;
+
+    for (iter = 0; iter < iterations; ++iter) begin
+      reset = 1'b1;
+      repeat (reset_cycles) @(posedge clk);
+
+      mem_load("init.bin");
+      if (mem_check("post.bin", 1'b0)) begin
+        $display("Error: Initial state of memory matches expected state");
+        $finish;
+      end
+
+      drive_dcr_sequence();
+
+      @(posedge clk);
+      reset = 1'b0;
+      seen_bits_q[0] = 1'b1;
+
+      while (!busy) begin
+        @(posedge clk);
+      end
+
+      while (busy) begin
+        @(posedge clk);
+      end
+
+      repeat (drain_cycles) @(posedge clk);
+      done_q = 1'b1;
+
+      if (!mem_check("post.bin", 1'b1)) begin
+        $display("Error: Final state of memory is incorrect");
+        ++errors;
+      end
+    end
+
+    if (errors == 0) begin
+      seen_bits_q[17] = 1'b1;
+      $display("TEST PASSED");
+    end else begin
+      $display("TEST FAILED");
+    end
+    $finish;
+  end
+
+  for (genvar i = 0; i < MEM_STAGES; ++i) begin : mem_rsp
+    logic                             valid_q;
+    logic [`VX_MEM_DATA_WIDTH-1:0]    data_q;
+    logic [`VX_MEM_TAG_WIDTH-1:0]     tag_q;
+    logic                             valid_d;
+    logic [`VX_MEM_DATA_WIDTH-1:0]    data_d;
+    logic [`VX_MEM_TAG_WIDTH-1:0]     tag_d;
+    logic                             ready;
+    logic                             move;
+
+    always @(posedge clk) begin
+      if (reset) begin
+        valid_q <= 1'b0;
+        data_q <= `VX_MEM_DATA_WIDTH'(0);
+        tag_q <= `VX_MEM_TAG_WIDTH'(0);
+      end else if (move) begin
+        valid_q <= valid_d;
+        data_q <= data_d;
+        tag_q <= tag_d;
+      end
+    end
+
+    assign mem_rsp_valid_vec[i] = valid_q;
+  end
+
+  assign mem_rsp[0].tag_d = mem_req_tag;
+
+  always @(negedge clk) begin
+    mem_req_ready <= 1'b0;
+    mem_rsp[0].valid_d <= 1'b0;
+    if (mem_req_valid && mem_rsp[0].ready) begin
+      mem_req_ready <= 1'b1;
+      if (!mem_req_rw) begin
+        mem_rsp[0].valid_d <= 1'b1;
+      end
+      mem_access(mem_req_rw, 64'(mem_req_byteen), 64'(mem_req_addr), mem_req_data, mem_rsp[0].data_d);
+    end
+  end
+
+  for (genvar i = 1; i < MEM_STAGES; ++i) begin : mem_connect
+    assign mem_rsp[i].valid_d = mem_rsp[i-1].valid_q;
+    assign mem_rsp[i].data_d = mem_rsp[i-1].data_q;
+    assign mem_rsp[i].tag_d = mem_rsp[i-1].tag_q;
+    assign mem_rsp[i-1].ready = ~mem_rsp[i-1].valid_q | mem_rsp[i].ready;
+    assign mem_rsp[i-1].move = (mem_rsp[i-1].valid_q & mem_rsp[i].ready) | ~mem_rsp[i-1].valid_q;
+  end
+
+  assign mem_rsp_valid = mem_rsp[MEM_STAGES-1].valid_q;
+  assign mem_rsp_data = mem_rsp[MEM_STAGES-1].data_q;
+  assign mem_rsp_tag = mem_rsp[MEM_STAGES-1].tag_q;
+  assign mem_rsp[MEM_STAGES-1].ready = ~mem_rsp[MEM_STAGES-1].valid_q | mem_rsp_ready;
+  assign mem_rsp[MEM_STAGES-1].move =
+      (mem_rsp[MEM_STAGES-1].valid_q & mem_rsp_ready) | ~mem_rsp[MEM_STAGES-1].valid_q;
+
+  always @(posedge clk) begin
+    logic [31:0] occupancy_now;
+    if (reset) begin
+      done_q <= 1'b0;
+      seen_busy_high_q <= 1'b0;
+      seen_bits_q <= '0;
+      dcr_write_count_q <= '0;
+      mem_req_handshake_count_q <= '0;
+      mem_rsp_handshake_count_q <= '0;
+      completed_iterations_q <= '0;
+      rsp_queue_overflow_q <= '0;
+      cycle_count_q <= '0;
+      max_reqfifo_depth_q <= '0;
+      max_rspfifo_depth_q <= '0;
+      req_data_mid_or_q <= '0;
+      req_addr_window_or_q <= '0;
+      rsp_data_low_or_q <= '0;
+      rsp_data_upper_or_q <= '0;
+    end else begin
+      cycle_count_q <= cycle_count_q + 32'd1;
+      occupancy_now = count_valid_stages(mem_rsp_valid_vec);
+      if (occupancy_now > max_reqfifo_depth_q) begin
+        max_reqfifo_depth_q <= occupancy_now;
+        max_rspfifo_depth_q <= occupancy_now;
+      end
+      if (dcr_wr_valid) begin
+        dcr_write_count_q <= dcr_write_count_q + 32'd1;
+        seen_bits_q[1] <= 1'b1;
+      end
+      if (busy) begin
+        seen_busy_high_q <= 1'b1;
+        seen_bits_q[2] <= 1'b1;
+      end
+      if (seen_busy_high_q && !busy) begin
+        seen_bits_q[3] <= 1'b1;
+      end
+      if (mem_req_valid) begin
+        seen_bits_q[4] <= 1'b1;
+      end
+      if (mem_req_valid && mem_req_ready) begin
+        mem_req_handshake_count_q <= mem_req_handshake_count_q + 32'd1;
+        seen_bits_q[5] <= 1'b1;
+      end else if (mem_req_valid && !mem_req_ready) begin
+        seen_bits_q[6] <= 1'b1;
+      end
+      if (mem_req_rw) begin
+        seen_bits_q[7] <= 1'b1;
+      end
+      if (|mem_req_data[31:16]) begin
+        req_data_mid_or_q <= req_data_mid_or_q | mem_req_data[31:0];
+        seen_bits_q[8] <= 1'b1;
+      end
+      if (|(mem_req_addr & `VX_MEM_ADDR_WIDTH'(cfg_or_default(cfg_address_mask_i, 32'h0000_0ffc)))) begin
+        req_addr_window_or_q <= req_addr_window_or_q | mem_req_addr[31:0];
+        seen_bits_q[9] <= 1'b1;
+      end
+      if (occupancy_now != 32'd0) begin
+        seen_bits_q[10] <= 1'b1;
+      end
+      if (mem_rsp_valid) begin
+        seen_bits_q[11] <= 1'b1;
+      end
+      if (mem_rsp_valid && mem_rsp_ready) begin
+        mem_rsp_handshake_count_q <= mem_rsp_handshake_count_q + 32'd1;
+        rsp_data_low_or_q <= rsp_data_low_or_q | mem_rsp_data[31:0];
+        seen_bits_q[12] <= 1'b1;
+        seen_bits_q[13] <= 1'b1;
+      end else if (mem_rsp_valid && !mem_rsp_ready) begin
+        rsp_queue_overflow_q <= rsp_queue_overflow_q + 32'd1;
+        seen_bits_q[14] <= 1'b1;
+      end
+      if (|mem_rsp_data[31:0]) begin
+        rsp_data_low_or_q <= rsp_data_low_or_q | mem_rsp_data[31:0];
+        seen_bits_q[15] <= 1'b1;
+      end
+      if (done_q) begin
+        completed_iterations_q <= completed_iterations_q + 32'd1;
+        seen_bits_q[16] <= 1'b1;
+      end
+    end
+  end
+
+  assign cfg_signature_o = cfg_batch_length_i ^ cfg_seed_i ^ cfg_address_mask_i ^ cfg_rsp_delay_max_i;
+  assign progress_cycle_count_o = cycle_count_q;
+  assign progress_signature_w =
+      cfg_signature_o
+      ^ mem_req_handshake_count_q
+      ^ {mem_rsp_handshake_count_q[15:0], dcr_write_count_q[15:0]}
+      ^ {31'd0, done_q};
+  assign progress_signature_o = progress_signature_w;
+  assign done_o = done_q;
+  assign host_req_accepted_o = dcr_write_count_q;
+  assign device_req_accepted_o = mem_req_handshake_count_q;
+  assign device_rsp_accepted_o = mem_rsp_handshake_count_q;
+  assign host_rsp_accepted_o = completed_iterations_q;
+  assign rsp_queue_overflow_o = rsp_queue_overflow_q;
+  assign trace_metric_max_reqfifo_depth_o = max_reqfifo_depth_q;
+  assign trace_metric_max_rspfifo_depth_o = max_rspfifo_depth_q;
+  assign trace_metric_reqfifo_nonempty_seen_o = {31'd0, seen_bits_q[10]};
+  assign trace_metric_rspfifo_nonempty_seen_o = {31'd0, seen_bits_q[11]};
+  assign trace_metric_a_data_mid_or_o = req_data_mid_or_q;
+  assign trace_metric_a_address_window_or_o = req_addr_window_or_q;
+  assign trace_metric_device_d_data_low_or_o = rsp_data_low_or_q;
+  assign trace_metric_device_d_data_upper_or_o = rsp_data_upper_or_q;
+  assign trace_metric_d_data_low_or_o = rsp_data_low_or_q;
+  assign trace_metric_d_data_upper_or_o = rsp_data_upper_or_q;
+  assign toggle_bitmap_word0_o = cycle_count_q;
+  assign toggle_bitmap_word1_o = dcr_write_count_q;
+  assign toggle_bitmap_word2_o = mem_req_handshake_count_q;
+  assign real_toggle_subset_word0_o  = cycle_count_q;
+  assign real_toggle_subset_word1_o  = dcr_write_count_q;
+  assign real_toggle_subset_word2_o  = {31'd0, busy};
+  assign real_toggle_subset_word3_o  = completed_iterations_q;
+  assign real_toggle_subset_word4_o  = mem_req_handshake_count_q;
+  assign real_toggle_subset_word5_o  = max_reqfifo_depth_q;
+  assign real_toggle_subset_word6_o  = req_data_mid_or_q;
+  assign real_toggle_subset_word7_o  = req_addr_window_or_q;
+  assign real_toggle_subset_word8_o  = {31'd0, mem_req_valid};
+  assign real_toggle_subset_word9_o  = {31'd0, mem_req_ready};
+  assign real_toggle_subset_word10_o = mem_rsp_handshake_count_q;
+  assign real_toggle_subset_word11_o = max_rspfifo_depth_q;
+  assign real_toggle_subset_word12_o = rsp_data_low_or_q;
+  assign real_toggle_subset_word13_o = rsp_data_upper_or_q;
+  assign real_toggle_subset_word14_o = rsp_queue_overflow_q;
+  assign real_toggle_subset_word15_o = {30'd0, mem_rsp_valid, mem_rsp_ready};
+  assign real_toggle_subset_word16_o = {14'd0, seen_bits_q};
+  assign real_toggle_subset_word17_o = {31'd0, done_q};
+  assign focused_wave_word0_o = cycle_count_q;
+  assign focused_wave_word1_o = {31'd0, busy};
+  assign focused_wave_word2_o = mem_req_handshake_count_q;
+  assign focused_wave_word3_o = mem_rsp_handshake_count_q;
+  assign focused_wave_word4_o = dcr_write_count_q;
+  assign focused_wave_word5_o = cfg_signature_o;
+  assign focused_wave_word6_o = max_reqfifo_depth_q;
+  assign focused_wave_word7_o = rsp_queue_overflow_q;
+  assign focused_metric_word0_o = host_req_accepted_o;
+  assign focused_metric_word1_o = device_req_accepted_o;
+  assign focused_metric_word2_o = device_rsp_accepted_o;
+  assign focused_metric_word3_o = host_rsp_accepted_o;
+  assign focused_metric_word4_o = {14'd0, seen_bits_q};
+
+`include "__rtlmeter_top_include.vh"
+
+endmodule
