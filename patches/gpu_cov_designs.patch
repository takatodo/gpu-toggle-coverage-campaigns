+`endif
+      {31'd0, done_w},
+      {31'd0, seen_bits_w[13]},
+      {31'd0, seen_bits_w[15]},
+      {31'd0, seen_bits_w[16]},
+      {31'd0, cfg_valid_i}
+    };
