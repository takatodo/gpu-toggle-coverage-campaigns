+            iccm_start_addr = {addr[31:2], 2'b00};
+            iccm_end_addr = {addr[31:2], 2'b00};
+            iccm_seen = 1'b1;
+        end else begin
+            if ({addr[31:2], 2'b00} < iccm_start_addr) iccm_start_addr = {addr[31:2], 2'b00};
+            if ({addr[31:2], 2'b00} > iccm_end_addr) iccm_end_addr = {addr[31:2], 2'b00};
+        end
+    end
+    if ((addr >= `RV_DCCM_SADR) && (addr <= `RV_DCCM_EADR)) begin
+        if (!dccm_seen) begin
+            dccm_start_addr = {addr[31:2], 2'b00};
+            dccm_end_addr = {addr[31:2], 2'b00};
+            dccm_seen = 1'b1;
+        end else begin
+            if ({addr[31:2], 2'b00} < dccm_start_addr) dccm_start_addr = {addr[31:2], 2'b00};
+            if ({addr[31:2], 2'b00} > dccm_end_addr) dccm_end_addr = {addr[31:2], 2'b00};
+        end
+    end
+end
+if (iccm_seen) begin
+    gpu_cov_store_preload_bound(32'hffff_fff0, iccm_start_addr);
+    gpu_cov_store_preload_bound(32'hffff_fff4, iccm_end_addr);
+end
+if (dccm_seen) begin
+    gpu_cov_store_preload_bound(32'hffff_fff8, dccm_start_addr);
+    gpu_cov_store_preload_bound(32'hffff_fffc, dccm_end_addr);
+end
+endtask
