+            iccm_end_addr = {addr[31:2], 2'b00};
+            iccm_seen = 1'b1;
+        end else begin
+            if ({addr[31:2], 2'b00} < iccm_start_addr) iccm_start_addr = {addr[31:2], 2'b00};
+            if ({addr[31:2], 2'b00} > iccm_end_addr) iccm_end_addr = {addr[31:2], 2'b00};
