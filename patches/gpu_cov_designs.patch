+
+  function automatic int unsigned clamp_pct(input int unsigned pct);
+    if (pct > 100) begin
+      return 100;
+    end
+    return pct;
+  endfunction
+
+  function automatic int unsigned prng_next(input int unsigned state);
+    return state * 32'd1664525 + 32'd1013904223;
+  endfunction
+
+  function automatic tl_a_op_e decode_req_opcode(input int unsigned rand_word);
+    rand_word = rand_word % 100;
+    if (rand_word < put_full_pct) begin
+      return PutFullData;
+    end
+    if (rand_word < (put_full_pct + put_partial_pct)) begin
+      return PutPartialData;
+    end
+    return Get;
+  endfunction
+
+  function automatic logic [31:0] window_base(input int unsigned window_idx);
+    case (window_idx)
+      0: return ADDR_SPACE_RV_DM__REGS;
+      1: return ADDR_SPACE_RV_DM__MEM;
+      2: return ADDR_SPACE_ROM_CTRL__ROM;
+      3: return ADDR_SPACE_ROM_CTRL__REGS;
+      4: return ADDR_SPACE_PERI[0];
+      5: return ADDR_SPACE_PERI[1];
+      6: return ADDR_SPACE_SPI_HOST0;
+      7: return ADDR_SPACE_SPI_HOST1;
+      8: return ADDR_SPACE_USBDEV;
+      9: return ADDR_SPACE_FLASH_CTRL__CORE;
+      10: return ADDR_SPACE_FLASH_CTRL__PRIM;
+      11: return ADDR_SPACE_FLASH_CTRL__MEM;
+      12: return ADDR_SPACE_HMAC;
+      13: return ADDR_SPACE_KMAC;
+      14: return ADDR_SPACE_AES;
+      15: return ADDR_SPACE_ENTROPY_SRC;
+      16: return ADDR_SPACE_CSRNG;
+      17: return ADDR_SPACE_EDN0;
+      18: return ADDR_SPACE_EDN1;
+      19: return ADDR_SPACE_RV_PLIC;
+      20: return ADDR_SPACE_OTBN;
+      21: return ADDR_SPACE_KEYMGR;
+      22: return ADDR_SPACE_RV_CORE_IBEX__CFG;
+      23: return ADDR_SPACE_SRAM_CTRL_MAIN__REGS;
+      24: return ADDR_SPACE_SRAM_CTRL_MAIN__RAM;
+      default: return 32'h6000_0000;
+    endcase
+  endfunction
+
+  function automatic logic [31:0] window_mask(input int unsigned window_idx);
+    case (window_idx)
+      0: return ADDR_MASK_RV_DM__REGS;
+      1: return ADDR_MASK_RV_DM__MEM;
+      2: return ADDR_MASK_ROM_CTRL__ROM;
+      3: return ADDR_MASK_ROM_CTRL__REGS;
+      4: return ADDR_MASK_PERI[0];
+      5: return ADDR_MASK_PERI[1];
+      6: return ADDR_MASK_SPI_HOST0;
+      7: return ADDR_MASK_SPI_HOST1;
+      8: return ADDR_MASK_USBDEV;
+      9: return ADDR_MASK_FLASH_CTRL__CORE;
+      10: return ADDR_MASK_FLASH_CTRL__PRIM;
+      11: return ADDR_MASK_FLASH_CTRL__MEM;
+      12: return ADDR_MASK_HMAC;
