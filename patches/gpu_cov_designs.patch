+  function automatic logic [top_pkg::TL_AW-1:0] choose_address(input int unsigned rand_word);
+    int unsigned addr_choice;
+    logic [31:0] base;
+    logic [31:0] mask;
+    logic [31:0] offset;
+    if ((rand_word % 100) < invalid_addr_pct) begin
+      offset = (address_base + (rand_word & address_mask)) & 32'h0000_fffc;
+      return 32'h6000_0000 | offset;
+    end
+    addr_choice = (rand_word >> 8) % NumAddrWindows;
+    base = window_base(addr_choice);
+    mask = window_mask(addr_choice) & address_mask;
+    offset = (address_base + rand_word) & mask;
+    choose_address = base | offset;
+    choose_address[1:0] = 2'b00;
+  endfunction
+
+  function automatic bit baseline_done();
+    bit host_idle;
+    bit device_idle;
+    host_idle = 1'b1;
+    device_idle = 1'b1;
+    for (int idx = 0; idx < NumHosts; idx++) begin
+      host_idle &= !host_req_pending_valid_q[idx];
+    end
+    for (int idx = 0; idx < NumDevices; idx++) begin
+      device_idle &= !device_rsp_pending_valid_q[idx];
+    end
+    return (main_cycles_q >= (batch_length + drain_cycles)) && host_idle && device_idle;
+  endfunction
+
+  always_comb begin
+    for (int idx = 0; idx < NumHosts; idx++) begin
+      host_h2d[idx] = TL_H2D_DEFAULT;
+      host_h2d[idx].d_ready = host_d_ready_q[idx];
+      host_h2d[idx].a_valid = host_req_pending_valid_q[idx];
+      host_h2d[idx].a_opcode = host_req_pending_q[idx].a_opcode;
+      host_h2d[idx].a_param = host_req_pending_q[idx].a_param;
+      host_h2d[idx].a_size = host_req_pending_q[idx].a_size;
+      host_h2d[idx].a_source = host_req_pending_q[idx].a_source;
+      host_h2d[idx].a_address = host_req_pending_q[idx].a_address;
+      host_h2d[idx].a_mask = host_req_pending_q[idx].a_mask;
+      host_h2d[idx].a_data = host_req_pending_q[idx].a_data;
+      host_h2d[idx].a_user = host_req_pending_q[idx].a_user;
+    end
+    for (int idx = 0; idx < NumDevices; idx++) begin
+      device_d2h[idx] = TL_D2H_DEFAULT;
+      device_d2h[idx].a_ready = device_a_ready_q[idx] && !device_rsp_pending_valid_q[idx];
+      device_d2h[idx].d_valid = device_rsp_pending_valid_q[idx] && (device_rsp_delay_q[idx] == 0);
+      device_d2h[idx].d_opcode = device_rsp_pending_q[idx].d_opcode;
+      device_d2h[idx].d_param = device_rsp_pending_q[idx].d_param;
+      device_d2h[idx].d_size = device_rsp_pending_q[idx].d_size;
+      device_d2h[idx].d_source = device_rsp_pending_q[idx].d_source;
+      device_d2h[idx].d_sink = device_rsp_pending_q[idx].d_sink;
+      device_d2h[idx].d_data = device_rsp_pending_q[idx].d_data;
+      device_d2h[idx].d_user = device_rsp_pending_q[idx].d_user;
+      device_d2h[idx].d_error = device_rsp_pending_q[idx].d_error;
+    end
+  end
+
+  always_comb begin
+    for (int idx = 0; idx < NumDevices; idx++) begin
+      device_clk[idx] = clk_main_i;
+      device_rst_ni[idx] = rst_main_ni;
+    end
+    device_clk[TlPeri] = clk_fixed_i;
+    device_rst_ni[TlPeri] = rst_fixed_ni;
+    device_clk[TlSpiHost0] = clk_spi_host0_i;
+    device_rst_ni[TlSpiHost0] = rst_spi_host0_ni;
+    device_clk[TlSpiHost1] = clk_spi_host1_i;
+    device_rst_ni[TlSpiHost1] = rst_spi_host1_ni;
+    device_clk[TlUsbdev] = clk_usb_i;
+    device_rst_ni[TlUsbdev] = rst_usb_ni;
+  end
+
+  always_ff @(posedge clk_main_i or negedge rst_main_ni) begin
+    int unsigned rand_word;
+    logic [HostSourceBits-1:0] host_source_mask;
+    if (!rst_main_ni) begin
+      main_cycles_q <= 0;
+      for (int idx = 0; idx < NumHosts; idx++) begin
+        host_req_pending_q[idx] <= TL_H2D_DEFAULT;
+        host_req_pending_valid_q[idx] <= 1'b0;
+        host_d_ready_q[idx] <= 1'b0;
+        host_rand_state_q[idx] <= (seed == 0 ? 32'h1 : seed) ^ (32'h1020_3040 + idx);
+        host_req_accepted[idx] <= 0;
+        host_rsp_accepted[idx] <= 0;
+      end
+    end else begin
+      main_cycles_q <= main_cycles_q + 1;
+      host_source_mask = source_mask[HostSourceBits-1:0];
+      for (int idx = 0; idx < NumHosts; idx++) begin
+        bit next_valid;
+        bit slot_free;
+        tl_h2d_t next_req;
+        tl_a_user_t next_user;
+
+        rand_word = host_rand_state_q[idx];
+        rand_word = prng_next(rand_word);
+        host_d_ready_q[idx] <= ((rand_word % 100) < host_d_ready_pct);
+
+        next_valid = host_req_pending_valid_q[idx];
+        next_req = host_req_pending_q[idx];
+        slot_free = !host_req_pending_valid_q[idx];
+
+        if (host_req_pending_valid_q[idx] && host_d2h[idx].a_ready) begin
+          host_req_accepted[idx] <= host_req_accepted[idx] + 1;
+          next_valid = 1'b0;
+          slot_free = 1'b1;
+        end
+        if (host_d2h[idx].d_valid && host_h2d[idx].d_ready) begin
+          host_rsp_accepted[idx] <= host_rsp_accepted[idx] + 1;
+        end
+
+        if (slot_free && (main_cycles_q < batch_length)) begin
+          rand_word = prng_next(rand_word);
+          if ((rand_word % 100) < req_valid_pct) begin
+            next_req = TL_H2D_DEFAULT;
+            next_req.a_opcode = decode_req_opcode(rand_word);
+            rand_word = prng_next(rand_word);
+            next_req.a_param = rand_word[2:0];
+            rand_word = prng_next(rand_word);
+            next_req.a_size = rand_word[top_pkg::TL_SZW-1:0];
+            rand_word = prng_next(rand_word);
+            next_req.a_source = rand_word[HostSourceBits-1:0] & host_source_mask;
+            rand_word = prng_next(rand_word);
+            next_req.a_address = choose_address(rand_word);
+            rand_word = prng_next(rand_word);
+            next_req.a_mask = rand_word[top_pkg::TL_DBW-1:0];
+            rand_word = prng_next(rand_word);
+            next_req.a_data = rand_word[top_pkg::TL_DW-1:0];
+            next_user = TL_A_USER_DEFAULT;
+            rand_word = prng_next(rand_word);
+            next_user.rsvd = rand_word[tlul_pkg::RsvdWidth-1:0];
+            rand_word = prng_next(rand_word);
+            next_user.instr_type = rand_word[0]
+                ? prim_mubi_pkg::MuBi4True
+                : prim_mubi_pkg::MuBi4False;
+            rand_word = prng_next(rand_word);
+            next_user.cmd_intg = rand_word[tlul_pkg::H2DCmdIntgWidth-1:0];
+            rand_word = prng_next(rand_word);
+            next_user.data_intg = rand_word[tlul_pkg::DataIntgWidth-1:0];
+            next_req.a_user = next_user;
+            next_valid = 1'b1;
+          end
+        end
+
+        host_req_pending_q[idx] <= next_req;
+        host_req_pending_valid_q[idx] <= next_valid;
+        host_rand_state_q[idx] <= rand_word;
+      end
+    end
+  end
+
+  for (genvar dev = 0; dev < NumDevices; dev++) begin : gen_device_model
+    always_ff @(posedge device_clk[dev] or negedge device_rst_ni[dev]) begin
+      int unsigned rand_word;
+      if (!device_rst_ni[dev]) begin
+        device_rsp_pending_q[dev] <= TL_D2H_DEFAULT;
+        device_rsp_pending_valid_q[dev] <= 1'b0;
+        device_rsp_delay_q[dev] <= '0;
+        device_a_ready_q[dev] <= 1'b0;
+        device_rand_state_q[dev] <= ((seed == 0) ? 32'h1 : seed) ^ (32'h6d2b_79f5 + dev);
+        device_req_accepted[dev] <= 0;
+        device_rsp_accepted[dev] <= 0;
+      end else begin
+        bit next_valid;
+        logic [2:0] next_delay;
+        tl_d2h_t next_rsp;
+
+        rand_word = prng_next(device_rand_state_q[dev]);
+        device_a_ready_q[dev] <= ((rand_word % 100) < device_a_ready_pct);
+
+        next_valid = device_rsp_pending_valid_q[dev];
+        next_delay = device_rsp_delay_q[dev];
+        next_rsp = device_rsp_pending_q[dev];
+
+        if (device_rsp_pending_valid_q[dev] && (device_rsp_delay_q[dev] != 0)) begin
+          next_delay = device_rsp_delay_q[dev] - 1'b1;
+        end else if (device_rsp_pending_valid_q[dev]
+                     && (device_rsp_delay_q[dev] == 0)
+                     && device_h2d[dev].d_ready) begin
+          next_valid = 1'b0;
+          next_delay = '0;
+          device_rsp_accepted[dev] <= device_rsp_accepted[dev] + 1;
+        end
+
+        if (!device_rsp_pending_valid_q[dev]
+            && device_h2d[dev].a_valid
+            && device_d2h[dev].a_ready) begin
+          tl_d_user_t next_user;
+          device_req_accepted[dev] <= device_req_accepted[dev] + 1;
+          next_rsp = TL_D2H_DEFAULT;
+          next_rsp.d_opcode = (device_h2d[dev].a_opcode == Get) ? AccessAckData : AccessAck;
+          rand_word = prng_next(rand_word);
+          next_rsp.d_param = rand_word[2:0];
+          next_rsp.d_size = device_h2d[dev].a_size;
+          next_rsp.d_source = device_h2d[dev].a_source;
+          rand_word = prng_next(rand_word);
+          next_rsp.d_sink = rand_word[top_pkg::TL_DIW-1:0];
+          rand_word = prng_next(rand_word);
+          next_rsp.d_data = rand_word[top_pkg::TL_DW-1:0] ^ (32'h0101_0101 * dev);
+          next_user = TL_D_USER_DEFAULT;
+          rand_word = prng_next(rand_word);
+          next_user.rsp_intg = rand_word[tlul_pkg::D2HRspIntgWidth-1:0];
+          rand_word = prng_next(rand_word);
+          next_user.data_intg = rand_word[tlul_pkg::DataIntgWidth-1:0];
+          next_rsp.d_user = next_user;
+          rand_word = prng_next(rand_word);
+          next_rsp.d_error = ((rand_word % 100) < rsp_error_pct);
+          rand_word = prng_next(rand_word);
+          next_delay = ((rand_word % 100) < rsp_valid_pct) ? 3'd0 : ((rand_word % 4) + 1);
+          next_valid = 1'b1;
+        end
+
+        device_rsp_pending_q[dev] <= next_rsp;
+        device_rsp_pending_valid_q[dev] <= next_valid;
+        device_rsp_delay_q[dev] <= next_delay;
+        device_rand_state_q[dev] <= rand_word;
+      end
+    end
+  end
+
+  initial begin
+    int unsigned event_count;
+    clk_main_i = 1'b0;
+    clk_fixed_i = 1'b0;
+    clk_usb_i = 1'b0;
+    clk_spi_host0_i = 1'b0;
+    clk_spi_host1_i = 1'b0;
+    rst_main_ni = 1'b0;
+    rst_fixed_ni = 1'b0;
+    rst_usb_ni = 1'b0;
+    rst_spi_host0_ni = 1'b0;
+    rst_spi_host1_ni = 1'b0;
+    scanmode_i = prim_mubi_pkg::MuBi4False;
+
+    batch_length = 256;
+    req_valid_pct = 65;
+    rsp_valid_pct = 70;
+    host_d_ready_pct = 75;
+    device_a_ready_pct = 80;
+    put_full_pct = 34;
+    put_partial_pct = 33;
+    access_ack_data_pct = 50;
+    rsp_error_pct = 10;
+    invalid_addr_pct = 12;
+    reset_cycles = 4;
+    drain_cycles = 48;
+    seed = 1;
+    address_base = 0;
+    address_mask = 32'h0000_0ffc;
+    source_mask = 32'hff;
+    main_half_period = 5;
+    fixed_half_period = 7;
+    usb_half_period = 9;
+    spi_host0_half_period = 11;
+    spi_host1_half_period = 13;
+    timeout_events = 0;
+
+    void'($value$plusargs("batch_length=%d", batch_length));
+    void'($value$plusargs("req_valid_pct=%d", req_valid_pct));
+    void'($value$plusargs("rsp_valid_pct=%d", rsp_valid_pct));
+    void'($value$plusargs("host_d_ready_pct=%d", host_d_ready_pct));
+    void'($value$plusargs("device_a_ready_pct=%d", device_a_ready_pct));
+    void'($value$plusargs("put_full_pct=%d", put_full_pct));
+    void'($value$plusargs("put_partial_pct=%d", put_partial_pct));
+    void'($value$plusargs("access_ack_data_pct=%d", access_ack_data_pct));
+    void'($value$plusargs("rsp_error_pct=%d", rsp_error_pct));
+    void'($value$plusargs("invalid_addr_pct=%d", invalid_addr_pct));
+    void'($value$plusargs("reset_cycles=%d", reset_cycles));
+    void'($value$plusargs("drain_cycles=%d", drain_cycles));
+    void'($value$plusargs("seed=%d", seed));
+    void'($value$plusargs("address_base=%d", address_base));
+    void'($value$plusargs("address_mask=%d", address_mask));
+    void'($value$plusargs("source_mask=%d", source_mask));
+    void'($value$plusargs("main_half_period=%d", main_half_period));
+    void'($value$plusargs("fixed_half_period=%d", fixed_half_period));
+    void'($value$plusargs("usb_half_period=%d", usb_half_period));
+    void'($value$plusargs("spi_host0_half_period=%d", spi_host0_half_period));
+    void'($value$plusargs("spi_host1_half_period=%d", spi_host1_half_period));
+    void'($value$plusargs("timeout_events=%d", timeout_events));
+
+    req_valid_pct = clamp_pct(req_valid_pct);
+    rsp_valid_pct = clamp_pct(rsp_valid_pct);
+    host_d_ready_pct = clamp_pct(host_d_ready_pct);
+    device_a_ready_pct = clamp_pct(device_a_ready_pct);
+    put_full_pct = clamp_pct(put_full_pct);
+    put_partial_pct = clamp_pct(put_partial_pct);
+    access_ack_data_pct = clamp_pct(access_ack_data_pct);
+    rsp_error_pct = clamp_pct(rsp_error_pct);
+    invalid_addr_pct = clamp_pct(invalid_addr_pct);
+
+    repeat (reset_cycles) @(posedge clk_main_i);
+    rst_main_ni = 1'b1;
+    rst_fixed_ni = 1'b1;
+    rst_usb_ni = 1'b1;
+    rst_spi_host0_ni = 1'b1;
+    rst_spi_host1_ni = 1'b1;
+
+    event_count = 0;
+    while (!baseline_done()) begin
+      @(posedge clk_main_i or posedge clk_fixed_i or posedge clk_usb_i
+        or posedge clk_spi_host0_i or posedge clk_spi_host1_i);
+      event_count++;
+      if ((timeout_events > 0) && (event_count >= timeout_events)) begin
+        $fatal(1, "Timed out waiting for xbar_main_cov_tb completion after %0d events", event_count);
+      end
+    end
+
+    $display("xbar_main_cov_tb host_req_accepted=%0d,%0d,%0d host_rsp_accepted=%0d,%0d,%0d",
+             host_req_accepted[0], host_req_accepted[1], host_req_accepted[2],
+             host_rsp_accepted[0], host_rsp_accepted[1], host_rsp_accepted[2]);
+    $display("xbar_main_cov_tb device_req_accepted_main=%0d device_req_accepted_async=%0d",
+             device_req_accepted[TlSramCtrlMainRam],
+             device_req_accepted[TlUsbdev] + device_req_accepted[TlSpiHost0]
+             + device_req_accepted[TlSpiHost1] + device_req_accepted[TlPeri]);
+    $finish;
+  end
+
+  logic unused_access_ack_data_pct;
+  assign unused_access_ack_data_pct = ^access_ack_data_pct;
+
+endmodule
diff --git a/designs/OpenTitan/src/xbar_main_gpu_cov_tb.sv b/designs/OpenTitan/src/xbar_main_gpu_cov_tb.sv
new file mode 100644
