+  int unsigned req_address_mode;
+  int unsigned req_data_mode;
+  int unsigned req_data_hi_xor;
+  int unsigned access_ack_data_pct;
+  int unsigned rsp_error_pct;
+  int unsigned rsp_fill_target;
+  int unsigned rsp_delay_max;
+  int unsigned rsp_family;
+  int unsigned rsp_delay_mode;
