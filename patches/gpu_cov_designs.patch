+//
+// Single-cluster-friendly gpu_cov wrapper for the Example design.
+// The wrapper keeps the gpu_cov contract but computes the observability payload
+// as one packed combinational bundle so the lowered assign graph stays cohesive.
+
+module example_gpu_cov_single_cluster_tb (
+  input  logic        cfg_valid_i,
+  input  logic [31:0] cfg_batch_length_i,
+  input  logic [31:0] cfg_req_valid_pct_i,
