+  int unsigned drain_cycles;
+  int unsigned seed;
+  int unsigned address_base;
+  int unsigned address_mask;
+  int unsigned source_mask;
+  int unsigned rand_state_q;
+  int unsigned trace_replay_enable;
+  int unsigned trace_replay_cycles;
+  string       trace_replay_init_file;
+  string       trace_vcd_file;
+
+  logic                   replay_req_valid_q [ReplayDepth];
+  logic             [2:0] replay_req_opcode_q [ReplayDepth];
+  logic             [2:0] replay_req_param_q [ReplayDepth];
+  logic [top_pkg::TL_SZW-1:0] replay_req_size_q [ReplayDepth];
+  logic  [top_pkg::TL_AW-1:0] replay_req_address_q [ReplayDepth];
+  logic [top_pkg::TL_DBW-1:0] replay_req_mask_q [ReplayDepth];
+  logic  [top_pkg::TL_DW-1:0] replay_req_data_q [ReplayDepth];
+  logic [top_pkg::TL_AIW-1:0] replay_req_source_q [ReplayDepth];
+  logic             [0:0] replay_req_spare_q [ReplayDepth];
+  logic             [1:0] replay_host_ready_mode_q [ReplayDepth];
+  logic             [1:0] replay_device_ready_mode_q [ReplayDepth];
+  logic                   replay_rsp_valid_q [ReplayDepth];
+  logic             [2:0] replay_rsp_opcode_q [ReplayDepth];
+  logic [top_pkg::TL_SZW-1:0] replay_rsp_size_q [ReplayDepth];
+  logic [top_pkg::TL_AIW-1:0] replay_rsp_source_q [ReplayDepth];
+  logic  [top_pkg::TL_DW-1:0] replay_rsp_data_q [ReplayDepth];
+  logic                   replay_rsp_error_q [ReplayDepth];
+
+  int unsigned host_req_accepted;
+  int unsigned device_req_accepted;
+  int unsigned device_rsp_accepted;
+  int unsigned host_rsp_accepted;
+  int unsigned rsp_queue_overflow;
+  int unsigned cycle_idx;
+
+  tlul_fifo_sync dut (
+    .clk_i,
+    .rst_ni,
+    .tl_h_i,
+    .tl_h_o,
+    .tl_d_o,
+    .tl_d_i,
+    .spare_req_i,
+    .spare_req_o,
+    .spare_rsp_i,
+    .spare_rsp_o
+  );
+
+  always #5 clk_i = ~clk_i;
+
+  function automatic int unsigned clamp_pct(input int unsigned pct);
+    if (pct > 100) begin
+      return 100;
+    end
+    return pct;
+  endfunction
+
+  function automatic int unsigned prng_next(input int unsigned state);
+    return state * 32'd1664525 + 32'd1013904223;
+  endfunction
+
+  function automatic logic decode_ready_mode(input logic [1:0] mode, input logic default_value);
+    unique case (mode)
+      2'd1: return 1'b0;
+      2'd2: return 1'b1;
+      default: return default_value;
+    endcase
+  endfunction
+
+  task automatic next_rand(output int unsigned value);
+    rand_state_q = prng_next(rand_state_q);
+    value = rand_state_q;
+  endtask
+
+  task automatic choose_req_opcode(output tl_a_op_e opcode);
+    int unsigned rand_word;
+    next_rand(rand_word);
+    rand_word = rand_word % 100;
+    unique case (req_family)
+      1: begin
+        if (rand_word < 72) opcode = PutFullData;
+        else if (rand_word < 92) opcode = PutPartialData;
+        else opcode = Get;
+      end
+      2: begin
+        if (rand_word < 82) opcode = Get;
+        else if (rand_word < 94) opcode = PutPartialData;
+        else opcode = PutFullData;
+      end
+      3: begin
+        unique case (rand_word[1:0])
+          2'd0: opcode = Get;
+          2'd1: opcode = PutPartialData;
+          default: opcode = PutFullData;
+        endcase
+      end
+      default: begin
+        if (rand_word < put_full_pct) begin
+          opcode = PutFullData;
+        end else if (rand_word < (put_full_pct + put_partial_pct)) begin
+          opcode = PutPartialData;
+        end else begin
+          opcode = Get;
+        end
+      end
+    endcase
+  endtask
+
+  task automatic choose_rsp_opcode(output tl_d_op_e opcode);
+    int unsigned rand_word;
+    next_rand(rand_word);
+    unique case (rsp_family)
+      1: opcode = AccessAckData;
+      2: opcode = ((rand_word % 100) < 20) ? AccessAckData : AccessAck;
+      3: opcode = rand_word[0] ? AccessAckData : AccessAck;
+      default: opcode = ((rand_word % 100) < access_ack_data_pct) ? AccessAckData : AccessAck;
+    endcase
+  endtask
+
+  task automatic maybe_make_request;
+    int unsigned rand_word;
+    if (req_pending_valid_q) begin
+      return;
+    end
+    if (req_burst_remaining_q != 0) begin
+      req_pending_valid_q = 1'b1;
+      req_pending_opcode_q = req_burst_opcode_q;
+      req_pending_param_q = req_burst_param_q;
+      req_pending_size_q = req_burst_size_q;
+      req_pending_source_q = req_burst_source_q;
+      req_pending_address_q = req_burst_address_q;
+      req_pending_mask_q = req_burst_mask_q;
+      req_pending_data_q = req_burst_data_q;
+      req_pending_user_q = req_burst_user_q;
+      req_pending_spare_q = req_burst_spare_q;
+      return;
+    end
+    next_rand(rand_word);
+    if ((rand_word % 100) >= req_valid_pct) begin
+      return;
+    end
+    req_pending_valid_q = 1'b1;
+    choose_req_opcode(req_pending_opcode_q);
+    next_rand(rand_word);
+    req_pending_param_q = rand_word[2:0];
+    next_rand(rand_word);
+    req_pending_size_q = rand_word[top_pkg::TL_SZW-1:0];
+    next_rand(rand_word);
+    req_pending_source_q = rand_word[top_pkg::TL_AIW-1:0] & source_mask[top_pkg::TL_AIW-1:0];
+    next_rand(rand_word);
+    req_pending_address_q = (address_base & ~address_mask) | (rand_word & address_mask);
+    req_pending_address_q[1:0] = 2'b00;
+    unique case (req_address_mode)
+      1: req_pending_address_q = (address_base & ~32'h3c) | (req_pending_address_q & 32'h3c);
+      2: req_pending_address_q = (address_base & ~32'hfc) | (req_pending_address_q & 32'hfc);
+      3: req_pending_address_q = (address_base & ~address_mask)
+                                 | ((32'(req_pending_source_q) << 4) & address_mask);
+      default: begin
+      end
+    endcase
+    next_rand(rand_word);
+    req_pending_mask_q = rand_word[top_pkg::TL_DBW-1:0];
+    next_rand(rand_word);
+    req_pending_data_q = rand_word;
+    unique case (req_data_mode)
+      1: req_pending_data_q =
+          {req_pending_address_q[15:0], req_pending_address_q[15:0]} ^ 32'h55aa_33cc;
+      2: req_pending_data_q =
+          {4{req_pending_source_q[7:0]}} ^ {8{req_pending_address_q[3:0]}};
+      3: req_pending_data_q =
+          {req_pending_address_q[15:0], req_pending_source_q, req_pending_mask_q, 4'h0}
+          ^ 32'hc0de_1234;
+      4: req_pending_data_q =
+          {(16'h8000 >> ((req_pending_address_q[5:2] + req_pending_source_q[3:0]) & 4'hf))
+             ^ req_data_hi_xor[31:16],
+           req_pending_address_q[15:0] ^ {4'h0, req_pending_mask_q, req_pending_source_q}};
+      default: begin
+      end
+    endcase
+    req_pending_data_q = req_pending_data_q ^ req_data_hi_xor;
+    unique case (req_family)
+      1: begin
+        req_pending_size_q = top_pkg::TL_SZW'(2);
+        req_pending_mask_q = '1;
+        req_pending_source_q = req_pending_source_q & 'h3;
+        req_pending_address_q = (address_base & ~32'h3c) | (req_pending_address_q & 32'h3c);
+        req_pending_data_q =
+            ({req_pending_address_q[15:0], req_pending_address_q[15:0]} ^ 32'h55aa_33cc)
+            ^ req_data_hi_xor;
+      end
+      2: begin
+        req_pending_opcode_q = Get;
+        req_pending_size_q = top_pkg::TL_SZW'(2);
+        req_pending_mask_q = '1;
+        req_pending_source_q = req_pending_source_q & 'h7;
+        req_pending_address_q = (address_base & ~32'hfc) | (req_pending_address_q & 32'hfc);
+      end
+      3: begin
+        req_pending_size_q = top_pkg::TL_SZW'(2);
+        req_pending_address_q =
+            (address_base & ~address_mask) | ((32'(req_pending_source_q) << 4) & address_mask);
+        req_pending_data_q =
+            {16{req_pending_source_q[1:0] ^ req_pending_address_q[3:2]}} ^ req_data_hi_xor;
+      end
+      default: begin
+      end
+    endcase
+    next_rand(rand_word);
+    req_pending_user_q = tlul_pkg::TL_A_USER_DEFAULT;
+    req_pending_user_q.rsvd = rand_word[tlul_pkg::RsvdWidth-1:0];
+    next_rand(rand_word);
+    req_pending_user_q.instr_type = rand_word[0]
+        ? prim_mubi_pkg::MuBi4True
+        : prim_mubi_pkg::MuBi4False;
+    next_rand(rand_word);
+    req_pending_user_q.cmd_intg = rand_word[tlul_pkg::H2DCmdIntgWidth-1:0];
+    next_rand(rand_word);
+    req_pending_user_q.data_intg = rand_word[tlul_pkg::DataIntgWidth-1:0];
+    next_rand(rand_word);
+    req_pending_spare_q = rand_word[0];
+    if (req_burst_len_max != 0) begin
+      next_rand(rand_word);
+      req_burst_remaining_q = rand_word % (req_burst_len_max + 1);
+      req_burst_opcode_q = req_pending_opcode_q;
+      req_burst_param_q = req_pending_param_q;
+      req_burst_size_q = req_pending_size_q;
+      req_burst_source_q = req_pending_source_q;
+      req_burst_address_q = req_pending_address_q + 32'd4;
+      req_burst_mask_q = req_pending_mask_q;
+      req_burst_data_q = (req_pending_data_q ^ 32'h0101_0101) ^ req_data_hi_xor;
+      req_burst_user_q = req_pending_user_q;
+      req_burst_spare_q = req_pending_spare_q;
+    end
+  endtask
+
+  task automatic maybe_make_response;
+    int unsigned rand_word;
+    if (rsp_pending_valid_q || rsp_count_q == 0) begin
+      return;
+    end
+    if (rsp_delay_queue[rsp_head_q] != 0) begin
+      return;
+    end
+    next_rand(rand_word);
+    if ((rand_word % 100) >= rsp_valid_pct) begin
+      return;
+    end
+    rsp_pending_valid_q = 1'b1;
+    choose_rsp_opcode(rsp_pending_opcode_q);
+    next_rand(rand_word);
+    rsp_pending_param_q = rand_word[2:0];
+    rsp_pending_size_q = rsp_size_queue[rsp_head_q];
+    rsp_pending_source_q = rsp_source_queue[rsp_head_q];
+    next_rand(rand_word);
+    rsp_pending_sink_q = rand_word[top_pkg::TL_DIW-1:0];
+    next_rand(rand_word);
+    rsp_pending_data_q = rand_word;
+    next_rand(rand_word);
+    rsp_pending_user_q = tlul_pkg::TL_D_USER_DEFAULT;
+    rsp_pending_user_q.rsp_intg = rand_word[tlul_pkg::D2HRspIntgWidth-1:0];
+    next_rand(rand_word);
+    rsp_pending_user_q.data_intg = rand_word[tlul_pkg::DataIntgWidth-1:0];
+    next_rand(rand_word);
+    rsp_pending_error_q = ((rand_word % 100) < rsp_error_pct);
+    next_rand(rand_word);
+    rsp_pending_spare_q = rand_word[0];
+    unique case (rsp_family)
+      1: begin
+        rsp_pending_opcode_q = AccessAckData;
+        rsp_pending_data_q =
+            {rsp_pending_source_q, rsp_pending_source_q,
+             rsp_pending_source_q, rsp_pending_source_q};
+        rsp_pending_error_q = 1'b0;
+      end
+      2: begin
+        rsp_pending_opcode_q = AccessAck;
+        rsp_pending_error_q = ((rand_word % 100) < (rsp_error_pct >> 1));
+      end
+      3: begin
+        rsp_pending_data_q = {16'hcafe, rsp_pending_source_q, rsp_pending_size_q, rand_word[5:0]};
+      end
+      default: begin
+      end
+    endcase
+    unique case (rsp_data_mode)
+      1: rsp_pending_data_q =
+          {rsp_pending_source_q, rsp_pending_source_q, rsp_pending_source_q, rsp_pending_source_q};
+      2: rsp_pending_data_q =
+          {16'hcafe, rsp_pending_source_q, rsp_pending_size_q, rand_word[5:0]};
+      3: rsp_pending_data_q =
+          {12'h0, rsp_pending_sink_q, rsp_pending_source_q, rsp_pending_size_q,
+           rsp_pending_param_q, rsp_pending_error_q, rand_word[4:0]} ^ 32'h2468_ace1;
+      4: rsp_pending_data_q =
+          {(16'h8000 >> ((rsp_pending_source_q[3:0] + {2'b00, rsp_pending_size_q}) & 4'hf))
+             ^ rsp_data_hi_xor[31:16],
+           rsp_pending_source_q, rsp_pending_size_q, rsp_pending_param_q,
+           rsp_pending_error_q, rand_word[1:0]};
+      default: begin
+      end
+    endcase
+    rsp_pending_data_q = rsp_pending_data_q ^ rsp_data_hi_xor;
+  endtask
+
+  task automatic maybe_advance_response_delay;
+    if (rsp_count_q == 0) begin
+      return;
+    end
+    if (rsp_delay_queue[rsp_head_q] != 0) begin
+      unique case (rsp_delay_mode)
+        1: rsp_delay_queue[rsp_head_q] = 0;
+        2: rsp_delay_queue[rsp_head_q] =
+            (rsp_delay_queue[rsp_head_q] > 2) ? 2 : rsp_delay_queue[rsp_head_q];
+        3: rsp_delay_queue[rsp_head_q]--;
+        default: rsp_delay_queue[rsp_head_q]--;
+      endcase
+    end
+  endtask
+
+  task automatic drive_cycle_inputs;
+    int unsigned rand_word;
+    next_rand(rand_word);
+    tl_h_i = tlul_pkg::TL_H2D_DEFAULT;
+    tl_h_i.d_ready = (rsp_count_q < rsp_fill_target)
+        ? 1'b0
+        : ((rand_word % 100) < host_d_ready_pct);
+    tl_h_i.a_valid = req_pending_valid_q;
+    tl_h_i.a_opcode = req_pending_opcode_q;
+    tl_h_i.a_param = req_pending_param_q;
+    tl_h_i.a_size = req_pending_size_q;
+    tl_h_i.a_source = req_pending_source_q;
+    tl_h_i.a_address = req_pending_address_q;
+    tl_h_i.a_mask = req_pending_mask_q;
+    tl_h_i.a_data = req_pending_data_q;
+    tl_h_i.a_user = req_pending_user_q;
+    spare_req_i = req_pending_spare_q;
+
+    next_rand(rand_word);
+    tl_d_i = tlul_pkg::TL_D2H_DEFAULT;
+    tl_d_i.a_ready = (rsp_count_q < req_fill_target)
+        ? 1'b0
+        : ((rand_word % 100) < device_a_ready_pct);
+    tl_d_i.d_valid = rsp_pending_valid_q;
+    tl_d_i.d_opcode = rsp_pending_opcode_q;
+    tl_d_i.d_param = rsp_pending_param_q;
+    tl_d_i.d_size = rsp_pending_size_q;
+    tl_d_i.d_source = rsp_pending_source_q;
+    tl_d_i.d_sink = rsp_pending_sink_q;
+    tl_d_i.d_data = rsp_pending_data_q;
+    tl_d_i.d_user = rsp_pending_user_q;
+    tl_d_i.d_error = rsp_pending_error_q;
+    spare_rsp_i = rsp_pending_spare_q;
+  endtask
+
+  task automatic drive_replay_cycle(input int unsigned replay_cycle_idx);
+    tl_h_i = tlul_pkg::TL_H2D_DEFAULT;
+    tl_d_i = tlul_pkg::TL_D2H_DEFAULT;
+    spare_req_i = '0;
+    spare_rsp_i = '0;
+
+    if (replay_cycle_idx >= trace_replay_cycles) begin
+      tl_h_i.d_ready = 1'b1;
+      tl_d_i.a_ready = 1'b1;
+      return;
+    end
+
+    tl_h_i.d_ready =
+        decode_ready_mode(replay_host_ready_mode_q[replay_cycle_idx], 1'b1);
+    tl_d_i.a_ready =
+        decode_ready_mode(replay_device_ready_mode_q[replay_cycle_idx], 1'b1);
+
+    if (replay_req_valid_q[replay_cycle_idx]) begin
+      tl_h_i.a_valid = 1'b1;
+      tl_h_i.a_opcode = tl_a_op_e'(replay_req_opcode_q[replay_cycle_idx]);
+      tl_h_i.a_param = replay_req_param_q[replay_cycle_idx];
+      tl_h_i.a_size = replay_req_size_q[replay_cycle_idx];
+      tl_h_i.a_source = replay_req_source_q[replay_cycle_idx];
+      tl_h_i.a_address = replay_req_address_q[replay_cycle_idx];
+      tl_h_i.a_mask = replay_req_mask_q[replay_cycle_idx];
+      tl_h_i.a_data = replay_req_data_q[replay_cycle_idx];
+      tl_h_i.a_user = tlul_pkg::TL_A_USER_DEFAULT;
+      spare_req_i = replay_req_spare_q[replay_cycle_idx];
+    end
+
+    if (replay_rsp_valid_q[replay_cycle_idx]) begin
+      tl_d_i.d_valid = 1'b1;
+      tl_d_i.d_opcode = tl_d_op_e'(replay_rsp_opcode_q[replay_cycle_idx]);
+      tl_d_i.d_size = replay_rsp_size_q[replay_cycle_idx];
+      tl_d_i.d_source = replay_rsp_source_q[replay_cycle_idx];
+      tl_d_i.d_sink = '0;
+      tl_d_i.d_data = replay_rsp_data_q[replay_cycle_idx];
+      tl_d_i.d_user = tlul_pkg::TL_D_USER_DEFAULT;
+      tl_d_i.d_error = replay_rsp_error_q[replay_cycle_idx];
+    end
+  endtask
+
+  task automatic load_trace_replay_file;
+    int replay_fd;
+    int replay_rc;
+    int unsigned replay_idx;
+    int unsigned req_valid;
+    int unsigned req_opcode;
+    int unsigned req_param;
+    int unsigned req_size;
+    int unsigned req_address;
+    int unsigned req_mask;
+    int unsigned req_data;
+    int unsigned req_source;
+    int unsigned req_spare;
+    int unsigned host_ready_mode;
+    int unsigned device_ready_mode;
+    int unsigned rsp_valid;
+    int unsigned rsp_opcode;
+    int unsigned rsp_size;
+    int unsigned rsp_source;
+    int unsigned rsp_data;
+    int unsigned rsp_error;
+
+    if ((trace_replay_enable == 0) || (trace_replay_init_file.len() == 0)) begin
+      return;
+    end
+    replay_fd = $fopen(trace_replay_init_file, "r");
+    if (replay_fd == 0) begin
+      $fatal(1, "Failed to open trace replay init file '%0s'", trace_replay_init_file);
+    end
+    replay_rc = $fscanf(replay_fd, "%d\n", trace_replay_cycles);
+    if (replay_rc != 1) begin
+      $fatal(1, "Failed to read trace replay cycle count from '%0s'", trace_replay_init_file);
+    end
+    if (trace_replay_cycles > ReplayDepth) begin
+      $fatal(1, "trace replay cycles %0d exceed ReplayDepth=%0d", trace_replay_cycles, ReplayDepth);
+    end
+    for (replay_idx = 0; replay_idx < trace_replay_cycles; replay_idx++) begin
+      replay_rc = $fscanf(
+          replay_fd,
+          "%d %h %h %h %h %h %h %h %h %d %d %d %h %h %h %h %h\n",
+          req_valid,
+          req_opcode,
+          req_param,
+          req_size,
+          req_address,
+          req_mask,
+          req_data,
+          req_source,
+          req_spare,
+          host_ready_mode,
+          device_ready_mode,
+          rsp_valid,
+          rsp_opcode,
+          rsp_size,
+          rsp_source,
+          rsp_data,
+          rsp_error
+      );
+      if (replay_rc != 17) begin
+        $fatal(1, "Malformed trace replay entry %0d in '%0s'", replay_idx, trace_replay_init_file);
+      end
+      replay_req_valid_q[replay_idx] = req_valid[0];
+      replay_req_opcode_q[replay_idx] = req_opcode[2:0];
+      replay_req_param_q[replay_idx] = req_param[2:0];
+      replay_req_size_q[replay_idx] = req_size[top_pkg::TL_SZW-1:0];
+      replay_req_address_q[replay_idx] = req_address[top_pkg::TL_AW-1:0];
+      replay_req_mask_q[replay_idx] = req_mask[top_pkg::TL_DBW-1:0];
+      replay_req_data_q[replay_idx] = req_data[top_pkg::TL_DW-1:0];
+      replay_req_source_q[replay_idx] = req_source[top_pkg::TL_AIW-1:0];
+      replay_req_spare_q[replay_idx] = req_spare[0];
+      replay_host_ready_mode_q[replay_idx] = host_ready_mode[1:0];
+      replay_device_ready_mode_q[replay_idx] = device_ready_mode[1:0];
+      replay_rsp_valid_q[replay_idx] = rsp_valid[0];
+      replay_rsp_opcode_q[replay_idx] = rsp_opcode[2:0];
+      replay_rsp_size_q[replay_idx] = rsp_size[top_pkg::TL_SZW-1:0];
+      replay_rsp_source_q[replay_idx] = rsp_source[top_pkg::TL_AIW-1:0];
+      replay_rsp_data_q[replay_idx] = rsp_data[top_pkg::TL_DW-1:0];
+      replay_rsp_error_q[replay_idx] = rsp_error[0];
+    end
+    $fclose(replay_fd);
+  endtask
+
+  task automatic sample_cycle_outputs;
+    int unsigned rand_word;
+    if (req_pending_valid_q && tl_h_o.a_ready) begin
+      req_pending_valid_q = 1'b0;
+      if (req_burst_remaining_q != 0) begin
+        req_burst_remaining_q--;
+        req_burst_address_q = req_burst_address_q + 32'd4;
+        req_burst_data_q = {req_burst_data_q[23:0], req_burst_data_q[31:24]} ^ 32'h1f1f_1f1f;
+      end
+      host_req_accepted++;
+    end
+
+    if (tl_d_o.a_valid && tl_d_i.a_ready) begin
+      device_req_accepted++;
+      if (rsp_count_q < QueueDepth) begin
+        rsp_source_queue[rsp_tail_q] = tl_d_o.a_source;
+        rsp_size_queue[rsp_tail_q] = tl_d_o.a_size;
+        next_rand(rand_word);
+        unique case (rsp_delay_mode)
+          1: rsp_delay_queue[rsp_tail_q] = 0;
+          2: rsp_delay_queue[rsp_tail_q] =
+              (rsp_delay_max == 0) ? 0 : (((rand_word % 2) != 0) ? rsp_delay_max : 0);
+          3: rsp_delay_queue[rsp_tail_q] =
+              (rsp_delay_max == 0) ? 0 : ((rand_word % (rsp_delay_max + 1)) >> 1);
+          default: rsp_delay_queue[rsp_tail_q] =
+              (rsp_delay_max == 0) ? 0 : (rand_word % (rsp_delay_max + 1));
+        endcase
+        rsp_tail_q = (rsp_tail_q + 1) % QueueDepth;
+        rsp_count_q++;
+      end else begin
+        rsp_queue_overflow++;
+      end
+    end
+
+    if (rsp_pending_valid_q && tl_d_o.d_ready) begin
+      rsp_pending_valid_q = 1'b0;
+      device_rsp_accepted++;
+      if (rsp_count_q != 0) begin
+        rsp_head_q = (rsp_head_q + 1) % QueueDepth;
+        rsp_count_q--;
+      end
+    end
+
+    if (tl_h_o.d_valid && tl_h_i.d_ready) begin
+      host_rsp_accepted++;
+    end
+  endtask
+
+  initial begin
+    int unsigned rand_word;
+
+    clk_i = 1'b0;
+    rst_ni = 1'b0;
+    tl_h_i = tlul_pkg::TL_H2D_DEFAULT;
+    tl_d_i = tlul_pkg::TL_D2H_DEFAULT;
+    spare_req_i = '0;
+    spare_rsp_i = '0;
+
+    req_pending_valid_q = 1'b0;
+    req_pending_opcode_q = PutFullData;
+    req_pending_param_q = '0;
+    req_pending_size_q = '0;
+    req_pending_source_q = '0;
+    req_pending_address_q = '0;
+    req_pending_mask_q = '0;
+    req_pending_data_q = '0;
+    req_pending_user_q = tlul_pkg::TL_A_USER_DEFAULT;
+    req_pending_spare_q = '0;
+    req_burst_remaining_q = 0;
+    req_burst_opcode_q = PutFullData;
+    req_burst_param_q = '0;
+    req_burst_size_q = '0;
+    req_burst_source_q = '0;
+    req_burst_address_q = '0;
+    req_burst_mask_q = '0;
+    req_burst_data_q = '0;
+    req_burst_user_q = tlul_pkg::TL_A_USER_DEFAULT;
+    req_burst_spare_q = '0;
+
+    rsp_pending_valid_q = 1'b0;
+    rsp_pending_opcode_q = AccessAck;
+    rsp_pending_param_q = '0;
+    rsp_pending_size_q = '0;
+    rsp_pending_source_q = '0;
+    rsp_pending_sink_q = '0;
+    rsp_pending_data_q = '0;
+    rsp_pending_user_q = tlul_pkg::TL_D_USER_DEFAULT;
+    rsp_pending_error_q = 1'b0;
+    rsp_pending_spare_q = '0;
+
+    rsp_head_q = 0;
+    rsp_tail_q = 0;
+    rsp_count_q = 0;
+    for (int unsigned queue_idx = 0; queue_idx < QueueDepth; queue_idx++) begin
+      rsp_delay_queue[queue_idx] = 0;
+    end
+
+    batch_length = 256;
+    req_valid_pct = 65;
+    rsp_valid_pct = 70;
+    host_d_ready_pct = 75;
+    device_a_ready_pct = 80;
+    put_full_pct = 34;
+    put_partial_pct = 33;
+    req_fill_target = 2;
+    req_burst_len_max = 0;
+    req_family = 0;
+    req_address_mode = 0;
+    req_data_mode = 0;
+    req_data_hi_xor = 0;
+    access_ack_data_pct = 50;
+    rsp_error_pct = 10;
+    rsp_fill_target = 2;
+    rsp_delay_max = 4;
+    rsp_family = 0;
+    rsp_delay_mode = 0;
+    rsp_data_mode = 0;
+    rsp_data_hi_xor = 0;
+    reset_cycles = 4;
+    drain_cycles = 16;
+    seed = 1;
+    address_base = 0;
+    address_mask = 32'h0000_0ffc;
+    source_mask = 32'({top_pkg::TL_AIW{1'b1}});
+    trace_replay_enable = 0;
+    trace_replay_cycles = 0;
+    trace_replay_init_file = "";
+    trace_vcd_file = "";
+    host_req_accepted = 0;
+    device_req_accepted = 0;
+    device_rsp_accepted = 0;
+    host_rsp_accepted = 0;
+    rsp_queue_overflow = 0;
+
+    void'($value$plusargs("batch_length=%d", batch_length));
+    void'($value$plusargs("req_valid_pct=%d", req_valid_pct));
+    void'($value$plusargs("rsp_valid_pct=%d", rsp_valid_pct));
+    void'($value$plusargs("host_d_ready_pct=%d", host_d_ready_pct));
+    void'($value$plusargs("device_a_ready_pct=%d", device_a_ready_pct));
+    void'($value$plusargs("put_full_pct=%d", put_full_pct));
+    void'($value$plusargs("put_partial_pct=%d", put_partial_pct));
+    void'($value$plusargs("req_fill_target=%d", req_fill_target));
+    void'($value$plusargs("req_burst_len_max=%d", req_burst_len_max));
+    void'($value$plusargs("req_family=%d", req_family));
+    void'($value$plusargs("req_address_mode=%d", req_address_mode));
+    void'($value$plusargs("req_data_mode=%d", req_data_mode));
+    void'($value$plusargs("req_data_hi_xor=%d", req_data_hi_xor));
+    void'($value$plusargs("access_ack_data_pct=%d", access_ack_data_pct));
+    void'($value$plusargs("rsp_error_pct=%d", rsp_error_pct));
+    void'($value$plusargs("rsp_fill_target=%d", rsp_fill_target));
+    void'($value$plusargs("rsp_delay_max=%d", rsp_delay_max));
+    void'($value$plusargs("rsp_family=%d", rsp_family));
+    void'($value$plusargs("rsp_delay_mode=%d", rsp_delay_mode));
+    void'($value$plusargs("rsp_data_mode=%d", rsp_data_mode));
+    void'($value$plusargs("rsp_data_hi_xor=%d", rsp_data_hi_xor));
+    void'($value$plusargs("reset_cycles=%d", reset_cycles));
+    void'($value$plusargs("drain_cycles=%d", drain_cycles));
+    void'($value$plusargs("seed=%d", seed));
+    void'($value$plusargs("address_base=%d", address_base));
+    void'($value$plusargs("address_mask=%d", address_mask));
+    void'($value$plusargs("source_mask=%d", source_mask));
+    void'($value$plusargs("trace_replay_enable=%d", trace_replay_enable));
+    void'($value$plusargs("trace_replay_cycles=%d", trace_replay_cycles));
+    void'($value$plusargs("trace_replay_init_file=%s", trace_replay_init_file));
+    void'($value$plusargs("trace_vcd=%s", trace_vcd_file));
+
+    req_valid_pct = clamp_pct(req_valid_pct);
+    rsp_valid_pct = clamp_pct(rsp_valid_pct);
+    host_d_ready_pct = clamp_pct(host_d_ready_pct);
+    device_a_ready_pct = clamp_pct(device_a_ready_pct);
+    put_full_pct = clamp_pct(put_full_pct);
+    put_partial_pct = clamp_pct(put_partial_pct);
+    if ((put_full_pct + put_partial_pct) > 100) begin
+      put_partial_pct = 100 - put_full_pct;
+    end
+    access_ack_data_pct = clamp_pct(access_ack_data_pct);
+    rsp_error_pct = clamp_pct(rsp_error_pct);
+    rand_state_q = (seed == 0) ? 32'h1 : seed;
+
+    for (int unsigned replay_idx = 0; replay_idx < ReplayDepth; replay_idx++) begin
+      replay_req_valid_q[replay_idx] = 1'b0;
+      replay_req_opcode_q[replay_idx] = '0;
+      replay_req_param_q[replay_idx] = '0;
+      replay_req_size_q[replay_idx] = '0;
+      replay_req_address_q[replay_idx] = '0;
+      replay_req_mask_q[replay_idx] = '0;
+      replay_req_data_q[replay_idx] = '0;
+      replay_req_source_q[replay_idx] = '0;
+      replay_req_spare_q[replay_idx] = '0;
+      replay_host_ready_mode_q[replay_idx] = 2'd2;
+      replay_device_ready_mode_q[replay_idx] = 2'd2;
+      replay_rsp_valid_q[replay_idx] = 1'b0;
+      replay_rsp_opcode_q[replay_idx] = '0;
+      replay_rsp_size_q[replay_idx] = '0;
+      replay_rsp_source_q[replay_idx] = '0;
+      replay_rsp_data_q[replay_idx] = '0;
+      replay_rsp_error_q[replay_idx] = 1'b0;
+    end
+    load_trace_replay_file();
+    if (trace_vcd_file.len() != 0) begin
+      $dumpfile(trace_vcd_file);
+      $dumpvars(0, tlul_fifo_sync_cov_tb);
+    end
+
+    next_rand(rand_word);
+    req_pending_spare_q = rand_word[0];
+    next_rand(rand_word);
+    rsp_pending_spare_q = rand_word[0];
+
+    repeat (reset_cycles) @(posedge clk_i);
+    rst_ni = 1'b1;
+    repeat (2) @(posedge clk_i);
+
+    if (trace_replay_enable != 0) begin
+      for (cycle_idx = 0; cycle_idx < trace_replay_cycles; cycle_idx++) begin
+        @(negedge clk_i);
+        drive_replay_cycle(cycle_idx);
+        @(posedge clk_i);
+        sample_cycle_outputs();
+      end
+    end else begin
+      for (cycle_idx = 0; cycle_idx < batch_length; cycle_idx++) begin
+        @(negedge clk_i);
+        maybe_make_request();
+        maybe_advance_response_delay();
+        maybe_make_response();
+        drive_cycle_inputs();
+        @(posedge clk_i);
+        sample_cycle_outputs();
+      end
+      tl_h_i = tlul_pkg::TL_H2D_DEFAULT;
+      tl_d_i = tlul_pkg::TL_D2H_DEFAULT;
+      spare_req_i = '0;
+      spare_rsp_i = '0;
+
+      for (int unsigned drain_idx = 0; drain_idx < drain_cycles; drain_idx++) begin
+        @(negedge clk_i);
+        maybe_advance_response_delay();
+        maybe_make_response();
+        drive_cycle_inputs();
+        @(posedge clk_i);
+        sample_cycle_outputs();
+      end
+    end
+
+    $display(
+        {"TLUL_FIFO_SYNC_BASELINE_PASS seed=%0d batch_length=%0d ",
+         "host_req_accepted=%0d device_req_accepted=%0d ",
+         "device_rsp_accepted=%0d host_rsp_accepted=%0d ",
+         "rsp_queue_overflow=%0d"},
+        seed,
+        batch_length,
+        host_req_accepted,
+        device_req_accepted,
+        device_rsp_accepted,
+        host_rsp_accepted,
+        rsp_queue_overflow
+    );
+    $finish;
+  end
+
+endmodule
